// RUN: llzk-opt -verify-diagnostics %s | FileCheck --enable-var-scope %s

#map = affine_map<()[s0, s1] -> (s0 + s1)>
module attributes {llzk.lang = "zirgen"} {
  poly.template @TComponent {
    struct.def @Component {
      function.def @compute() -> !struct.type<@TComponent::@Component<[]>> {
        %self = struct.new : !struct.type<@TComponent::@Component<[]>>
        function.return %self : !struct.type<@TComponent::@Component<[]>>
      }

      function.def @constrain(%self: !struct.type<@TComponent::@Component<[]>>) {
        function.return
      }
    }
  }

  struct.def @Reg {
    // ZIR frontend should mark function.return value with `pub`
    struct.member @reg : !felt.type {llzk.pub}

    function.def @compute(%v: !felt.type) -> !struct.type<@Reg> {
      %self = struct.new : !struct.type<@Reg>
      struct.writem %self[@reg] = %v : !struct.type<@Reg>, !felt.type
      function.return %self : !struct.type<@Reg>
    }

    function.def @constrain(%self: !struct.type<@Reg>, %v: !felt.type) {
      %0 = struct.readm %self[@reg] : !struct.type<@Reg>, !felt.type
      constrain.eq %v, %0 : !felt.type
      function.return
    }
  }

  poly.template @TDiv {
    struct.def @Div {
      struct.member @reciprocal : !felt.type
      // ZIR frontend should mark function.return value with `pub`
      struct.member @synthetic_return : !felt.type {llzk.pub}

      function.def @compute(%lhs: !felt.type, %rhs: !felt.type) -> !struct.type<@TDiv::@Div<[]>> attributes {function.allow_non_native_field_ops} {
        %self = struct.new : !struct.type<@TDiv::@Div<[]>>
        // res_inv := inv(rhs);
        %res_inv = felt.inv %rhs
        struct.writem %self[@reciprocal] = %res_inv : !struct.type<@TDiv::@Div<[]>>, !felt.type
        // self.synthetic_return := res_inv * lhs;
        %res_mul = felt.mul %res_inv, %lhs
        struct.writem %self[@synthetic_return] = %res_mul : !struct.type<@TDiv::@Div<[]>>, !felt.type
        //
        function.return %self : !struct.type<@TDiv::@Div<[]>>
      }

      function.def @constrain(%self: !struct.type<@TDiv::@Div<[]>>, %lhs: !felt.type, %rhs: !felt.type) {
        // emit self.reciprocal * rhs = 1;
        %res_inv = struct.readm %self[@reciprocal] : !struct.type<@TDiv::@Div<[]>>, !felt.type
        %res_mul_1 = felt.mul %res_inv, %rhs
        %const_1 = felt.const 1
        constrain.eq %res_mul_1, %const_1 : !felt.type
        // emit self.synthetic_return = self.reciprocal * lhs;
        %res_self = struct.readm %self[@synthetic_return] : !struct.type<@TDiv::@Div<[]>>, !felt.type
        %res_mul_2 = felt.mul %res_inv, %lhs
        constrain.eq %res_self, %res_mul_2 : !felt.type
        //
        function.return
      }
    }
  }

  poly.template @TFoo {
    poly.param @N
    poly.param @P
    poly.param @Aff$0

    struct.def @Foo {
      struct.member @"$super" : !struct.type<@TComponent::@Component<[]>>
      struct.member @"$temp_0" : !struct.type<@TComponent::@Component<[]>>
      struct.member @"$temp" : !struct.type<@TDiv::@Div<[]>>
      function.def @compute(%arg0: !array.type<@Aff$0 x !felt.type>) -> !struct.type<@TFoo::@Foo<[@N, @P, @Aff$0]>> attributes {function.allow_non_native_field_ops} {
        %self = struct.new : !struct.type<@TFoo::@Foo<[@N, @P, @Aff$0]>>
        %0 = poly.read_const @N : !felt.type
        %1 = poly.read_const @P : !felt.type
        %2 = function.call @TDiv::@Div::@compute(%0, %1) : (!felt.type, !felt.type) -> !struct.type<@TDiv::@Div<[]>>
        struct.writem %self[@"$temp"] = %2 : !struct.type<@TFoo::@Foo<[@N, @P, @Aff$0]>>, !struct.type<@TDiv::@Div<[]>>
        %3 = struct.readm %self[@"$temp"] : !struct.type<@TFoo::@Foo<[@N, @P, @Aff$0]>>, !struct.type<@TDiv::@Div<[]>>
        %4 = function.call @TComponent::@Component::@compute() : () -> !struct.type<@TComponent::@Component<[]>>
        struct.writem %self[@"$temp_0"] = %4 : !struct.type<@TFoo::@Foo<[@N, @P, @Aff$0]>>, !struct.type<@TComponent::@Component<[]>>
        %5 = struct.readm %self[@"$temp_0"] : !struct.type<@TFoo::@Foo<[@N, @P, @Aff$0]>>, !struct.type<@TComponent::@Component<[]>>
        struct.writem %self[@"$super"] = %5 : !struct.type<@TFoo::@Foo<[@N, @P, @Aff$0]>>, !struct.type<@TComponent::@Component<[]>>
        function.return %self : !struct.type<@TFoo::@Foo<[@N, @P, @Aff$0]>>
      }
      function.def @constrain(%arg0: !struct.type<@TFoo::@Foo<[@N, @P, @Aff$0]>>, %arg1: !array.type<@Aff$0 x !felt.type>) {
        %0 = poly.read_const @N : !felt.type
        %1 = poly.read_const @P : !felt.type
        %2 = struct.readm %arg0[@"$temp"] : !struct.type<@TFoo::@Foo<[@N, @P, @Aff$0]>>, !struct.type<@TDiv::@Div<[]>>
        function.call @TDiv::@Div::@constrain(%2, %0, %1) : (!struct.type<@TDiv::@Div<[]>>, !felt.type, !felt.type) -> ()
        %3 = struct.readm %arg0[@"$temp_0"] : !struct.type<@TFoo::@Foo<[@N, @P, @Aff$0]>>, !struct.type<@TComponent::@Component<[]>>
        function.call @TComponent::@Component::@constrain(%3) : (!struct.type<@TComponent::@Component<[]>>) -> ()
        function.return
      }
    }
  }

  poly.template @TBar {
    poly.param @N
    poly.param @P
    poly.param @Aff$0

    struct.def @Bar {
      struct.member @"$super" : !struct.type<@TComponent::@Component<[]>>
      struct.member @"$temp_1" : !struct.type<@TComponent::@Component<[]>>
      struct.member @"$temp_0" : !struct.type<@TFoo::@Foo<[@N, @P, #map]>>
      struct.member @"$temp" : !struct.type<@TDiv::@Div<[]>>
      function.def @compute(%arg0: !array.type<@Aff$0 x !felt.type>) -> !struct.type<@TBar::@Bar<[@N, @P, @Aff$0]>> attributes {function.allow_non_native_field_ops} {
        %self = struct.new : !struct.type<@TBar::@Bar<[@N, @P, @Aff$0]>>
        %0 = poly.read_const @N : !felt.type
        %1 = poly.read_const @P : !felt.type
        %2 = function.call @TDiv::@Div::@compute(%0, %1) : (!felt.type, !felt.type) -> !struct.type<@TDiv::@Div<[]>>
        struct.writem %self[@"$temp"] = %2 : !struct.type<@TBar::@Bar<[@N, @P, @Aff$0]>>, !struct.type<@TDiv::@Div<[]>>
        %3 = struct.readm %self[@"$temp"] : !struct.type<@TBar::@Bar<[@N, @P, @Aff$0]>>, !struct.type<@TDiv::@Div<[]>>
        %4 = poly.read_const @N : !felt.type
        %5 = cast.toindex %4
        %6 = poly.read_const @P : !felt.type
        %7 = cast.toindex %6
        %8 = function.call @TFoo::@Foo::@compute(%arg0) {()[%5, %7]} : (!array.type<@Aff$0 x !felt.type>) -> !struct.type<@TFoo::@Foo<[@N, @P, #map]>>
        struct.writem %self[@"$temp_0"] = %8 : !struct.type<@TBar::@Bar<[@N, @P, @Aff$0]>>, !struct.type<@TFoo::@Foo<[@N, @P, #map]>>
        %9 = struct.readm %self[@"$temp_0"] : !struct.type<@TBar::@Bar<[@N, @P, @Aff$0]>>, !struct.type<@TFoo::@Foo<[@N, @P, #map]>>
        %10 = function.call @TComponent::@Component::@compute() : () -> !struct.type<@TComponent::@Component<[]>>
        struct.writem %self[@"$temp_1"] = %10 : !struct.type<@TBar::@Bar<[@N, @P, @Aff$0]>>, !struct.type<@TComponent::@Component<[]>>
        %11 = struct.readm %self[@"$temp_1"] : !struct.type<@TBar::@Bar<[@N, @P, @Aff$0]>>, !struct.type<@TComponent::@Component<[]>>
        struct.writem %self[@"$super"] = %11 : !struct.type<@TBar::@Bar<[@N, @P, @Aff$0]>>, !struct.type<@TComponent::@Component<[]>>
        function.return %self : !struct.type<@TBar::@Bar<[@N, @P, @Aff$0]>>
      }
      function.def @constrain(%arg0: !struct.type<@TBar::@Bar<[@N, @P, @Aff$0]>>, %arg1: !array.type<@Aff$0 x !felt.type>) {
        %0 = poly.read_const @N : !felt.type
        %1 = poly.read_const @P : !felt.type
        %2 = struct.readm %arg0[@"$temp"] : !struct.type<@TBar::@Bar<[@N, @P, @Aff$0]>>, !struct.type<@TDiv::@Div<[]>>
        function.call @TDiv::@Div::@constrain(%2, %0, %1) : (!struct.type<@TDiv::@Div<[]>>, !felt.type, !felt.type) -> ()
        %3 = struct.readm %arg0[@"$temp_0"] : !struct.type<@TBar::@Bar<[@N, @P, @Aff$0]>>, !struct.type<@TFoo::@Foo<[@N, @P, #map]>>
        function.call @TFoo::@Foo::@constrain(%3, %arg1) : (!struct.type<@TFoo::@Foo<[@N, @P, #map]>>, !array.type<@Aff$0 x !felt.type>) -> ()
        %4 = struct.readm %arg0[@"$temp_1"] : !struct.type<@TBar::@Bar<[@N, @P, @Aff$0]>>, !struct.type<@TComponent::@Component<[]>>
        function.call @TComponent::@Component::@constrain(%4) : (!struct.type<@TComponent::@Component<[]>>) -> ()
        function.return
      }
    }
  }
}

