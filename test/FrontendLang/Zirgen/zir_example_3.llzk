// CHECK-NEXT:      %[[VAL_43:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_42]][@"$super"] : <@THead::@Head<[!struct.type<@TA::@A<[1]>>, 2]>>, !struct.type<@TA::@A<[1]>>
// CHECK-NEXT:      %[[VAL_44:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_43]][@"$super"] : <@TA::@A<[1]>>, !struct.type<@THead::@Head<[!felt.type, 3]>>
// CHECK-NEXT:      %[[VAL_45:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_44]][@"$super"] : <@THead::@Head<[!felt.type, 3]>>, !felt.type
// CHECK-NEXT:      constrain.eq %[[VAL_41]], %[[VAL_45]] : !felt.type, !felt.type
