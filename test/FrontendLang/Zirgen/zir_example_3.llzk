// CHECK-NEXT:    struct.member @b : !struct.type<@B>
// CHECK-NEXT:    function.def @compute() -> !struct.type<@Top> attributes {function.allow_witness} {
// CHECK-NEXT:      %[[VAL_33:[0-9a-zA-Z_\.]+]] = struct.new : <@Top>
