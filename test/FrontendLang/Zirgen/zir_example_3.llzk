// CHECK-NEXT:      %[[VAL_36:[0-9a-zA-Z_\.]+]] = function.call @VoidComponent::@compute() : () -> !struct.type<@VoidComponent>
// CHECK-NEXT:      struct.writem %[[VAL_33]][@"$super"] = %[[VAL_36]] : <@Top>, !struct.type<@VoidComponent>
// CHECK-NEXT:      function.return %[[VAL_33]] : !struct.type<@Top>
