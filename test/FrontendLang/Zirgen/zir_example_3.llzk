// CHECK-NEXT:    poly.param @T
// CHECK-NEXT:    poly.param @N
// CHECK-NEXT:    struct.def @Head {
// CHECK-NEXT:      struct.member @"$super" : !poly.tvar<@T> {llzk.pub}
// CHECK-NEXT:      function.def @compute(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !array.type<@N x !poly.tvar<@T>>) -> !struct.type<@THead::@Head<[@T, @N]>> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_1:[0-9a-zA-Z_\.]+]] = struct.new : <@THead::@Head<[@T, @N]>>
// CHECK-NEXT:        %[[VAL_2:[0-9a-zA-Z_\.]+]] = arith.constant 0 : index
// CHECK-NEXT:        %[[VAL_3:[0-9a-zA-Z_\.]+]] = array.read %[[VAL_0]]{{\[}}%[[VAL_2]]] : <@N x !poly.tvar<@T>>, !poly.tvar<@T>
// CHECK-NEXT:        struct.writem %[[VAL_1]][@"$super"] = %[[VAL_3]] : <@THead::@Head<[@T, @N]>>, !poly.tvar<@T>
// CHECK-NEXT:        function.return %[[VAL_1]] : !struct.type<@THead::@Head<[@T, @N]>>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_4:[0-9a-zA-Z_\.]+]]: !struct.type<@THead::@Head<[@T, @N]>>, %[[VAL_5:[0-9a-zA-Z_\.]+]]: !array.type<@N x !poly.tvar<@T>>) attributes {function.allow_constraint} {
// CHECK-NEXT:        %[[VAL_6:[0-9a-zA-Z_\.]+]] = arith.constant 0 : index
// CHECK-NEXT:        %[[VAL_7:[0-9a-zA-Z_\.]+]] = array.read %[[VAL_5]]{{\[}}%[[VAL_6]]] : <@N x !poly.tvar<@T>>, !poly.tvar<@T>
// CHECK-NEXT:        %[[VAL_8:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_4]][@"$super"] : <@THead::@Head<[@T, @N]>>, !poly.tvar<@T>
// CHECK-NEXT:        constrain.eq %[[VAL_7]], %[[VAL_8]] : !poly.tvar<@T>, !poly.tvar<@T>
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }
