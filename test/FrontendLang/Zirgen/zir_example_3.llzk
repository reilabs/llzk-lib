// RUN: llzk-opt -split-input-file %s 2>&1 | FileCheck --enable-var-scope %s

// component Head<T: Type, N: Val>(arr: Array<T, N>) {
//   arr[0]
// }
//
// component A<N: Val>() {
//   Head<Val, 3>([N,N+1,N+2])
// }
//
// component B() {
//   Head<A<1>, 2>([A<1>(), A<1>()])
// }
//
// component Top() {
//   a := A<1>();
//   b := B();
//   a = b;
// }
module attributes {llzk.lang = "zirgen"} {
  poly.template @THead {
    poly.param @T
    poly.param @N

    struct.def @Head {
      struct.member @"$super" : !poly.tvar<@T> {llzk.pub}

      function.def @compute(%arr: !array.type<@N x !poly.tvar<@T>>) -> !struct.type<@THead::@Head<[@T, @N]>> {
        %self = struct.new : !struct.type<@THead::@Head<[@T, @N]>>
        %1 = arith.constant 0 : index
        %2 = array.read %arr[%1] : !array.type<@N x !poly.tvar<@T>>, !poly.tvar<@T>
        struct.writem %self[@"$super"] = %2 : !struct.type<@THead::@Head<[@T, @N]>>, !poly.tvar<@T>
        function.return %self : !struct.type<@THead::@Head<[@T, @N]>>
      }

      function.def @constrain(%self: !struct.type<@THead::@Head<[@T, @N]>>, %arr: !array.type<@N x !poly.tvar<@T>>) {
        %1 = arith.constant 0 : index
        %2 = array.read %arr[%1] : !array.type<@N x !poly.tvar<@T>>, !poly.tvar<@T>
        %3 = struct.readm %self[@"$super"] : !struct.type<@THead::@Head<[@T, @N]>>, !poly.tvar<@T>
        constrain.eq %2, %3 : !poly.tvar<@T>
        function.return
      }
    }
  }

  poly.template @TA {
    poly.param @N

    struct.def @A {
      struct.member @"$super" : !struct.type<@THead::@Head<[!felt.type, 3]>> {llzk.pub}

      function.def @compute() -> !struct.type<@TA::@A<[@N]>> {
        %self = struct.new : !struct.type<@TA::@A<[@N]>>
        %1 = poly.read_const @N : !felt.type
        %2 = felt.const 1
        %3 = felt.const 2
        %4 = felt.add %1, %2
        %5 = felt.add %1, %3
        %6 = array.new %1, %4, %5 : !array.type<3 x !felt.type>
        %7 = function.call @THead::@Head::@compute(%6) : (!array.type<3 x !felt.type>) -> !struct.type<@THead::@Head<[!felt.type, 3]>>
        struct.writem %self[@"$super"] = %7 : !struct.type<@TA::@A<[@N]>>, !struct.type<@THead::@Head<[!felt.type, 3]>>
        function.return %self : !struct.type<@TA::@A<[@N]>>
      }

      function.def @constrain(%self: !struct.type<@TA::@A<[@N]>>) {
        %0 = struct.readm %self[@"$super"] : !struct.type<@TA::@A<[@N]>>, !struct.type<@THead::@Head<[!felt.type, 3]>>
        %1 = poly.read_const @N : !felt.type
        %2 = felt.const 1
        %3 = felt.const 2
        %4 = felt.add %1, %2
        %5 = felt.add %1, %3
        %arr = array.new %1, %4, %5 : !array.type<3 x !felt.type>
        function.call @THead::@Head::@constrain(%0, %arr) : (!struct.type<@THead::@Head<[!felt.type, 3]>>, !array.type<3 x !felt.type>) -> ()
        function.return
      }
    }
  }

  struct.def @B {
    struct.member @"$super" : !struct.type<@THead::@Head<[!struct.type<@TA::@A<[1]>>, 2]>> {llzk.pub}

    function.def @compute() -> !struct.type<@B> {
      %self = struct.new : !struct.type<@B>
      %1 = function.call @TA::@A::@compute() : () -> !struct.type<@TA::@A<[1]>>
      %2 = function.call @TA::@A::@compute() : () -> !struct.type<@TA::@A<[1]>>
      %3 = array.new %1, %2 : !array.type<2 x !struct.type<@TA::@A<[1]>>>
      %4 = function.call @THead::@Head::@compute(%3) : (!array.type<2 x !struct.type<@TA::@A<[1]>>>) -> !struct.type<@THead::@Head<[!struct.type<@TA::@A<[1]>>, 2]>>
      struct.writem %self[@"$super"] = %4 : !struct.type<@B>, !struct.type<@THead::@Head<[!struct.type<@TA::@A<[1]>>, 2]>>
      function.return %self : !struct.type<@B>
    }

    function.def @constrain(%self: !struct.type<@B>) {
      %0 = struct.readm %self[@"$super"] : !struct.type<@B>, !struct.type<@THead::@Head<[!struct.type<@TA::@A<[1]>>, 2]>>
      %arr = array.new : !array.type<2 x !struct.type<@TA::@A<[1]>>>
      function.call @THead::@Head::@constrain(%0, %arr) : (!struct.type<@THead::@Head<[!struct.type<@TA::@A<[1]>>, 2]>>, !array.type<2 x !struct.type<@TA::@A<[1]>>>) -> ()
      function.return
    }
  }

  struct.def @Top {
    struct.member @"$super" : !struct.type<@VoidComponent>
    struct.member @a : !struct.type<@TA::@A<[1]>>
    struct.member @b : !struct.type<@B>

    function.def @compute() -> !struct.type<@Top> {
      %self = struct.new : !struct.type<@Top>
      %1 = function.call @TA::@A::@compute() : () -> !struct.type<@TA::@A<[1]>>
      struct.writem %self[@a] = %1 : !struct.type<@Top>, !struct.type<@TA::@A<[1]>>
      %2 = function.call @B::@compute() : () -> !struct.type<@B>
      struct.writem %self[@b] = %2 : !struct.type<@Top>, !struct.type<@B>
      %3 = function.call @VoidComponent::@compute() : () -> !struct.type<@VoidComponent>
      struct.writem %self[@"$super"] = %3 : !struct.type<@Top>, !struct.type<@VoidComponent>
      function.return %self : !struct.type<@Top>
    }

    function.def @constrain(%self: !struct.type<@Top>) {
      %0 = struct.readm %self[@a] : !struct.type<@Top>, !struct.type<@TA::@A<[1]>>
      function.call @TA::@A::@constrain(%0) : (!struct.type<@TA::@A<[1]>>) -> ()
      %1 = struct.readm %self[@b] : !struct.type<@Top>, !struct.type<@B>
      function.call @B::@constrain(%1) : (!struct.type<@B>) -> ()
      %2 = struct.readm %0[@"$super"] : !struct.type<@TA::@A<[1]>>, !struct.type<@THead::@Head<[!felt.type, 3]>>
      %3 = struct.readm %2[@"$super"] : !struct.type<@THead::@Head<[!felt.type, 3]>>, !felt.type
      %4 = struct.readm %1[@"$super"] : !struct.type<@B>, !struct.type<@THead::@Head<[!struct.type<@TA::@A<[1]>>, 2]>>
      %5 = struct.readm %4[@"$super"] : !struct.type<@THead::@Head<[!struct.type<@TA::@A<[1]>>, 2]>>, !struct.type<@TA::@A<[1]>>
      %6 = struct.readm %5[@"$super"] : !struct.type<@TA::@A<[1]>>, !struct.type<@THead::@Head<[!felt.type, 3]>>
      %7 = struct.readm %6[@"$super"] : !struct.type<@THead::@Head<[!felt.type, 3]>>, !felt.type
      constrain.eq %3, %7 : !felt.type
      %8 = struct.readm %self[@"$super"]: !struct.type<@Top>, !struct.type<@VoidComponent>
      function.call @VoidComponent::@constrain(%8) : (!struct.type<@VoidComponent>) -> ()
      function.return
    }
  }

  struct.def @VoidComponent {
    function.def @compute() -> !struct.type<@VoidComponent> {
      %self = struct.new : !struct.type<@VoidComponent>
      function.return %self : !struct.type<@VoidComponent>
    }

    function.def @constrain(%self: !struct.type<@VoidComponent>) { function.return }
  }
}

