// RUN: llzk-opt -split-input-file %s 2>&1 | FileCheck --enable-var-scope %s

//////////////////////////////////////////////////////////////////////////////////
// Circom source:
//
// template A(N){
//    signal input in;
//    signal output out;
//    out <== in;
// }
// template B(N){
//   signal output out;
//   component a;
//   if(N > 0){
//      a = A(N);
//   } else {
//      a = A(0);
//   }
//   a.in <== 1;
//   a.out ==> out;
// }
//
// component main = B(1);
//////////////////////////////////////////////////////////////////////////////////

// Another possible LLZK translation of the above Circom code, using `poly.expr` but it must still be cast to the
// affine_map type to be stored in the struct since that's the only way to represent the heterogeneous component type.
#id = affine_map<(s0) -> (s0)>
!AAnyN = !struct.type<@TA::@A<[#id]>>

module attributes {llzk.lang = "circom"} {
  poly.template @TA {
    poly.param @N

    struct.def @A {
      struct.member @out : !felt.type {llzk.pub}

      function.def @compute(%in: !felt.type) -> !struct.type<@TA::@A<[@N]>> {
        %self = struct.new : !struct.type<@TA::@A<[@N]>>
        struct.writem %self[@out] = %in : !struct.type<@TA::@A<[@N]>>, !felt.type
        function.return %self : !struct.type<@TA::@A<[@N]>>
      }

      function.def @constrain(%self: !struct.type<@TA::@A<[@N]>>, %in: !felt.type) {
        %out = struct.readm %self[@out] : !struct.type<@TA::@A<[@N]>>, !felt.type
        constrain.eq %out, %in : !felt.type
        function.return
      }
    }
  }

  poly.template @TB {
    poly.param @N
    poly.expr @EN {
      %n = poly.read_const @N : !felt.type
      %zero = felt.const 0
      %cond = bool.cmp gt(%n, %zero) : !felt.type, !felt.type
      %r = scf.if %cond -> (!felt.type) {
        scf.yield %n : !felt.type
      } else {
        %nondet = llzk.nondet : !felt.type
        scf.yield %nondet : !felt.type
      }
      poly.yield %r : !felt.type
    }
    poly.expr @E0 {
      %n = poly.read_const @N : !felt.type
      %zero = felt.const 0
      %cond = bool.cmp gt(%n, %zero) : !felt.type, !felt.type
      %r = scf.if %cond -> (!felt.type) {
        %nondet = llzk.nondet : !felt.type
        scf.yield %nondet : !felt.type
      } else {
        scf.yield %zero : !felt.type
      }
      poly.yield %r : !felt.type
    }

    struct.def @B {
      struct.member @a : !AAnyN
      struct.member @out : !felt.type {llzk.pub}

      function.def @compute() -> !struct.type<@TB::@B<[@N]>> {
        %self = struct.new : !struct.type<@TB::@B<[@N]>>

        %n_felt = poly.read_const @N : !felt.type
        %n_idx = poly.read_const @N : index
        %zero_felt = felt.const 0
        %one_felt = felt.const 1
        %zero_idx = arith.constant 0 : index

        %cond = bool.cmp gt(%n_felt, %zero_felt) : !felt.type, !felt.type
        %a = scf.if %cond -> (!AAnyN) {
          %a_then = function.call @TA::@A::@compute(%one_felt) : (!felt.type) -> !struct.type<@TA::@A<[@EN]>>
          %a_then_cast = poly.unifiable_cast %a_then : (!struct.type<@TA::@A<[@EN]>>) -> !AAnyN
          scf.yield %a_then_cast : !AAnyN
        } else {
          %a_else = function.call @TA::@A::@compute(%one_felt) : (!felt.type) -> !struct.type<@TA::@A<[@E0]>>
          %a_else_cast = poly.unifiable_cast %a_else : (!struct.type<@TA::@A<[@E0]>>) -> !AAnyN
          scf.yield %a_else_cast : !AAnyN
        }

        struct.writem %self[@a] = %a : !struct.type<@TB::@B<[@N]>>, !AAnyN

        %a_out = struct.readm %a[@out] : !AAnyN, !felt.type
        struct.writem %self[@out] = %a_out : !struct.type<@TB::@B<[@N]>>, !felt.type

        function.return %self : !struct.type<@TB::@B<[@N]>>
      }

      function.def @constrain(%self: !struct.type<@TB::@B<[@N]>>) {
        %a = struct.readm %self[@a] : !struct.type<@TB::@B<[@N]>>, !AAnyN
        %out = struct.readm %self[@out] : !struct.type<@TB::@B<[@N]>>, !felt.type

        %n_felt = poly.read_const @N : !felt.type
        %n_idx = poly.read_const @N : index
        %zero_felt = felt.const 0
        %one_felt = felt.const 1
        %zero_idx = arith.constant 0 : index

        // No matter the condition, the constrain function signature is the same
        function.call @TA::@A::@constrain(%a, %one_felt) : (!AAnyN, !felt.type) -> ()

        %a_out = struct.readm %a[@out] : !AAnyN, !felt.type
        constrain.eq %out, %a_out : !felt.type

        function.return
      }
    }
  }

  struct.def @Main {
    struct.member @sub : !struct.type<@TB::@B<[1]>>

    function.def @compute() -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      %sub = function.call @TB::@B::@compute() : () -> !struct.type<@TB::@B<[1]>>
      struct.writem %self[@sub] = %sub : !struct.type<@Main>, !struct.type<@TB::@B<[1]>>
      function.return %self : !struct.type<@Main>
    }

    function.def @constrain(%self: !struct.type<@Main>) {
      %sub = struct.readm %self[@sub] : !struct.type<@Main>, !struct.type<@TB::@B<[1]>>
      function.call @TB::@B::@constrain(%sub) : (!struct.type<@TB::@B<[1]>>) -> ()
      function.return
    }
  }
}
// CHECK: #[[$ATTR_0:[0-9a-zA-Z_\.]+]] = affine_map<(d0) -> (d0)>
//
// CHECK-LABEL: module attributes {llzk.lang = "circom"} {
// CHECK-NEXT:    poly.template @TA {
// CHECK-NEXT:      poly.param @N
// CHECK-NEXT:      struct.def @A {
// CHECK-NEXT:        struct.member @out : !felt.type {llzk.pub}
// CHECK-NEXT:        function.def @compute(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !felt.type) -> !struct.type<@TA::@A<[@N]>> attributes {function.allow_witness} {
// CHECK-NEXT:          %[[VAL_1:[0-9a-zA-Z_\.]+]] = struct.new : <@TA::@A<[@N]>>
// CHECK-NEXT:          struct.writem %[[VAL_1]][@out] = %[[VAL_0]] : <@TA::@A<[@N]>>, !felt.type
// CHECK-NEXT:          function.return %[[VAL_1]] : !struct.type<@TA::@A<[@N]>>
// CHECK-NEXT:        }
// CHECK-NEXT:        function.def @constrain(%[[VAL_2:[0-9a-zA-Z_\.]+]]: !struct.type<@TA::@A<[@N]>>, %[[VAL_3:[0-9a-zA-Z_\.]+]]: !felt.type) attributes {function.allow_constraint} {
// CHECK-NEXT:          %[[VAL_4:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_2]][@out] : <@TA::@A<[@N]>>, !felt.type
// CHECK-NEXT:          constrain.eq %[[VAL_4]], %[[VAL_3]] : !felt.type, !felt.type
// CHECK-NEXT:          function.return
// CHECK-NEXT:        }
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:    poly.template @TB {
