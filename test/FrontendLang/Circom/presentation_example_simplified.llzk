// RUN: llzk-opt -split-input-file %s 2>&1 | FileCheck --enable-var-scope %s

module attributes {llzk.lang, llzk.main = !struct.type<@Main<[]>>} {
  poly.template @GetWeight {
    poly.param @A
    struct.def @S {
      struct.member @out : !felt.type<"bn128"> {llzk.pub}
      function.def @compute(%arg0: !felt.type<"bn128">) -> !struct.type<@GetWeight::@S<[@A]>> attributes {function.allow_non_native_field_ops, function.allow_witness} {
        %self = struct.new : !struct.type<@GetWeight::@S<[@A]>>
        function.return %self : !struct.type<@GetWeight::@S<[@A]>>
      }
      function.def @constrain(%arg0: !struct.type<@GetWeight::@S<[@A]>>, %arg1: !felt.type<"bn128">) attributes {function.allow_constraint, function.allow_non_native_field_ops} {
        %1 = struct.readm %arg0[@out] : !struct.type<@GetWeight::@S<[@A]>>, !felt.type<"bn128">
        function.return
      }
    }
  }

  struct.def @Main {
    struct.member @ret : !array.type<2 x !felt.type<"bn128">> {llzk.pub}
    struct.member @w1 : !struct.type<@GetWeight::@S<[99]>>
    struct.member @w2 : !struct.type<@GetWeight::@S<[88]>>
    function.def @compute(%arg0: !array.type<2 x !felt.type<"bn128">>) -> !struct.type<@Main<[]>> attributes {function.allow_non_native_field_ops, function.allow_witness} {
      %self = struct.new : !struct.type<@Main<[]>>
      %arr = array.new : !array.type<2 x !felt.type<"bn128">>
      %idx0 = arith.constant 0 : index
      %inp0 = array.read %arg0[%idx0] : !array.type<2 x !felt.type<"bn128">>, !felt.type<"bn128">
      %comp0 = function.call @GetWeight::@S::@compute(%inp0) : (!felt.type<"bn128">) -> !struct.type<@GetWeight::@S<[99]>>
      struct.writem %self[@w1] = %comp0 : !struct.type<@Main<[]>>, !struct.type<@GetWeight::@S<[99]>>
      %out0 = struct.readm %comp0[@out] : !struct.type<@GetWeight::@S<[99]>>, !felt.type<"bn128">
      array.write %arr[%idx0] = %out0 : !array.type<2 x !felt.type<"bn128">>, !felt.type<"bn128">
      %idx1 = arith.constant 1 : index
      %inp1 = array.read %arg0[%idx1] : !array.type<2 x !felt.type<"bn128">>, !felt.type<"bn128">
      %comp1 = function.call @GetWeight::@S::@compute(%inp1) : (!felt.type<"bn128">) -> !struct.type<@GetWeight::@S<[88]>>
      struct.writem %self[@w2] = %comp1 : !struct.type<@Main<[]>>, !struct.type<@GetWeight::@S<[88]>>
      %out1 = struct.readm %comp1[@out] : !struct.type<@GetWeight::@S<[88]>>, !felt.type<"bn128">
      array.write %arr[%idx1] = %out1 : !array.type<2 x !felt.type<"bn128">>, !felt.type<"bn128">
      struct.writem %self[@ret] = %arr : !struct.type<@Main<[]>>, !array.type<2 x !felt.type<"bn128">>
      function.return %self : !struct.type<@Main<[]>>
    }
    function.def @constrain(%arg0: !struct.type<@Main<[]>>, %arg1: !array.type<2 x !felt.type<"bn128">>) attributes {function.allow_constraint, function.allow_non_native_field_ops} {
      %ret = struct.readm %arg0[@ret] : !struct.type<@Main<[]>>, !array.type<2 x !felt.type<"bn128">>
      %sc1 = struct.readm %arg0[@w1] : !struct.type<@Main<[]>>, !struct.type<@GetWeight::@S<[99]>>
      %sc2 = struct.readm %arg0[@w2] : !struct.type<@Main<[]>>, !struct.type<@GetWeight::@S<[88]>>
      %idx0 = arith.constant 0 : index
      %inp0 = array.read %arg1[%idx0] : !array.type<2 x !felt.type<"bn128">>, !felt.type<"bn128">
      %sc1_out = struct.readm %sc1[@out] : !struct.type<@GetWeight::@S<[99]>>, !felt.type<"bn128">
      %ret0 = array.read %ret[%idx0] : !array.type<2 x !felt.type<"bn128">>, !felt.type<"bn128">
      constrain.eq %ret0, %sc1_out : !felt.type<"bn128">, !felt.type<"bn128">
      function.call @GetWeight::@S::@constrain(%sc1, %inp0) : (!struct.type<@GetWeight::@S<[99]>>, !felt.type<"bn128">) -> ()
      %idx1 = arith.constant 1 : index
      %inp1 = array.read %arg1[%idx1] : !array.type<2 x !felt.type<"bn128">>, !felt.type<"bn128">
      %sc2_out = struct.readm %sc2[@out] : !struct.type<@GetWeight::@S<[88]>>, !felt.type<"bn128">
      %ret1 = array.read %ret[%idx1] : !array.type<2 x !felt.type<"bn128">>, !felt.type<"bn128">
      constrain.eq %ret1, %sc2_out : !felt.type<"bn128">, !felt.type<"bn128">
      function.call @GetWeight::@S::@constrain(%sc2, %inp1) : (!struct.type<@GetWeight::@S<[88]>>, !felt.type<"bn128">) -> ()
      function.return
    }
  }
}

