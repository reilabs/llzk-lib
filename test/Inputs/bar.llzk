module attributes {llzk.lang} {
  poly.template @TFoo {
    poly.param @N

    struct.def @Foo {
      struct.member @x : !array.type<@N x !felt.type>
      function.def @compute() -> !struct.type<@TFoo::@Foo<[@N]>> attributes {function.allow_witness} {
        %self = struct.new : <@TFoo::@Foo<[@N]>>
        function.return %self : !struct.type<@TFoo::@Foo<[@N]>>
      }
      function.def @constrain(%arg0: !struct.type<@TFoo::@Foo<[@N]>>) attributes {function.allow_constraint} {
        function.return
      }
    }
  }
}
