      }
      function.def @constrain(%self: !struct.type<@TComponent1A::@Component1A<[@S]>>) {
        %0 = struct.readm %self[@f] : !struct.type<@TComponent1A::@Component1A<[@S]>>, !struct.type<@TComponent1B::@Component1B<[@S]>>
