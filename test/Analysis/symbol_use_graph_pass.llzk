        %self = struct.new : !struct.type<@TComponent1B::@Component1B<[@T]>>
        function.return %self : !struct.type<@TComponent1B::@Component1B<[@T]>>
      }
      function.def @constrain(%self: !struct.type<@TComponent1B::@Component1B<[@T]>>) {
