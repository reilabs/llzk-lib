module attributes {llzk.lang} {
  module @FreeFuncModule {
    module @Level2A {
      module @Level3 {
        function.def @struct_param(%a: !struct.type<@StructModule::@MoreNested::@THasUse::@HasUse<[!felt.type]>>) -> !felt.type {
          %b = felt.const 42
          function.return %b: !felt.type
        }
      }
    }
    module @Level2B {
      module @Level3 {
        function.def @struct_param(%a: !struct.type<@StructModule::@MoreNested::@THasUse::@HasUse<[!felt.type]>>) -> !felt.type {
          %b = felt.const 42
          function.return %b: !felt.type
        }
      }
    }
  }

  module @StructModule {
    module @MoreNested {
      poly.template @THasUse {
        poly.param @T

        struct.def @HasUse {
          function.def @compute() -> !struct.type<@StructModule::@MoreNested::@THasUse::@HasUse<[@T]>> {
            %self = struct.new : !struct.type<@StructModule::@MoreNested::@THasUse::@HasUse<[@T]>>
            function.return %self : !struct.type<@StructModule::@MoreNested::@THasUse::@HasUse<[@T]>>
          }
          function.def @constrain(%arg0: !struct.type<@StructModule::@MoreNested::@THasUse::@HasUse<[@T]>>) {
            function.return
          }
        }
      }

      struct.def @NoUse {
        function.def @compute() -> !struct.type<@StructModule::@MoreNested::@NoUse> {
          %self = struct.new : !struct.type<@StructModule::@MoreNested::@NoUse>
          function.return %self : !struct.type<@StructModule::@MoreNested::@NoUse>
        }
        function.def @constrain(%arg0: !struct.type<@StructModule::@MoreNested::@NoUse>) {
          function.return
        }
      }
    }
  }
}
