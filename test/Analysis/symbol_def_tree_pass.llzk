module attributes {llzk.lang} {
  poly.template @MyTemplate {
    poly.param @A
    poly.param @B
    poly.expr @C {
      %a = poly.read_const @A : !felt.type
      %b = poly.read_const @B : !felt.type
      %c = felt.add %a, %b
      poly.yield %c : !felt.type
    }

    struct.def @MyStruct {
      function.def @compute() -> !struct.type<@MyTemplate::@MyStruct<[@A, @B]>> {
        %self = struct.new : !struct.type<@MyTemplate::@MyStruct<[@A, @B]>>
        function.return %self : !struct.type<@MyTemplate::@MyStruct<[@A, @B]>>
      }
      function.def @constrain(%arg0: !struct.type<@MyTemplate::@MyStruct<[@A, @B]>>) {
        function.return
      }
    }

    function.def private @MyFunc () -> !felt.type
  }
}
