module attributes {llzk.lang} {
  module @GlobalsWithinNestedModule {
    global.def @a : !struct.type<@THasUse::@HasUse<[!felt.type]>>
    module @NestedAgain {
      global.def @a : !struct.type<@THasUse::@HasUse<[!felt.type]>>
      module @NestedEvenMore {
        global.def @a : !struct.type<@THasUse::@HasUse<[!felt.type]>>
      }
      global.def @b : !struct.type<@THasUse::@HasUse<[i1]>>
      module @SiblingNesting {
        global.def @a : !struct.type<@THasUse::@HasUse<[!string.type]>>
      }
    }
  }

  poly.template @THasUse {
    poly.param @T

    struct.def @HasUse {
      function.def @compute() -> !struct.type<@THasUse::@HasUse<[@T]>> {
        %self = struct.new : !struct.type<@THasUse::@HasUse<[@T]>>
        function.return %self : !struct.type<@THasUse::@HasUse<[@T]>>
      }
      function.def @constrain(%arg0: !struct.type<@THasUse::@HasUse<[@T]>>) {
        function.return
      }
    }
  }

  struct.def @NoUse {
    function.def @compute() -> !struct.type<@NoUse> {
      %self = struct.new : !struct.type<@NoUse>
      function.return %self : !struct.type<@NoUse>
    }
    function.def @constrain(%arg0: !struct.type<@NoUse>) {
      function.return
    }
  }
}
