module attributes {llzk.lang} {
  global.def @a : !struct.type<@StructsWithinNestedModule::@THasUse::@HasUse<[i1]>>
  global.def @b : !felt.type

  module @StructsWithinNestedModule {
    poly.template @THasUse {
      poly.param @T

      struct.def @HasUse {
        struct.member @f1 : !poly.tvar<@T>
        function.def @compute() -> !struct.type<@StructsWithinNestedModule::@THasUse::@HasUse<[@T]>> {
          %self = struct.new : !struct.type<@StructsWithinNestedModule::@THasUse::@HasUse<[@T]>>
          function.return %self : !struct.type<@StructsWithinNestedModule::@THasUse::@HasUse<[@T]>>
        }
        function.def @constrain(%arg0: !struct.type<@StructsWithinNestedModule::@THasUse::@HasUse<[@T]>>) {
          function.return
        }
      }
    }

    struct.def @NoUse {
      struct.member @f2 : i1
      struct.member @f3 : !felt.type
      function.def @compute() -> !struct.type<@StructsWithinNestedModule::@NoUse> {
        %self = struct.new : !struct.type<@StructsWithinNestedModule::@NoUse>
        function.return %self : !struct.type<@StructsWithinNestedModule::@NoUse>
      }
      function.def @constrain(%arg0: !struct.type<@StructsWithinNestedModule::@NoUse>) {
        function.return
      }
    }
  }
}
