        %30 = felt.mul %29, %28 : !felt.type, !felt.type
        %31 = cast.toindex %felt_const_1
        %32 = array.read %array[%31] : <2 x !struct.type<@TNondetReg::@NondetReg<[]>>>, !struct.type<@TNondetReg::@NondetReg<[]>>
        %33 = struct.readm %32[@"$super"] : <@TNondetReg::@NondetReg<[]>>, !felt.type
        constrain.eq %30, %33 : !felt.type, !felt.type
