        %12 = struct.readm %arg0[@"$temp_0"] : <@TEdwards2Montgomery::@Edwards2Montgomery<[]>>, !struct.type<@TDiv::@Div<[]>>
        function.call @TDiv::@Div::@constrain(%12, %11, %10) : (!struct.type<@TDiv::@Div<[]>>, !felt.type, !felt.type) -> ()
        %13 = struct.readm %12[@"$super"] : <@TDiv::@Div<[]>>, !felt.type
        %14 = struct.readm %arg0[@"$temp_1"] : <@TEdwards2Montgomery::@Edwards2Montgomery<[]>>, !struct.type<@TNondetReg::@NondetReg<[]>>
        function.call @TNondetReg::@NondetReg::@constrain(%14, %13) : (!struct.type<@TNondetReg::@NondetReg<[]>>, !felt.type) -> ()
        %array = array.new %8, %14 : <2 x !struct.type<@TNondetReg::@NondetReg<[]>>>
        %15 = cast.toindex %felt_const_0
        %16 = array.read %array[%15] : <2 x !struct.type<@TNondetReg::@NondetReg<[]>>>, !struct.type<@TNondetReg::@NondetReg<[]>>
        %17 = cast.toindex %felt_const_1
        %18 = array.read %arg1[%17] : <2 x !felt.type>, !felt.type
        %19 = felt.sub %felt_const_1, %18 : !felt.type, !felt.type
        %20 = struct.readm %16[@"$super"] : <@TNondetReg::@NondetReg<[]>>, !felt.type
        %21 = felt.mul %20, %19 : !felt.type, !felt.type
        %22 = cast.toindex %felt_const_1
        %23 = array.read %arg1[%22] : <2 x !felt.type>, !felt.type
        %24 = felt.add %23, %felt_const_1 : !felt.type, !felt.type
        constrain.eq %21, %24 : !felt.type, !felt.type
