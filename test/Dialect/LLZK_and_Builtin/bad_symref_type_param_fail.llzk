}
// -----
module attributes {llzk.lang} {
  poly.template @TA {
    poly.param @T

    struct.def @A {
      function.def @compute() -> !struct.type<@TA::@A<[@T]>> {
        %self = struct.new : !struct.type<@TA::@A<[@T]>>
        function.return %self : !struct.type<@TA::@A<[@T]>>
      }
      function.def @constrain(%self: !struct.type<@TA::@A<[@T]>>) { function.return }
    }
  }

  // expected-error@+1 {{'function.def' op references unknown symbol "@Unknown"}}
  function.def private @in_arg_deep(
    !array.type<2 x !struct.type<@TA::@A<[
      !struct.type<@TA::@A<[
        !array.type<2 x !struct.type<@TA::@A<[
          !array.type<2 x !struct.type<@TA::@A<[
            !struct.type<@TA::@A<[!poly.tvar<@Unknown>]>>
          ]>>>
        ]>>>
      ]>>
    ]>>>) -> i1

}
