module attributes {llzk.lang} {
  poly.template @TReadArrayOpWithUnknownInResultTypeArrElem {
    poly.param @T

    struct.def @ReadArrayOpWithUnknownInResultTypeArrElem {
      function.def @compute(%arr: !array.type<5 x !poly.tvar<@T>>) -> !struct.type<@TReadArrayOpWithUnknownInResultTypeArrElem::@ReadArrayOpWithUnknownInResultTypeArrElem<[@T]>> {
        %self = struct.new : !struct.type<@TReadArrayOpWithUnknownInResultTypeArrElem::@ReadArrayOpWithUnknownInResultTypeArrElem<[@T]>>
        function.return %self : !struct.type<@TReadArrayOpWithUnknownInResultTypeArrElem::@ReadArrayOpWithUnknownInResultTypeArrElem<[@T]>>
      }
      function.def @constrain(%self: !struct.type<@TReadArrayOpWithUnknownInResultTypeArrElem::@ReadArrayOpWithUnknownInResultTypeArrElem<[@T]>>, %arr: !array.type<5 x !poly.tvar<@T>>) {
        %k = arith.constant 0 : index
