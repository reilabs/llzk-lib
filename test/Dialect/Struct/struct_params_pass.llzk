module attributes {llzk.lang} {
  poly.template @TComponentB1 {
    poly.param @A

    struct.def @ComponentB1 {
      struct.member @f1 : !felt.type {llzk.pub}

      function.def @compute() -> !struct.type<@TComponentB1::@ComponentB1<[@A]>> {
