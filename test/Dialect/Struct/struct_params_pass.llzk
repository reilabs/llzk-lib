module attributes {llzk.lang} {
  poly.template @TComponentF1 {
    poly.param @A

    struct.def @ComponentF1 {
      struct.member @f : !array.type<@A,@A x index>

      function.def @compute(%0: !array.type<@A,@A x index>) -> !struct.type<@TComponentF1::@ComponentF1<[@A]>> {
        %self = struct.new : !struct.type<@TComponentF1::@ComponentF1<[@A]>>
        struct.writem %self[@f] = %0 : !struct.type<@TComponentF1::@ComponentF1<[@A]>>, !array.type<@A,@A x index>
        function.return %self : !struct.type<@TComponentF1::@ComponentF1<[@A]>>
      }
      function.def @constrain(%self: !struct.type<@TComponentF1::@ComponentF1<[@A]>>, %0: !array.type<@A,@A x index>) {
        %b = struct.readm %self[@f] : !struct.type<@TComponentF1::@ComponentF1<[@A]>>, !array.type<@A,@A x index>
        function.return
      }
    }
  }

  function.def @producer() -> !array.type<2,2 x index> {
    %1 = arith.constant 11 : index
    %2 = arith.constant 22 : index
    %3 = arith.constant 33 : index
    %4 = arith.constant 44 : index
    %r = array.new %1, %2, %3, %4 : !array.type<2,2 x index>
    function.return %r: !array.type<2,2 x index>
  }

  struct.def @ComponentF2 {
    struct.member @g : !struct.type<@TComponentF1::@ComponentF1<[2]>>

    function.def @compute() -> !struct.type<@ComponentF2> {
      %self = struct.new : !struct.type<@ComponentF2>
      %0 = function.call @producer() : () -> !array.type<2,2 x index>
      %1 = function.call @TComponentF1::@ComponentF1::@compute(%0) : (!array.type<2,2 x index>) -> !struct.type<@TComponentF1::@ComponentF1<[2]>>
      struct.writem %self[@g] = %1 : !struct.type<@ComponentF2>, !struct.type<@TComponentF1::@ComponentF1<[2]>>
      function.return %self : !struct.type<@ComponentF2>
    }
    function.def @constrain(%self: !struct.type<@ComponentF2>) {
      function.return
    }
  }
}
