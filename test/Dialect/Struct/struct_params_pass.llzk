// RUN: llzk-opt -split-input-file %s 2>&1 | FileCheck --enable-var-scope %s

module attributes {llzk.lang} {
  poly.template @TComponentA1 {
    poly.param @A
    poly.param @B

    struct.def @ComponentA1 {
      function.def @compute() -> !struct.type<@TComponentA1::@ComponentA1<[@A, @B]>> {
        %self = struct.new : !struct.type<@TComponentA1::@ComponentA1<[@A, @B]>>
        function.return %self : !struct.type<@TComponentA1::@ComponentA1<[@A, @B]>>
      }
      function.def @constrain(%self: !struct.type<@TComponentA1::@ComponentA1<[@A, @B]>>) { function.return }
    }
  }

  poly.template @TComponentA2 {
    poly.param @C

    struct.def @ComponentA2 {
      struct.member @f2 : !struct.type<@TComponentA1::@ComponentA1<[5, @C]>>

      function.def @compute() -> !struct.type<@TComponentA2::@ComponentA2<[@C]>> {
        %self = struct.new : !struct.type<@TComponentA2::@ComponentA2<[@C]>>
        %x = function.call @TComponentA1::@ComponentA1::@compute() : () -> (!struct.type<@TComponentA1::@ComponentA1<[5, @C]>>)
        struct.writem %self[@f2] = %x : !struct.type<@TComponentA2::@ComponentA2<[@C]>>, !struct.type<@TComponentA1::@ComponentA1<[5, @C]>>
        function.return %self : !struct.type<@TComponentA2::@ComponentA2<[@C]>>
      }

      function.def @constrain(%self: !struct.type<@TComponentA2::@ComponentA2<[@C]>>) {
        %b = struct.readm %self[@f2] : !struct.type<@TComponentA2::@ComponentA2<[@C]>>, !struct.type<@TComponentA1::@ComponentA1<[5, @C]>>
        function.call @TComponentA1::@ComponentA1::@constrain(%b) : (!struct.type<@TComponentA1::@ComponentA1<[5, @C]>>) -> ()
        function.return
      }
    }
  }

  struct.def @ComponentA3 {
    struct.member @f3 : !struct.type<@TComponentA2::@ComponentA2<[43]>>

    function.def @compute() -> !struct.type<@ComponentA3> {
      %self = struct.new : !struct.type<@ComponentA3>
      %x = function.call @TComponentA2::@ComponentA2::@compute() : () -> (!struct.type<@TComponentA2::@ComponentA2<[43]>>)
      struct.writem %self[@f3] = %x : !struct.type<@ComponentA3>, !struct.type<@TComponentA2::@ComponentA2<[43]>>
      function.return %self : !struct.type<@ComponentA3>
    }

    function.def @constrain(%self: !struct.type<@ComponentA3>) {
      %b = struct.readm %self[@f3] : !struct.type<@ComponentA3>, !struct.type<@TComponentA2::@ComponentA2<[43]>>
      function.call @TComponentA2::@ComponentA2::@constrain(%b) : (!struct.type<@TComponentA2::@ComponentA2<[43]>>) -> ()
      function.return
    }
  }
}
