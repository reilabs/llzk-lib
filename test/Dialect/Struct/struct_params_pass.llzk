    }
  }

  poly.template @TComponentB2 {
    poly.param @C

    struct.def @ComponentB2 {
      struct.member @f2 : !felt.type

      function.def @compute(%0: !struct.type<@TComponentB1::@ComponentB1<[@C]>>) -> !struct.type<@TComponentB2::@ComponentB2<[@C]>> {
        %self = struct.new : !struct.type<@TComponentB2::@ComponentB2<[@C]>>
        %a = struct.readm %0[@f1] : !struct.type<@TComponentB1::@ComponentB1<[@C]>>, !felt.type
        struct.writem %self[@f2] = %a : !struct.type<@TComponentB2::@ComponentB2<[@C]>>, !felt.type
        function.return %self : !struct.type<@TComponentB2::@ComponentB2<[@C]>>
      }

      function.def @constrain(%self: !struct.type<@TComponentB2::@ComponentB2<[@C]>>, %0: !struct.type<@TComponentB1::@ComponentB1<[@C]>>) {
        function.return
      }
