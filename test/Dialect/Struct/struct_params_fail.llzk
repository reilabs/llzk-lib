module attributes {llzk.lang} {
  function.def private @some_function() -> ()
  poly.template @TComponentT1 {
    poly.param @Z

    struct.def @ComponentT1 {
      function.def @compute() -> !struct.type<@TComponentT1::@ComponentT1<[@Z]>> {
        %self = struct.new : !struct.type<@TComponentT1::@ComponentT1<[@Z]>>
        function.return %self : !struct.type<@TComponentT1::@ComponentT1<[@Z]>>
      }
      function.def @constrain(%self: !struct.type<@TComponentT1::@ComponentT1<[@Z]>>)  { function.return }
    }
  }
  struct.def @ComponentT2 {
    // expected-error@+1 {{ref "@some_function" in type '!struct.type<@TComponentT1::@ComponentT1<[@some_function]>>' refers to a 'function.def' which is not allowed}}
    struct.member @f : !struct.type<@TComponentT1::@ComponentT1<[@some_function]>>

    function.def @compute() -> !struct.type<@ComponentT2> {
      %self = struct.new : !struct.type<@ComponentT2>
      function.return %self : !struct.type<@ComponentT2>
    }
    function.def @constrain(%self: !struct.type<@ComponentT2>)  { function.return }
  }
}
