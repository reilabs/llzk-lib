// RUN: llzk-opt -split-input-file -verify-diagnostics %s

module attributes {llzk.lang} {
  poly.template @TComponentA1 {
    poly.param @A
    poly.param @B

    struct.def @ComponentA1 {
      function.def @compute() -> !struct.type<@TComponentA1::@ComponentA1<[@A, @B]>> {
        %self = struct.new : !struct.type<@TComponentA1::@ComponentA1<[@A, @B]>>
        function.return %self : !struct.type<@TComponentA1::@ComponentA1<[@A, @B]>>
      }
      function.def @constrain(%self: !struct.type<@TComponentA1::@ComponentA1<[@A, @B]>>) { function.return }
    }
  }

  poly.template @TComponentA2 {
    poly.param @C

    struct.def @ComponentA2 {
      // expected-error@+1 {{'struct.type' type has 3 parameters but "ComponentA1" expects 2}}
      struct.member @f3 : !struct.type<@TComponentA1::@ComponentA1<[5, @C, 6]>>

      function.def @compute() -> !struct.type<@TComponentA2::@ComponentA2<[@C]>> {
        %self = struct.new : !struct.type<@TComponentA2::@ComponentA2<[@C]>>
        function.return %self : !struct.type<@TComponentA2::@ComponentA2<[@C]>>
      }

      function.def @constrain(%self: !struct.type<@TComponentA2::@ComponentA2<[@C]>>) { function.return }
    }
  }
}
// -----
module attributes {llzk.lang} {
  poly.template @TComponentB1 {
    poly.param @A
    poly.param @B

    struct.def @ComponentB1 {
      function.def @compute() -> !struct.type<@TComponentB1::@ComponentB1<[@A, @B]>> {
        %self = struct.new : !struct.type<@TComponentB1::@ComponentB1<[@A, @B]>>
        function.return %self : !struct.type<@TComponentB1::@ComponentB1<[@A, @B]>>
      }
      function.def @constrain(%self: !struct.type<@TComponentB1::@ComponentB1<[@A, @B]>>) { function.return }
    }
  }

  struct.def @ComponentB2 {
    struct.member @f3 : !struct.type<@TComponentB1::@ComponentB1<[5,5]>>

    function.def @compute() -> !struct.type<@ComponentB2> {
      %self = struct.new : !struct.type<@ComponentB2>
      function.return %self : !struct.type<@ComponentB2>
    }

    function.def @constrain(%self: !struct.type<@ComponentB2>) {
      // expected-error@+1 {{'struct.readm' op has wrong type; expected '!struct.type<@TComponentB1::@ComponentB1<[5, 5]>>', got '!struct.type<@TComponentB1::@ComponentB1<[5, 6]>>'}}
      %b = struct.readm %self[@f3] : !struct.type<@ComponentB2>, !struct.type<@TComponentB1::@ComponentB1<[5,6]>>
      function.return
    }
  }
}
