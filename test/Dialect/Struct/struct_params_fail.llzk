        function.def @compute() -> !struct.type<@a::@TComponentU1::@ComponentU1<[@Z]>> {
          %self = struct.new : !struct.type<@a::@TComponentU1::@ComponentU1<[@Z]>>
          function.return %self : !struct.type<@a::@TComponentU1::@ComponentU1<[@Z]>>
        }
        function.def @constrain(%self: !struct.type<@a::@TComponentU1::@ComponentU1<[@Z]>>)  { function.return }
      }
    }
  }
  // expected-error@+1 {{'function.def' op references unknown symbol "@D"}}
  function.def @fun3(%0: !struct.type<@a::@TComponentU1::@ComponentU1<[@D]>>) -> !struct.type<@a::@TComponentU1::@ComponentU1<[@D]>> {
    function.return %0 : !struct.type<@a::@TComponentU1::@ComponentU1<[@D]>>
  }
}
