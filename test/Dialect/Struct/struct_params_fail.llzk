      poly.param @Z

      struct.def @ComponentM1 { // expected-note {{type parameters must unify with parameters defined here}}
        function.def @compute() -> !struct.type<@a::@TComponentM1::@ComponentM1<[@Z]>> {
          %self = struct.new : !struct.type<@a::@TComponentM1::@ComponentM1<[@Z]>>
          function.return %self : !struct.type<@a::@TComponentM1::@ComponentM1<[@Z]>>
        }
        function.def @constrain(%self: !struct.type<@a::@TComponentM1::@ComponentM1<[@Z]>>)  { function.return }
      }
    }
  }
  module @b {
    struct.def @ComponentM2 {
      // expected-error@+1 {{Cannot unify parameters of type '!struct.type<@a::@TComponentM1::@ComponentM1>' with parameters of 'struct.def' "@a::@TComponentM1::@ComponentM1<[@Z]>"}}
      struct.member @f : !struct.type<@a::@TComponentM1::@ComponentM1>

      function.def @compute() -> !struct.type<@b::@ComponentM2> {
        %self = struct.new : !struct.type<@b::@ComponentM2>
        function.return %self : !struct.type<@b::@ComponentM2>
      }
      function.def @constrain(%self: !struct.type<@b::@ComponentM2>)  { function.return }
    }
  }
}
