// -----
module attributes {llzk.lang} {
  poly.template @TComponentL1 {
    poly.param @Z

    struct.def @ComponentL1 { // expected-note {{type parameters must unify with parameters defined here}}
      function.def @compute() -> !struct.type<@TComponentL1::@ComponentL1<[@Z]>> {
        %self = struct.new : !struct.type<@TComponentL1::@ComponentL1<[@Z]>>
        function.return %self : !struct.type<@TComponentL1::@ComponentL1<[@Z]>>
      }
      function.def @constrain(%self: !struct.type<@TComponentL1::@ComponentL1<[@Z]>>)  { function.return }
    }
  }
  struct.def @ComponentL2 {
    // expected-error@+1 {{Cannot unify parameters of type '!struct.type<@TComponentL1::@ComponentL1>' with parameters of 'struct.def' "@TComponentL1::@ComponentL1<[@Z]>"}}
    struct.member @f : !struct.type<@TComponentL1::@ComponentL1>

    function.def @compute() -> !struct.type<@ComponentL2> {
      %self = struct.new : !struct.type<@ComponentL2>
      function.return %self : !struct.type<@ComponentL2>
    }
    function.def @constrain(%self: !struct.type<@ComponentL2>)  { function.return }
  }
}
