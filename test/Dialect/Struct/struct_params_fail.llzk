// -----
module attributes {llzk.lang} {
  poly.template @TComponentE1 {
    poly.param @A
    poly.param @B

    struct.def @ComponentE1 {
      function.def @compute() -> !struct.type<@TComponentE1::@ComponentE1<[@A, @B]>> {
        %self = struct.new : !struct.type<@TComponentE1::@ComponentE1<[@A, @B]>>
        function.return %self : !struct.type<@TComponentE1::@ComponentE1<[@A, @B]>>
      }
      function.def @constrain(%self: !struct.type<@TComponentE1::@ComponentE1<[@A, @B]>>) { function.return }
    }
  }

  poly.template @TComponentE2 {
    poly.param @C

    struct.def @ComponentE2 {
      struct.member @f3 : !struct.type<@TComponentE1::@ComponentE1<[5, @C]>>

      function.def @compute() -> !struct.type<@TComponentE2::@ComponentE2<[@C]>> {
        %self = struct.new : !struct.type<@TComponentE2::@ComponentE2<[@C]>>
        function.return %self : !struct.type<@TComponentE2::@ComponentE2<[@C]>>
      }

      function.def @constrain(%self: !struct.type<@TComponentE2::@ComponentE2<[@C]>>) {
        // expected-note@+1 {{prior use here}}
        %b = struct.readm %self[@f3] : !struct.type<@TComponentE2::@ComponentE2<[@C]>>, !struct.type<@TComponentE1::@ComponentE1<[5, @C]>>
        // expected-error@+1 {{use of value '%b' expects different type than prior uses: '!struct.type<@TComponentE1::@ComponentE1<[5, @C, 4]>>' vs '!struct.type<@TComponentE1::@ComponentE1<[5, @C]>>'}}
        function.call @TComponentE1::@ComponentE1::@constrain(%b) : (!struct.type<@TComponentE1::@ComponentE1<[5,@C,4]>>) -> ()
        function.return
      }
    }
  }
}
// -----
module attributes {llzk.lang} {
  poly.template @TComponentF1 {
    poly.param @A
    poly.param @B

    struct.def @ComponentF1 {
      function.def @compute() -> !struct.type<@TComponentF1::@ComponentF1<[@A, @B]>> {
        %self = struct.new : !struct.type<@TComponentF1::@ComponentF1<[@A, @B]>>
        function.return %self : !struct.type<@TComponentF1::@ComponentF1<[@A, @B]>>
      }
      function.def @constrain(%self: !struct.type<@TComponentF1::@ComponentF1<[@A, @B]>>) { function.return }
    }
  }

  poly.template @TComponentF2 {
    poly.param @C

    struct.def @ComponentF2 {
      // expected-error@+1 {{'struct.type' type has 3 parameters but "ComponentF1" expects 2}}
      function.def @compute(%0: !struct.type<@TComponentF1::@ComponentF1<[5,@C,88]>>) -> !struct.type<@TComponentF2::@ComponentF2<[@C]>> {
        %self = struct.new : !struct.type<@TComponentF2::@ComponentF2<[@C]>>
        function.return %self : !struct.type<@TComponentF2::@ComponentF2<[@C]>>
      }

      function.def @constrain(%self: !struct.type<@TComponentF2::@ComponentF2<[@C]>>, %0: !struct.type<@TComponentF1::@ComponentF1<[5,@C,88]>>) {
        function.return
      }
    }
  }
}
// -----
// No parameters used to reference self type within component
module attributes {llzk.lang} {
  poly.template @TComponentG {
    poly.param @A
    poly.param @B

    struct.def @ComponentG { // expected-note {{should be type of this 'struct.def'}}
      // expected-error@+1 {{'function.def' op "@compute" must use type of its ancestor 'struct.def' "@TComponentG::@ComponentG<[@A, @B]>" as return type}}
      function.def @compute() -> !struct.type<@TComponentG::@ComponentG> {
        %self = struct.new : !struct.type<@TComponentG::@ComponentG>
        function.return %self : !struct.type<@TComponentG::@ComponentG>
      }
      function.def @constrain(%self: !struct.type<@TComponentG::@ComponentG>) { function.return }
    }
  }
}
