#map = affine_map<(i) -> (i, 2)>
module attributes {llzk.lang} {
  // This would also trigger {{'struct.def' op attribute 'const_params' failed to satisfy constraint: flat symbol ref array attribute}},
  // but the below error fires first.
  poly.template @TFoo {
    poly.param @N
    poly.param @P

    struct.def @Foo {
      // expected-error@+1 {{AffineMapAttr must yield a single result, but found 2 results}}
      function.def @compute() -> !struct.type<@TFoo::@Foo<[@N, @P, #map]>> {
        %self = struct.new : !struct.type<@TFoo::@Foo<[@N, @P, #map]>>
        function.return %self : !struct.type<@TFoo::@Foo<[@N, @P, #map]>>
      }

      function.def @constrain(%self: !struct.type<@TFoo::@Foo<[@N, @P, #map]>>) {
        function.return
      }
    }
  }
}

