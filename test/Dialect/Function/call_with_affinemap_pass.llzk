// RUN: llzk-opt -split-input-file %s 2>&1 | FileCheck --enable-var-scope %s

#id = affine_map<(i)->(i)>
#IdxToLen = affine_map<(i)->(5*i+1)>
!ToFelt = !struct.type<@TToFelt::@ToFelt<[#id]>>
module attributes {llzk.lang} {
  // pre-defined
  poly.template @TVarArray {
    poly.param @N
    poly.param @T

    struct.def @VarArray {
      struct.member @val: !array.type<@N x !poly.tvar<@T>>

      function.def @compute(%inp: !array.type<@N x !poly.tvar<@T>>) -> !struct.type<@TVarArray::@VarArray<[@N, @T]>> {
        %self = struct.new : !struct.type<@TVarArray::@VarArray<[@N, @T]>>
        struct.writem %self[@val] = %inp : !struct.type<@TVarArray::@VarArray<[@N, @T]>>, !array.type<@N x !poly.tvar<@T>>
        function.return %self : !struct.type<@TVarArray::@VarArray<[@N, @T]>>
      }

      function.def @constrain(%self: !struct.type<@TVarArray::@VarArray<[@N, @T]>>, %inp: !array.type<@N x !poly.tvar<@T>>) {
        function.return
      }
    }
  }

  poly.template @TToFelt {
    poly.param @A

    struct.def @ToFelt {
      struct.member @out: !felt.type {llzk.pub}

      function.def @compute() -> !struct.type<@TToFelt::@ToFelt<[@A]>> {
        %self = struct.new : !struct.type<@TToFelt::@ToFelt<[@A]>>
        %constA = poly.read_const @A : !felt.type
        struct.writem %self[@out] = %constA : !struct.type<@TToFelt::@ToFelt<[@A]>>, !felt.type
        function.return %self: !struct.type<@TToFelt::@ToFelt<[@A]>>
      }

      function.def @constrain(%self: !struct.type<@TToFelt::@ToFelt<[@A]>>) {
        function.return
      }
    }
  }

  struct.def @ComponentB {
    function.def @compute(%a: index) -> !struct.type<@ComponentB> {
      %self = struct.new : !struct.type<@ComponentB>
      // In real code, this should be loop induction variable
      %n = arith.constant 2 : index
      // The array length is a function of 'i' and it contains non-homogeneous structs
      //    !ToFelt = !struct.type<@ToFelt<[#id]>>
      %arr = array.new{(%n)} : !array.type<#IdxToLen x !ToFelt>
      // Real code would probably have a loop here j= 0..n that assigns values to the array
      //
      // Creates a VarArray with length as a function of 'n' and non-homogeneous element type
      %wsi = function.call @TVarArray::@VarArray::@compute(%arr){(%n)}
        : (!array.type<#IdxToLen x !ToFelt>) -> !struct.type<@TVarArray::@VarArray<[#IdxToLen, !ToFelt]>>
      //
      function.return %self : !struct.type<@ComponentB>
    }

    function.def @constrain(%self: !struct.type<@ComponentB>, %a: index) {
      function.return
    }
  }
}
// CHECK: #[[$M1:[0-9a-zA-Z_\.]+]] = affine_map<(d0) -> (d0 * 5 + 1)>
// CHECK: #[[$M0:[0-9a-zA-Z_\.]+]] = affine_map<(d0) -> (d0)>
//
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    poly.template @TVarArray {
// CHECK-NEXT:      poly.param @N
// CHECK-NEXT:      poly.param @T
// CHECK-NEXT:      struct.def @VarArray {
// CHECK-NEXT:        struct.member @val : !array.type<@N x !poly.tvar<@T>>
// CHECK-NEXT:        function.def @compute(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !array.type<@N x !poly.tvar<@T>>) -> !struct.type<@TVarArray::@VarArray<[@N, @T]>> attributes {function.allow_witness} {
// CHECK-NEXT:          %[[VAL_1:[0-9a-zA-Z_\.]+]] = struct.new : <@TVarArray::@VarArray<[@N, @T]>>
// CHECK-NEXT:          struct.writem %[[VAL_1]][@val] = %[[VAL_0]] : <@TVarArray::@VarArray<[@N, @T]>>, !array.type<@N x !poly.tvar<@T>>
// CHECK-NEXT:          function.return %[[VAL_1]] : !struct.type<@TVarArray::@VarArray<[@N, @T]>>
// CHECK-NEXT:        }
// CHECK-NEXT:        function.def @constrain(%[[VAL_2:[0-9a-zA-Z_\.]+]]: !struct.type<@TVarArray::@VarArray<[@N, @T]>>, %[[VAL_3:[0-9a-zA-Z_\.]+]]: !array.type<@N x !poly.tvar<@T>>) attributes {function.allow_constraint} {
// CHECK-NEXT:          function.return
// CHECK-NEXT:        }
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:    poly.template @TToFelt {
// CHECK-NEXT:      poly.param @A
// CHECK-NEXT:      struct.def @ToFelt {
// CHECK-NEXT:        struct.member @out : !felt.type {llzk.pub}
// CHECK-NEXT:        function.def @compute() -> !struct.type<@TToFelt::@ToFelt<[@A]>> attributes {function.allow_witness} {
// CHECK-NEXT:          %[[VAL_4:[0-9a-zA-Z_\.]+]] = struct.new : <@TToFelt::@ToFelt<[@A]>>
// CHECK-NEXT:          %[[VAL_5:[0-9a-zA-Z_\.]+]] = poly.read_const @A : !felt.type
// CHECK-NEXT:          struct.writem %[[VAL_4]][@out] = %[[VAL_5]] : <@TToFelt::@ToFelt<[@A]>>, !felt.type
// CHECK-NEXT:          function.return %[[VAL_4]] : !struct.type<@TToFelt::@ToFelt<[@A]>>
// CHECK-NEXT:        }
// CHECK-NEXT:        function.def @constrain(%[[VAL_6:[0-9a-zA-Z_\.]+]]: !struct.type<@TToFelt::@ToFelt<[@A]>>) attributes {function.allow_constraint} {
// CHECK-NEXT:          function.return
// CHECK-NEXT:        }
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:    struct.def @ComponentB {
// CHECK-NEXT:      function.def @compute(%[[VAL_7:[0-9a-zA-Z_\.]+]]: index) -> !struct.type<@ComponentB> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_8:[0-9a-zA-Z_\.]+]] = struct.new : <@ComponentB>
// CHECK-NEXT:        %[[VAL_9:[0-9a-zA-Z_\.]+]] = arith.constant 2 : index
// CHECK-NEXT:        %[[VAL_10:[0-9a-zA-Z_\.]+]] = array.new{(%[[VAL_9]])} : <#[[$M1]] x !struct.type<@TToFelt::@ToFelt<[#[[$M0]]]>>>
// CHECK-NEXT:        %[[VAL_11:[0-9a-zA-Z_\.]+]] = function.call @TVarArray::@VarArray::@compute(%[[VAL_10]]) {(%[[VAL_9]])} : (!array.type<#[[$M1]] x !struct.type<@TToFelt::@ToFelt<[#[[$M0]]]>>>) -> !struct.type<@TVarArray::@VarArray<[#[[$M1]], !struct.type<@TToFelt::@ToFelt<[#[[$M0]]]>>]>>
// CHECK-NEXT:        function.return %[[VAL_8]] : !struct.type<@ComponentB>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_12:[0-9a-zA-Z_\.]+]]: !struct.type<@ComponentB>, %[[VAL_13:[0-9a-zA-Z_\.]+]]: index) attributes {function.allow_constraint} {
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }
