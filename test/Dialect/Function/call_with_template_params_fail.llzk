module attributes {llzk.lang} {
  poly.template @GlobalFunc {
    poly.param @A : !felt.type

    function.def @id() -> !felt.type {
      %a = poly.read_const @A : !felt.type
      function.return %a : !felt.type
    }
  }

  struct.def @WrongParamTypeC {
    function.def @compute() -> !struct.type<@WrongParamTypeC> {
      %self = struct.new : !struct.type<@WrongParamTypeC>
      // expected-error@+1 {{'function.call' op instantiation value '"string"' is not compatible with parameter "@A" type restriction '!felt.type'}}
      %0 = function.call @GlobalFunc::@id<["string"]>() : () -> !felt.type
      function.return %self : !struct.type<@WrongParamTypeC>
    }

    function.def @constrain(%self: !struct.type<@WrongParamTypeC>) { function.return }
  }
}
