  struct.def @CannotUnifyWithInferredB {
    function.def @compute() -> !struct.type<@CannotUnifyWithInferredB> {
      %self = struct.new : !struct.type<@CannotUnifyWithInferredB>
      // expected-error@+1 {{'function.call' op template instantiation value '1 : index' for parameter "@N" conflicts with value '5 : index' inferred from function type signature}}
      %0 = function.call @GlobalFunc::@id<[true]>() : () -> !array.type<2,5 x index>
      function.return %self : !struct.type<@CannotUnifyWithInferredB>
    }

    function.def @constrain(%self: !struct.type<@CannotUnifyWithInferredB>) { function.return }
  }
}
