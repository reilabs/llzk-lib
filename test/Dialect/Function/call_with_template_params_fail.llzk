module attributes {llzk.lang} {
  poly.template @GlobalFunc {
    poly.param @A : !poly.tvar<@A>

    function.def @id() -> !poly.tvar<@A> {
      %a = poly.read_const @A : !poly.tvar<@A>
      function.return %a : !poly.tvar<@A>
    }
  }

  struct.def @WrongParamTypeD {
    function.def @compute() -> !struct.type<@WrongParamTypeD> {
      %self = struct.new : !struct.type<@WrongParamTypeD>
      // expected-error@+1 {{'function.call' op instantiation value '98 : index' is not compatible with parameter "@A" type restriction '!poly.tvar<@A>'}}
      %0 = function.call @GlobalFunc::@id<[98]>() : () -> !felt.type
      function.return %self : !struct.type<@WrongParamTypeD>
    }

    function.def @constrain(%self: !struct.type<@WrongParamTypeD>) { function.return }
  }
}
// -----
module attributes {llzk.lang} {
  poly.template @GlobalFunc {
    poly.param @N

    function.def @id() -> !array.type<2,@N x index> {
      %a = array.new : !array.type<2,@N x index>
      function.return %a : !array.type<2,@N x index>
    }
  }

  struct.def @CannotUnifyWithInferredA {
    function.def @compute() -> !struct.type<@CannotUnifyWithInferredA> {
      %self = struct.new : !struct.type<@CannotUnifyWithInferredA>
      // expected-error@+1 {{'function.call' op template instantiation value '9 : index' for parameter "@N" conflicts with value '5 : index' inferred from function type signature}}
      %0 = function.call @GlobalFunc::@id<[9]>() : () -> !array.type<2,5 x index>
      function.return %self : !struct.type<@CannotUnifyWithInferredA>
    }

    function.def @constrain(%self: !struct.type<@CannotUnifyWithInferredA>) { function.return }
  }
}
