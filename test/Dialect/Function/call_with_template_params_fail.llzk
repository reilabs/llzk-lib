// RUN: llzk-opt -split-input-file -verify-diagnostics %s

module attributes {llzk.lang} {
  poly.template @GlobalFunc {
    poly.param @A

    function.def @id() -> index {
      %a = poly.read_const @A : index
      function.return %a : index
    }
  }

  struct.def @MissingTemplateParams {
    function.def @compute() -> !struct.type<@MissingTemplateParams> {
      %self = struct.new : !struct.type<@MissingTemplateParams>
      // expected-error@+1 {{'function.call' op must provide template instantiation parameters when calling "@id" because not all template parameters of "@GlobalFunc" appear in the function type signature}}
      %0 = function.call @GlobalFunc::@id() : () -> index
      function.return %self : !struct.type<@MissingTemplateParams>
    }

    function.def @constrain(%self: !struct.type<@MissingTemplateParams>) { function.return }
  }
}
// -----
module attributes {llzk.lang} {
  poly.template @GlobalFunc {
    poly.param @A

    function.def @id() -> index {
      %a = poly.read_const @A : index
      function.return %a : index
    }
  }

  struct.def @EmptyTemplateParams {
    function.def @compute() -> !struct.type<@EmptyTemplateParams> {
      %self = struct.new : !struct.type<@EmptyTemplateParams>
      // expected-error@+1 {{'function.call' op must provide template instantiation parameters when calling "@id" because not all template parameters of "@GlobalFunc" appear in the function type signature}}
      %0 = function.call @GlobalFunc::@id<[]>() : () -> index
      function.return %self : !struct.type<@EmptyTemplateParams>
    }

    function.def @constrain(%self: !struct.type<@EmptyTemplateParams>) { function.return }
  }
}
// -----
module attributes {llzk.lang} {
  poly.template @GlobalFunc {
    poly.param @A

    function.def @id() -> index {
      %a = poly.read_const @A : index
      function.return %a : index
    }
  }

  struct.def @ExtraTemplateParams {
    function.def @compute() -> !struct.type<@ExtraTemplateParams> {
      %self = struct.new : !struct.type<@ExtraTemplateParams>
      // expected-error@+1 {{'function.call' op template instantiation has 2 parameter(s) but "@GlobalFunc" expects 1 template parameter(s)}}
      %0 = function.call @GlobalFunc::@id<[23, 91]>() : () -> index
      function.return %self : !struct.type<@ExtraTemplateParams>
    }

    function.def @constrain(%self: !struct.type<@ExtraTemplateParams>) { function.return }
  }
}
// -----
module attributes {llzk.lang} {
  function.def @id() -> index {
    %a = arith.constant 42 : index
    function.return %a : index
  }

  struct.def @ShouldNotHaveTemplateParams {
    function.def @compute() -> !struct.type<@ShouldNotHaveTemplateParams> {
      %self = struct.new : !struct.type<@ShouldNotHaveTemplateParams>
      // expected-error@+1 {{'function.call' op can only have template instantiations when targeting a templated free function}}
      %0 = function.call @id<[23, 91]>() : () -> index
      function.return %self : !struct.type<@ShouldNotHaveTemplateParams>
    }

    function.def @constrain(%self: !struct.type<@ShouldNotHaveTemplateParams>) { function.return }
  }
}
// -----
module attributes {llzk.lang} {
  poly.template @GlobalFunc {
    poly.param @A : index

    function.def @id() -> index {
      %a = poly.read_const @A : index
      function.return %a : index
    }
  }

  struct.def @WrongParamTypeB {
    function.def @compute() -> !struct.type<@WrongParamTypeB> {
      %self = struct.new : !struct.type<@WrongParamTypeB>
      // expected-error@+1 {{'function.call' op instantiation value '#felt<const 35> : !felt.type' is not compatible with parameter "@A" type restriction 'index'}}
      %0 = function.call @GlobalFunc::@id<[#felt<const 35>]>() : () -> index
      function.return %self : !struct.type<@WrongParamTypeB>
    }

    function.def @constrain(%self: !struct.type<@WrongParamTypeB>) { function.return }
  }
}
