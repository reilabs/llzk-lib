module attributes {llzk.lang} {
  poly.template @GlobalFunc {
    poly.param @A : i1

    function.def @id() -> i1 {
      %a = poly.read_const @A : i1
      function.return %a : i1
    }
  }

  struct.def @WrongParamTypeA {
    function.def @compute() -> !struct.type<@WrongParamTypeA> {
      %self = struct.new : !struct.type<@WrongParamTypeA>
      // Note: Using a value larger than 1 bit is allowed here but, just like struct type instantiation,
      // flattening pass treats 0 as false and any other value as true (but give a warning if it's not 1).
      %0 = function.call @GlobalFunc::@id<[98]>() : () -> i1
      function.return %self : !struct.type<@WrongParamTypeA>
    }

    function.def @constrain(%self: !struct.type<@WrongParamTypeA>) { function.return }
  }
}
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    poly.template @GlobalFunc {
// CHECK-NEXT:      poly.param @A : i1
// CHECK-NEXT:      function.def @id() -> i1 {
// CHECK-NEXT:        %[[VAL_0:[0-9a-zA-Z_\.]+]] = poly.read_const @A : i1
// CHECK-NEXT:        function.return %[[VAL_0]] : i1
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:    struct.def @WrongParamTypeA {
// CHECK-NEXT:      function.def @compute() -> !struct.type<@WrongParamTypeA> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_1:[0-9a-zA-Z_\.]+]] = struct.new : <@WrongParamTypeA>
// CHECK-NEXT:        %[[VAL_2:[0-9a-zA-Z_\.]+]] = function.call @GlobalFunc::@id<[98]>() : () -> i1
// CHECK-NEXT:        function.return %[[VAL_1]] : !struct.type<@WrongParamTypeA>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_3:[0-9a-zA-Z_\.]+]]: !struct.type<@WrongParamTypeA>) attributes {function.allow_constraint} {
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }
