// RUN: llzk-opt %s --canonicalize | FileCheck --enable-var-scope %s

module attributes {llzk.lang} {
    function.def private @use_index(%i: index) -> ()
    function.def private @use_felt(%f: !felt.type) -> ()
    function.def private @use_felt_bb(%f: !felt.type<"babybear">) -> ()

    function.def @func(%a: !felt.type) attributes {function.allow_non_native_field_ops} {
        %f0 = felt.const 0
        %f1 = felt.const 1 : !felt.type<"babybear">
        
        // These should both generate arith.constant's
        %c0 = cast.toindex %f0
        %c1 = cast.toindex %f1 : !felt.type<"babybear">

        %c2 = arith.constant 2 : index

        // These should both generate felt.const's with appropriate types
        %f2 = cast.tofelt %c2 : index, !felt.type
        %f2_bb = cast.tofelt %c2 : index, !felt.type<"babybear">

        function.call @use_index(%c0) : (index) -> ()
        function.call @use_index(%c1) : (index) -> ()

        function.call @use_felt(%f2) : (!felt.type) -> ()
        function.call @use_felt_bb(%f2_bb) : (!felt.type<"babybear">) -> ()
        
        function.return
    }
}

// CHECK-LABEL: function.def @func
// CHECK-NEXT:      %[[VAL_1:[0-9a-zA-Z_\.]+]] = arith.constant 0 : index
// CHECK-NEXT:      %[[VAL_2:[0-9a-zA-Z_\.]+]] = arith.constant 1 : index
// CHECK-NEXT:      %[[VAL_3:[0-9a-zA-Z_\.]+]] = felt.const  2
// CHECK-NEXT:      %[[VAL_4:[0-9a-zA-Z_\.]+]] = felt.const  2 : <"babybear">
