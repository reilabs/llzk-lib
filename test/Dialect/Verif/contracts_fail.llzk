module attributes {llzk.lang} {
  function.def @loop_pick(%seed: !felt.type, %trip_count: index) -> !felt.type {
    %lb = arith.constant 0 : index
    %step = arith.constant 1 : index
    %selected = scf.for %iv = %lb to %trip_count step %step iter_args(%acc = %seed) -> (!felt.type) {
      scf.yield %acc : !felt.type
    }
    function.return %selected : !felt.type
  }

  struct.def @CountBox {
    struct.member @trip_count : index
    function.def @compute(%trip_count: index, %value: !felt.type) -> !struct.type<@CountBox> {
      %self = struct.new : !struct.type<@CountBox>
