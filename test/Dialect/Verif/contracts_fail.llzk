    }
  }

  verif.contract @CallHelperWithMemberControlledReturn for @SecretBox (%self: !struct.type<@SecretBox>, %value: !felt.type, %gate: i1) {
    // expected-note@+1 {{forbidden struct member value originates here}}
    %secret = struct.readm %self[@secret] : !struct.type<@SecretBox>, !felt.type
    // expected-note@+1 {{forbidden struct member value originates here}}
    %member_gate = struct.readm %self[@gate] : !struct.type<@SecretBox>, i1
    %ret = function.call @select_secret(%secret, %value, %member_gate) : (!felt.type, !felt.type, i1) -> !felt.type
    %isEq = bool.cmp eq(%ret, %value) : !felt.type, !felt.type
    // expected-error@+1 {{'verif.require_constrain' op condition cannot be derived from a struct member value}}
    verif.require_constrain %isEq
  }
}

