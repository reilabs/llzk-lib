module attributes {llzk.lang} {
  function.def @passthrough_bool(%flag : i1) -> i1 {
    function.return %flag : i1
  }

  verif.contract @ReturnGateViaExecuteRegion for @passthrough_bool (%flag : i1, %ret_value : i1) {
    %selected = scf.execute_region -> i1 {
