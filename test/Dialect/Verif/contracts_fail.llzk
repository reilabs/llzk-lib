    function.def @constrain(%self: !struct.type<@GateBox>, %gate: i1) {
      function.return
    }
  }

  verif.contract @CheckGateWithinLoop for @GateBox (%self: !struct.type<@GateBox>, %gate: i1) {
    %true = arith.constant true
    // expected-note@+1 {{forbidden struct member value originates here}}
    %member_gate = struct.readm %self[@gate] : !struct.type<@GateBox>, i1
    %selected = scf.while (%init = %true) : (i1) -> i1 {
      scf.condition(%true) %init : i1
    } do {
    ^bb0(%iter : i1):
      // expected-error@+1 {{'verif.require_constrain' op condition cannot be derived from a struct member value}}
      verif.require_constrain %iter
      %yield_val = bool.and %member_gate, %iter
      scf.yield %yield_val : i1
    }
  }
}

