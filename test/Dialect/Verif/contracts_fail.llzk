    function.def @constrain(%self: !struct.type<@GateBox>, %gate_a: i1, %gate_b: i1) {
      function.return
    }
  }

  verif.contract @Leaf for @helper_gates (%gate_a: i1, %gate_b: i1) {
    // expected-note@+1 {{included precondition triggered here}}
