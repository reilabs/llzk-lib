    function.return
  }

  struct.def @GateBox {
    struct.member @gate_a : i1
    struct.member @gate_b : i1
    function.def @compute(%gate_a: i1, %gate_b: i1) -> !struct.type<@GateBox> {
      %self = struct.new : !struct.type<@GateBox>
