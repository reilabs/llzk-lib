module attributes {llzk.lang} {
  struct.def @GateBox {
    struct.member @gate : i1
    function.def @compute(%gate: i1) -> !struct.type<@GateBox> {
      %self = struct.new : !struct.type<@GateBox>
      struct.writem %self[@gate] = %gate : !struct.type<@GateBox>, i1
      function.return %self : !struct.type<@GateBox>
