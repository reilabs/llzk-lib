    function.def @constrain(%self: !struct.type<@CountBox>, %trip_count: index) {
      function.return
    }
  }

  verif.contract @CheckTripCountViaForBounds for @CountBox (%self: !struct.type<@CountBox>, %trip_count: index) {
    %lb = arith.constant 0 : index
    %step = arith.constant 1 : index
    %true = arith.constant true
    // expected-note@+1 {{forbidden struct member value originates here}}
    %member_trip_count = struct.readm %self[@trip_count] : !struct.type<@CountBox>, index
    %selected = scf.for %iv = %lb to %member_trip_count step %step iter_args(%acc = %true) -> (i1) {
      scf.yield %acc : i1
    }
    // expected-error@+1 {{'verif.require_constrain' op condition cannot be derived from a struct member value}}
    verif.require_constrain %selected
  }
}

