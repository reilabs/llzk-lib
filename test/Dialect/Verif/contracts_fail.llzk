      function.return %self : !struct.type<@CountBox>
    }
    function.def @constrain(%self: !struct.type<@CountBox>, %trip_count: index, %value: !felt.type) {
      function.return
    }
  }

  verif.contract @CallHelperWithLoopControlledReturn for @CountBox (%self: !struct.type<@CountBox>, %trip_count: index, %value: !felt.type) {
    // expected-note@+1 {{forbidden struct member value originates here}}
    %member_trip_count = struct.readm %self[@trip_count] : !struct.type<@CountBox>, index
    %ret = function.call @loop_pick(%value, %member_trip_count) : (!felt.type, index) -> !felt.type
    %isEq = bool.cmp eq(%ret, %value) : !felt.type, !felt.type
    // expected-error@+1 {{'verif.require_constrain' op condition cannot be derived from a struct member value}}
    verif.require_constrain %isEq
  }
}

