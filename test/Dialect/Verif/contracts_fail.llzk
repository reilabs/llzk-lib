  verif.contract @CheckRegionVerification for @GateBox (%self: !struct.type<@GateBox>, %gate: i1) {
    %true = arith.constant true
    %member_gate = struct.readm %self[@gate] : !struct.type<@GateBox>, i1
    // expected-error@+1 {{'scf.while' op  region control flow edge from Region #1 to Region #0: source has 1 operands, but target successor needs 0}}
    %selected = scf.while : () -> i1 {
      scf.condition(%true) %true : i1
    } do {
    ^bb0(%iter : i1):
      scf.yield %member_gate : i1
    }
    verif.require_constrain %selected
  }
}

