module attributes {llzk.lang} {
  function.def @select_input(%a : !felt.type, %fallback: !felt.type, %gate: i1) -> !felt.type {
    %selected = scf.if %gate -> (!felt.type) {
      scf.yield %a : !felt.type
    } else {
      scf.yield %fallback : !felt.type
    }
    function.return %selected : !felt.type
  }

  function.def @check(%a : !felt.type, %gate: i1) {
    function.return
  }

  verif.contract @HelperControlPre for @check (%a : !felt.type, %gate: i1) {
    %ret = function.call @select_input(%a, %a, %gate) : (!felt.type, !felt.type, i1) -> !felt.type
    %isEq = bool.cmp eq(%ret, %a) : !felt.type, !felt.type
    verif.require_compute %isEq
  }
}

