module attributes {llzk.lang} {
  poly.template @T {
    poly.param @N : index

    function.def @templated_fn(%x: !array.type<@N x index>) {
      function.return
    }
  }

  verif.contract @OutsideFunc for @T::@templated_fn (%x: !array.type<@N x index>) {
    %n = poly.read_const @N : index
    %zero = arith.constant 0 : index
    %ok = arith.cmpi sge, %n, %zero : index
    verif.ensure_compute %ok
  }
}

