module attributes {llzk.lang} {
  function.def @same(%a : !felt.type) -> !felt.type {
    function.return %a : !felt.type
  }

  function.def @check(%a : !felt.type) {
    function.return
  }

  verif.contract @HelperPre for @check (%a : !felt.type) {
    %ret = function.call @same(%a) : (!felt.type) -> !felt.type
    %isEq = bool.cmp eq(%ret, %a) : !felt.type, !felt.type
    verif.require_compute %isEq
  }
}

