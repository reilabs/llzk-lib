// CHECK-NEXT:    function.def @check(%[[VAL_0:[0-9a-zA-Z_\.]+]]: index, %[[VAL_1:[0-9a-zA-Z_\.]+]]: i1) {
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:    verif.contract @Base for @check (%[[VAL_2:[0-9a-zA-Z_\.]+]]: index, %[[VAL_3:[0-9a-zA-Z_\.]+]]: i1) {
// CHECK-NEXT:      verif.require_compute %[[VAL_3]]
// CHECK-NEXT:      verif.ensure_constrain %[[VAL_3]]
// CHECK-NEXT:    }
// CHECK-NEXT:    verif.contract @Wrapper for @check (%[[VAL_4:[0-9a-zA-Z_\.]+]]: index, %[[VAL_5:[0-9a-zA-Z_\.]+]]: i1) {
