module attributes {llzk.lang} {
  struct.def @GateBox {
    struct.member @gate : i1
    function.def @compute(%gate: i1) -> !struct.type<@GateBox> {
      %self = struct.new : !struct.type<@GateBox>
      struct.writem %self[@gate] = %gate : !struct.type<@GateBox>, i1
      function.return %self : !struct.type<@GateBox>
    }
    function.def @constrain(%self: !struct.type<@GateBox>, %gate: i1) {
      function.return
    }
  }

  verif.contract @ExecuteRegionIgnoresNestedYield for @GateBox (%self: !struct.type<@GateBox>, %gate: i1) {
    %true = arith.constant true
    %member_gate = struct.readm %self[@gate] : !struct.type<@GateBox>, i1
    %selected = scf.execute_region -> i1 {
      %ignored = scf.if %true -> (i1) {
        scf.yield %member_gate : i1
      } else {
        scf.yield %true : i1
      }
      scf.yield %true : i1
    }
    verif.require_compute %selected
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    struct.def @GateBox {
// CHECK-NEXT:      struct.member @gate : i1
