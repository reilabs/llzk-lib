module attributes {llzk.lang} {
  function.def @check(%ok: i1) {
    function.return
  }

  verif.contract @RequireInsideIf for @check (%ok: i1) {
    %true = arith.constant true
    scf.if %ok {
      verif.require_compute %true
    }
  }
}

