module attributes {llzk.lang} {
  function.def @touch_input_if(%a : !felt.type, %gate: i1) -> !felt.type {
    scf.if %gate {
      %isEq = bool.cmp eq(%a, %a) : !felt.type, !felt.type
    }
    function.return %a : !felt.type
  }

  function.def @check(%a : !felt.type, %gate: i1) {
    function.return
  }

  verif.contract @HelperImbalancedIfPre for @check (%a : !felt.type, %gate: i1) {
    %ret = function.call @touch_input_if(%a, %gate) : (!felt.type, i1) -> !felt.type
    %isEq = bool.cmp eq(%ret, %a) : !felt.type, !felt.type
    verif.require_compute %isEq
  }
}

