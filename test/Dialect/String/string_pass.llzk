// RUN: llzk-opt -split-input-file %s 2>&1 | FileCheck %s

module attributes {llzk.lang} {
  poly.template @TFoo {
    struct.def @Foo {
      function.def @compute() -> !struct.type<@TFoo::@Foo<[]>> {
        %self = struct.new : !struct.type<@TFoo::@Foo<[]>>
        %str = string.new "this is a string"
        function.return %self : !struct.type<@TFoo::@Foo<[]>>
      }
      function.def @constrain(%self: !struct.type<@TFoo::@Foo<[]>>) { function.return }
    }
  }
}
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    poly.template @TFoo {
// CHECK-NEXT:      struct.def @Foo {
// CHECK-NEXT:        function.def @compute() -> !struct.type<@TFoo::@Foo<[]>> attributes {function.allow_witness} {
// CHECK-NEXT:          %[[VAL_0:[0-9a-zA-Z_\.]+]] = struct.new : <@TFoo::@Foo<[]>>
// CHECK-NEXT:          %[[VAL_1:[0-9a-zA-Z_\.]+]] = string.new "this is a string"
// CHECK-NEXT:          function.return %[[VAL_0]] : !struct.type<@TFoo::@Foo<[]>>
// CHECK-NEXT:        }
// CHECK-NEXT:        function.def @constrain(%[[VAL_2:[0-9a-zA-Z_\.]+]]: !struct.type<@TFoo::@Foo<[]>>) attributes {function.allow_constraint} {
// CHECK-NEXT:          function.return
// CHECK-NEXT:        }
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }
