// RUN: llzk-opt -split-input-file %s 2>&1 | FileCheck --enable-var-scope %s

// This IR mimics an idiom that could be generated by the zirgen frontend
#map = affine_map<()[s0, s1] -> (s0 + s1)>
module attributes { llzk.lang } {
  poly.template @TA {
    poly.param @X
    poly.param @Y
    poly.param @N

    struct.def @A {
      function.def @compute(%0: !array.type<@N x !felt.type>) -> !struct.type<@TA::@A<[@X, @Y, @N]>> {
        %self = struct.new : <@TA::@A<[@X, @Y, @N]>>
        function.return %self : !struct.type<@TA::@A<[@X, @Y, @N]>>
      }
      function.def @constrain(%self: !struct.type<@TA::@A<[@X, @Y, @N]>>, %0: !array.type<@N x !felt.type>) {
        function.return
      }
    }
  }
  poly.template @TB {
    poly.param @X
    poly.param @Y
    poly.param @N

    struct.def @B {
      struct.member @a : !struct.type<@TA::@A<[@X, @Y, #map]>>
      function.def @compute(%a0: !array.type<@N x !felt.type>) -> !struct.type<@TB::@B<[@X, @Y, @N]>> {
        %self = struct.new : <@TB::@B<[@X, @Y, @N]>>
        %0 = poly.read_const @X : index
        %1 = poly.read_const @Y : index
        %2 = poly.unifiable_cast %a0 : (!array.type<@N x !felt.type>) -> !array.type<#map x !felt.type>
        %3 = function.call @TA::@A::@compute(%2){()[%0, %1]} : (!array.type<#map x !felt.type>) -> !struct.type<@TA::@A<[@X, @Y, #map]>>
        struct.writem %self[@a] = %3 : !struct.type<@TB::@B<[@X, @Y, @N]>>, !struct.type<@TA::@A<[@X, @Y, #map]>>
        function.return %self : !struct.type<@TB::@B<[@X, @Y, @N]>>
      }
      function.def @constrain(%self: !struct.type<@TB::@B<[@X, @Y, @N]>>, %a0: !array.type<@N x !felt.type>) {
        %2 = poly.unifiable_cast %a0 : (!array.type<@N x !felt.type>) -> !array.type<#map x !felt.type>
        %a = struct.readm %self[@a] : !struct.type<@TB::@B<[@X, @Y, @N]>>, !struct.type<@TA::@A<[@X, @Y, #map]>>
        function.call @TA::@A::@constrain(%a, %2) : (!struct.type<@TA::@A<[@X, @Y, #map]>>, !array.type<#map x !felt.type>) -> ()
        function.return
      }
    }
  }
}
// CHECK: #[[$M0:[0-9a-zA-Z_\.]+]] = affine_map<()[s0, s1] -> (s0 + s1)>
//
// CHECK-LABEL: module attributes {llzk.lang} {
