// CHECK-NEXT:          %[[VAL_8:[0-9a-zA-Z_\.]+]] = poly.unifiable_cast %[[VAL_4]] : (!array.type<@N x !felt.type>) -> !array.type<#[[$M0]] x !felt.type>
// CHECK-NEXT:          %[[VAL_9:[0-9a-zA-Z_\.]+]] = function.call @TA::@A::@compute(%[[VAL_8]]) {(){{\[}}%[[VAL_6]], %[[VAL_7]]]} : (!array.type<#[[$M0]] x !felt.type>) -> !struct.type<@TA::@A<[@X, @Y, #[[$M0]]]>>
// CHECK-NEXT:          struct.writem %[[VAL_5]][@a] = %[[VAL_9]] : <@TB::@B<[@X, @Y, @N]>>, !struct.type<@TA::@A<[@X, @Y, #[[$M0]]]>>
// CHECK-NEXT:          function.return %[[VAL_5]] : !struct.type<@TB::@B<[@X, @Y, @N]>>
// CHECK-NEXT:        }
// CHECK-NEXT:        function.def @constrain(%[[VAL_10:[0-9a-zA-Z_\.]+]]: !struct.type<@TB::@B<[@X, @Y, @N]>>, %[[VAL_11:[0-9a-zA-Z_\.]+]]: !array.type<@N x !felt.type>) attributes {function.allow_constraint} {
// CHECK-NEXT:          %[[VAL_12:[0-9a-zA-Z_\.]+]] = poly.unifiable_cast %[[VAL_11]] : (!array.type<@N x !felt.type>) -> !array.type<#[[$M0]] x !felt.type>
// CHECK-NEXT:          %[[VAL_13:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_10]][@a] : <@TB::@B<[@X, @Y, @N]>>, !struct.type<@TA::@A<[@X, @Y, #[[$M0]]]>>
// CHECK-NEXT:          function.call @TA::@A::@constrain(%[[VAL_13]], %[[VAL_12]]) : (!struct.type<@TA::@A<[@X, @Y, #[[$M0]]]>>, !array.type<#[[$M0]] x !felt.type>) -> ()
