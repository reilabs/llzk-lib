// CHECK-NEXT:      poly.param @N
// CHECK-NEXT:      struct.def @B {
// CHECK-NEXT:        struct.member @a : !struct.type<@TA::@A<[@X, @Y, #[[$M0]]]>>
// CHECK-NEXT:        function.def @compute(%[[VAL_4:[0-9a-zA-Z_\.]+]]: !array.type<@N x !felt.type>) -> !struct.type<@TB::@B<[@X, @Y, @N]>> attributes {function.allow_witness} {
// CHECK-NEXT:          %[[VAL_5:[0-9a-zA-Z_\.]+]] = struct.new : <@TB::@B<[@X, @Y, @N]>>
