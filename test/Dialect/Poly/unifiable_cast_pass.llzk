// -----

#map1 = affine_map<()[s0, s1] -> (s0 + s1)>
#map2 = affine_map<()[s0, s1, s2] -> (s0 + s1 + s2)>
module attributes {llzk.lang} {
  poly.template @TT1 {
    struct.def @T1 {
      function.def @compute() -> !struct.type<@TT1::@T1<[]>> {
        %self = struct.new : <@TT1::@T1<[]>>
        function.return %self : !struct.type<@TT1::@T1<[]>>
      }
      function.def @constrain(%self : !struct.type<@TT1::@T1<[]>>) {
        function.return
      }
    }
  }
  poly.template @TT2 {
    poly.param @N

    struct.def @T2 {
      function.def @compute() -> !struct.type<@TT2::@T2<[@N]>> {
        %self = struct.new : <@TT2::@T2<[@N]>>
        function.return %self : !struct.type<@TT2::@T2<[@N]>>
      }
      function.def @constrain(%self : !struct.type<@TT2::@T2<[@N]>>) {
        function.return
      }
    }
  }
  poly.template @TT3 {
    poly.param @A
    poly.param @B
    poly.param @C
    poly.param @D
    poly.param @E

    struct.def @T3 {
      function.def @compute() -> !struct.type<@TT3::@T3<[@A, @B, @C, @D, @E]>> {
        %self = struct.new : <@TT3::@T3<[@A, @B, @C, @D, @E]>>
        function.return %self : !struct.type<@TT3::@T3<[@A, @B, @C, @D, @E]>>
      }
      function.def @constrain(%self : !struct.type<@TT3::@T3<[@A, @B, @C, @D, @E]>>) {
        function.return
      }
    }
  }
  poly.template @TTester {
    poly.param @S0
    poly.param @S1

    struct.def @Tester {
      function.def @compute(%0: index, %1: i1, %2: !felt.type, %3: !struct.type<@TT1::@T1<[]>>,
                    %4: !struct.type<@TT2::@T2<[1]>>, %5: !struct.type<@TT2::@T2<[@S0]>>,
                    %6: !struct.type<@TT2::@T2<[7]>>, %7: !struct.type<@TT2::@T2<[!felt.type]>>,
                    %8: !array.type<2,2 x !felt.type>, %9: !array.type<2,@S0 x !felt.type>,
                    %10: !array.type<2,7 x !felt.type>, %11: !string.type, %12: !poly.tvar<@S1>,
                    %18: !struct.type<@TT3::@T3<[1, 7, @S0, 1, !struct.type<@TT2::@T2<[1]>>]>>,
                    %20: !array.type<1, 7, @S0, 1 x !struct.type<@TT2::@T2<[1]>>>,
                    %22: !array.type<? x !felt.type>) -> !struct.type<@TTester::@Tester<[@S0, @S1]>> {
        %self = struct.new : <@TTester::@Tester<[@S0, @S1]>>
        // Tests for equality
        %r0 = poly.unifiable_cast %0 : (index) -> index
        %r1 = poly.unifiable_cast %1 : (i1) -> i1
        %r2 = poly.unifiable_cast %2 : (!felt.type) -> !felt.type
        %r3 = poly.unifiable_cast %3 : (!struct.type<@TT1::@T1<[]>>) -> !struct.type<@TT1::@T1<[]>>
        %r4 = poly.unifiable_cast %4 : (!struct.type<@TT2::@T2<[1]>>) -> !struct.type<@TT2::@T2<[1]>>
        %r5 = poly.unifiable_cast %5 : (!struct.type<@TT2::@T2<[@S0]>>) -> !struct.type<@TT2::@T2<[@S0]>>
        %r6 = poly.unifiable_cast %6 : (!struct.type<@TT2::@T2<[7]>>) -> !struct.type<@TT2::@T2<[#map1]>>
        %r7 = poly.unifiable_cast %7 : (!struct.type<@TT2::@T2<[!felt.type]>>) -> !struct.type<@TT2::@T2<[!felt.type]>>
        %r8 = poly.unifiable_cast %8 : (!array.type<2,2 x !felt.type>) -> !array.type<2,2 x !felt.type>
        %r9 = poly.unifiable_cast %9 : (!array.type<2,@S0 x !felt.type>) -> !array.type<2,@S0 x !felt.type>
        %r10 = poly.unifiable_cast %10 : (!array.type<2,7 x !felt.type>) -> !array.type<2,#map1 x !felt.type>
        %r11 = poly.unifiable_cast %11 : (!string.type) -> !string.type
        // Test that a type variable unifies with any type
        %r12 = poly.unifiable_cast %12 : (!poly.tvar<@S1>) -> index
        %13 = poly.unifiable_cast %2 : (!felt.type) -> !poly.tvar<@S1>
        // Test that if structs have the same name they unify if their params unify
        %19 = poly.unifiable_cast %18 : (!struct.type<@TT3::@T3<[1, 7, @S0, 1, !struct.type<@TT2::@T2<[1]>>]>>) -> !struct.type<@TT3::@T3<[#map1, #map1, 1, @S0, !struct.type<@TT2::@T2<[#map2]>>]>>
        %21 = poly.unifiable_cast %20 : (!array.type<1, 7, @S0, 1 x !struct.type<@TT2::@T2<[1]>>>) -> !array.type<#map1, #map1, 1, @S0 x !struct.type<@TT2::@T2<[#map2]>>>
        %23 = poly.unifiable_cast %22 : (!array.type<? x !felt.type>) -> !array.type<1 x !felt.type>
        %24 = poly.unifiable_cast %23 : (!array.type<1 x !felt.type>) -> !array.type<? x !felt.type>
        function.return %self : !struct.type<@TTester::@Tester<[@S0, @S1]>>
      }
      function.def @constrain(%self: !struct.type<@TTester::@Tester<[@S0, @S1]>>, %0: index, %1: i1, %2: !felt.type, %3: !struct.type<@TT1::@T1<[]>>,
                    %4: !struct.type<@TT2::@T2<[1]>>, %5: !struct.type<@TT2::@T2<[@S0]>>,
                    %6: !struct.type<@TT2::@T2<[7]>>, %7: !struct.type<@TT2::@T2<[!felt.type]>>,
                    %8: !array.type<2,2 x !felt.type>, %9: !array.type<2,@S0 x !felt.type>,
                    %10: !array.type<2,7 x !felt.type>, %11: !string.type, %12: !poly.tvar<@S1>,
                    %18: !struct.type<@TT3::@T3<[1, 7, @S0, 1, !struct.type<@TT2::@T2<[1]>>]>>,
                    %20: !array.type<1, 7, @S0, 1 x !struct.type<@TT2::@T2<[1]>>>,
                    %22: !array.type<? x !felt.type>) {
        function.return
      }
    }
  }
}
