// CHECK-NEXT:      poly.param @Y
// CHECK-NEXT:      poly.param @N
// CHECK-NEXT:      struct.def @A {
// CHECK-NEXT:        function.def @compute(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !array.type<@N x !felt.type>) -> !struct.type<@TA::@A<[@X, @Y, @N]>> attributes {function.allow_witness} {
// CHECK-NEXT:          %[[VAL_1:[0-9a-zA-Z_\.]+]] = struct.new : <@TA::@A<[@X, @Y, @N]>>
// CHECK-NEXT:          function.return %[[VAL_1]] : !struct.type<@TA::@A<[@X, @Y, @N]>>
// CHECK-NEXT:        }
