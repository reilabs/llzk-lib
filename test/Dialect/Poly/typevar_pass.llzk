// CHECK-NEXT:        struct.member @f : !struct.type<@TComponentB1::@ComponentB1<[!poly.tvar<@X>]>>
// CHECK-NEXT:        function.def @compute(%[[VAL_11:[0-9a-zA-Z_\.]+]]: !struct.type<@TComponentB1::@ComponentB1<[!poly.tvar<@X>]>>) -> !struct.type<@TComponentB3::@ComponentB3<[@X]>> attributes {function.allow_witness} {
