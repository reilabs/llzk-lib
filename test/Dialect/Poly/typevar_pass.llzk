// RUN: llzk-opt -split-input-file %s 2>&1 | FileCheck --enable-var-scope %s

// Instantiations of parameterized struct with different types.
module attributes {llzk.lang} {
  // Struct with type parameter
  poly.template @TA {
    poly.param @Ty

    struct.def @A {
      struct.member @x : !poly.tvar<@Ty>

      function.def @compute(%0: !poly.tvar<@Ty>) -> !struct.type<@TA::@A<[@Ty]>> {
        %self = struct.new : !struct.type<@TA::@A<[@Ty]>>
        struct.writem %self[@x] = %0 : !struct.type<@TA::@A<[@Ty]>>, !poly.tvar<@Ty>
        function.return %self : !struct.type<@TA::@A<[@Ty]>>
      }

      function.def @constrain(%self: !struct.type<@TA::@A<[@Ty]>>, %0: !poly.tvar<@Ty>) {
        %1 = struct.readm %self[@x] : !struct.type<@TA::@A<[@Ty]>>, !poly.tvar<@Ty>
        // Validation here must be assumed correct when the struct
        //  verifies itself because the type is not known.
        constrain.eq %1, %0 : !poly.tvar<@Ty>
        function.return
      }
    }
  }

  // Specialization of the parameterized struct for Felt type
  struct.def @FeltA {
    struct.member @a : !struct.type<@TA::@A<[!felt.type]>>

    function.def @compute() -> !struct.type<@FeltA> {
      %self = struct.new : !struct.type<@FeltA>
      %c = felt.const 57
      %s = function.call @TA::@A::@compute(%c) : (!felt.type) -> !struct.type<@TA::@A<[!felt.type]>>
      struct.writem %self[@a] = %s : !struct.type<@FeltA>, !struct.type<@TA::@A<[!felt.type]>>
      function.return %self : !struct.type<@FeltA>
    }

    function.def @constrain(%self: !struct.type<@FeltA>) {
      %c = felt.const 57
      %s = struct.readm %self[@a] : !struct.type<@FeltA>, !struct.type<@TA::@A<[!felt.type]>>
      function.call @TA::@A::@constrain(%s, %c) : (!struct.type<@TA::@A<[!felt.type]>>, !felt.type) -> ()
      function.return
    }
  }

  // Specialization of the parameterized struct for Felt type
  struct.def @IndexA {
    struct.member @a : !struct.type<@TA::@A<[index]>>

    function.def @compute() -> !struct.type<@IndexA> {
      %self = struct.new : !struct.type<@IndexA>
      %c = arith.constant 57 : index
      %s = function.call @TA::@A::@compute(%c) : (index) -> !struct.type<@TA::@A<[index]>>
      struct.writem %self[@a] = %s : !struct.type<@IndexA>, !struct.type<@TA::@A<[index]>>
      function.return %self : !struct.type<@IndexA>
    }

    function.def @constrain(%self: !struct.type<@IndexA>) {
      %c = arith.constant 57 : index
      %s = struct.readm %self[@a] : !struct.type<@IndexA>, !struct.type<@TA::@A<[index]>>
      function.call @TA::@A::@constrain(%s, %c) : (!struct.type<@TA::@A<[index]>>, index) -> ()
      function.return
    }
  }
}
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    poly.template @TA {
// CHECK-NEXT:      poly.param @Ty
// CHECK-NEXT:      struct.def @A {
// CHECK-NEXT:        struct.member @x : !poly.tvar<@Ty>
// CHECK-NEXT:        function.def @compute(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !poly.tvar<@Ty>) -> !struct.type<@TA::@A<[@Ty]>> attributes {function.allow_witness} {
// CHECK-NEXT:          %[[VAL_1:[0-9a-zA-Z_\.]+]] = struct.new : <@TA::@A<[@Ty]>>
// CHECK-NEXT:          struct.writem %[[VAL_1]][@x] = %[[VAL_0]] : <@TA::@A<[@Ty]>>, !poly.tvar<@Ty>
// CHECK-NEXT:          function.return %[[VAL_1]] : !struct.type<@TA::@A<[@Ty]>>
// CHECK-NEXT:        }
// CHECK-NEXT:        function.def @constrain(%[[VAL_2:[0-9a-zA-Z_\.]+]]: !struct.type<@TA::@A<[@Ty]>>, %[[VAL_3:[0-9a-zA-Z_\.]+]]: !poly.tvar<@Ty>) attributes {function.allow_constraint} {
// CHECK-NEXT:          %[[VAL_4:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_2]][@x] : <@TA::@A<[@Ty]>>, !poly.tvar<@Ty>
// CHECK-NEXT:          constrain.eq %[[VAL_4]], %[[VAL_3]] : !poly.tvar<@Ty>, !poly.tvar<@Ty>
// CHECK-NEXT:          function.return
// CHECK-NEXT:        }
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:    struct.def @FeltA {
// CHECK-NEXT:      struct.member @a : !struct.type<@TA::@A<[!felt.type]>>
// CHECK-NEXT:      function.def @compute() -> !struct.type<@FeltA> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_5:[0-9a-zA-Z_\.]+]] = struct.new : <@FeltA>
// CHECK-NEXT:        %[[VAL_6:[0-9a-zA-Z_\.]+]] = felt.const  57
// CHECK-NEXT:        %[[VAL_7:[0-9a-zA-Z_\.]+]] = function.call @TA::@A::@compute(%[[VAL_6]]) : (!felt.type) -> !struct.type<@TA::@A<[!felt.type]>>
// CHECK-NEXT:        struct.writem %[[VAL_5]][@a] = %[[VAL_7]] : <@FeltA>, !struct.type<@TA::@A<[!felt.type]>>
// CHECK-NEXT:        function.return %[[VAL_5]] : !struct.type<@FeltA>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_8:[0-9a-zA-Z_\.]+]]: !struct.type<@FeltA>) attributes {function.allow_constraint} {
