module attributes {llzk.lang} {
  poly.template @TComponentG {
    poly.param @S
    poly.param @T

    struct.def @ComponentG {
      struct.member @f : !array.type<@S x !poly.tvar<@T>>

      function.def @compute() -> !struct.type<@TComponentG::@ComponentG<[@S, @T]>> {
        %self = struct.new : !struct.type<@TComponentG::@ComponentG<[@S, @T]>>
        %arr = array.new : !array.type<@S x !poly.tvar<@T>>
        %lb = arith.constant 0 : index
        %up = poly.read_const @S : index
        %step = arith.constant 1 : index
        scf.for %iv = %lb to %up step %step {
          // Although a type variable is used, this struct can only be instantiated
          //  with `@T = index` since an `index` value is assigned to the tvar array.
          array.write %arr[%iv] = %iv : !array.type<@S x !poly.tvar<@T>>, index
        }
        struct.writem %self[@f] = %arr : !struct.type<@TComponentG::@ComponentG<[@S, @T]>>, !array.type<@S x !poly.tvar<@T>>
        function.return %self : !struct.type<@TComponentG::@ComponentG<[@S, @T]>>
      }

      function.def @constrain(%self: !struct.type<@TComponentG::@ComponentG<[@S, @T]>>) {
        %arr = struct.readm %self[@f] : !struct.type<@TComponentG::@ComponentG<[@S, @T]>>, !array.type<@S x !poly.tvar<@T>>
        %lb = arith.constant 0 : index
        %up = poly.read_const @S : index
        %step = arith.constant 1 : index
        scf.for %iv = %lb to %up step %step {
          %temp = array.read %arr[%iv] : !array.type<@S x !poly.tvar<@T>>, !poly.tvar<@T>
          constrain.eq %temp, %iv : !poly.tvar<@T>, index
        }
        function.return
      }
    }
  }
}
