// CHECK-NEXT:        %[[VAL_10:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_8]][@a] : <@FeltA>, !struct.type<@TA::@A<[!felt.type]>>
// CHECK-NEXT:        function.call @TA::@A::@constrain(%[[VAL_10]], %[[VAL_9]]) : (!struct.type<@TA::@A<[!felt.type]>>, !felt.type) -> ()
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:    struct.def @IndexA {
// CHECK-NEXT:      struct.member @a : !struct.type<@TA::@A<[index]>>
// CHECK-NEXT:      function.def @compute() -> !struct.type<@IndexA> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_11:[0-9a-zA-Z_\.]+]] = struct.new : <@IndexA>
// CHECK-NEXT:        %[[VAL_12:[0-9a-zA-Z_\.]+]] = arith.constant 57 : index
// CHECK-NEXT:        %[[VAL_13:[0-9a-zA-Z_\.]+]] = function.call @TA::@A::@compute(%[[VAL_12]]) : (index) -> !struct.type<@TA::@A<[index]>>
// CHECK-NEXT:        struct.writem %[[VAL_11]][@a] = %[[VAL_13]] : <@IndexA>, !struct.type<@TA::@A<[index]>>
// CHECK-NEXT:        function.return %[[VAL_11]] : !struct.type<@IndexA>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_14:[0-9a-zA-Z_\.]+]]: !struct.type<@IndexA>) attributes {function.allow_constraint} {
// CHECK-NEXT:        %[[VAL_15:[0-9a-zA-Z_\.]+]] = arith.constant 57 : index
// CHECK-NEXT:        %[[VAL_16:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_14]][@a] : <@IndexA>, !struct.type<@TA::@A<[index]>>
// CHECK-NEXT:        function.call @TA::@A::@constrain(%[[VAL_16]], %[[VAL_15]]) : (!struct.type<@TA::@A<[index]>>, index) -> ()
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }
