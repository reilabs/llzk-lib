// Like the previous but demonstrates the permissiveness of using struct parameters and type variables.
// In non-instantiated structs, these must be very permissive and fully checked only when instantiated.
module attributes {llzk.lang} {
  poly.template @TComponentB4 {
    poly.param @T

    struct.def @ComponentB4 {
      struct.member @f : !poly.tvar<@T> {llzk.pub}

      function.def @compute(%0: !poly.tvar<@T>) -> !struct.type<@TComponentB4::@ComponentB4<[@T]>> {
        %self = struct.new : !struct.type<@TComponentB4::@ComponentB4<[@T]>>
        struct.writem %self[@f] = %0 : !struct.type<@TComponentB4::@ComponentB4<[@T]>>, !poly.tvar<@T>
        function.return %self : !struct.type<@TComponentB4::@ComponentB4<[@T]>>
      }

      function.def @constrain(%self: !struct.type<@TComponentB4::@ComponentB4<[@T]>>, %0: !poly.tvar<@T>) { function.return }
    }
  }

  poly.template @TComponentB5 {
    poly.param @A
    poly.param @B
    poly.param @C
    poly.param @D
    poly.param @E
    poly.param @F
    poly.param @G

    struct.def @ComponentB5 {
      struct.member @f : !struct.type<@TComponentB4::@ComponentB4<[@A]>>

      function.def @compute(%c0: !struct.type<@TComponentB4::@ComponentB4<[@B]>>) -> !struct.type<@TComponentB5::@ComponentB5<[@A, @B, @C, @D, @E, @F, @G]>> {
        %self = struct.new : !struct.type<@TComponentB5::@ComponentB5<[@A, @B, @C, @D, @E, @F, @G]>>
        struct.writem %self[@f] = %c0 : !struct.type<@TComponentB5::@ComponentB5<[@A, @B, @C, @D, @E, @F, @G]>>, !struct.type<@TComponentB4::@ComponentB4<[@B]>>
        function.return %self : !struct.type<@TComponentB5::@ComponentB5<[@A, @B, @C, @D, @E, @F, @G]>>
      }

      function.def @constrain(%self: !struct.type<@TComponentB5::@ComponentB5<[@A, @B, @C, @D, @E, @F, @G]>>, %c0: !struct.type<@TComponentB4::@ComponentB4<[@C]>>) {
        // Note: since @ComponentB4::@f has tvar type, the return type of the 'readm' here could be anything.
        %v0 = struct.readm %c0[@f] : !struct.type<@TComponentB4::@ComponentB4<[@C]>>, !poly.tvar<@D>
        %c1 = struct.readm %self[@f] : !struct.type<@TComponentB5::@ComponentB5<[@A, @B, @C, @D, @E, @F, @G]>>, !struct.type<@TComponentB4::@ComponentB4<[@E]>>
        %v1 = struct.readm %c1[@f] : !struct.type<@TComponentB4::@ComponentB4<[@E]>>, !poly.tvar<@F>
        constrain.eq %v0, %v1 : !poly.tvar<@D>, !poly.tvar<@F>
        function.return
      }
    }
  }

  poly.template @TComponentB6 {
    poly.param @A
    poly.param @B
    poly.param @C
    poly.param @D
    poly.param @E
    poly.param @F
    poly.param @G

    struct.def @ComponentB6 {
      struct.member @f : !struct.type<@TComponentB4::@ComponentB4<[!poly.tvar<@A>]>>

      function.def @compute(%c0: !struct.type<@TComponentB4::@ComponentB4<[!poly.tvar<@B>]>>) -> !struct.type<@TComponentB6::@ComponentB6<[@A, @B, @C, @D, @E, @F, @G]>> {
        %self = struct.new : !struct.type<@TComponentB6::@ComponentB6<[@A, @B, @C, @D, @E, @F, @G]>>
        struct.writem %self[@f] = %c0 : !struct.type<@TComponentB6::@ComponentB6<[@A, @B, @C, @D, @E, @F, @G]>>, !struct.type<@TComponentB4::@ComponentB4<[!poly.tvar<@B>]>>
        function.return %self : !struct.type<@TComponentB6::@ComponentB6<[@A, @B, @C, @D, @E, @F, @G]>>
      }

      function.def @constrain(%self: !struct.type<@TComponentB6::@ComponentB6<[@A, @B, @C, @D, @E, @F, @G]>>, %c0: !struct.type<@TComponentB4::@ComponentB4<[!poly.tvar<@C>]>>) {
        %v0 = struct.readm %c0[@f] : !struct.type<@TComponentB4::@ComponentB4<[!poly.tvar<@C>]>>, !poly.tvar<@D>
        %c1 = struct.readm %self[@f] : !struct.type<@TComponentB6::@ComponentB6<[@A, @B, @C, @D, @E, @F, @G]>>, !struct.type<@TComponentB4::@ComponentB4<[!poly.tvar<@E>]>>
        %v1 = struct.readm %c1[@f] : !struct.type<@TComponentB4::@ComponentB4<[!poly.tvar<@E>]>>, !poly.tvar<@F>
        constrain.eq %v0, %v1 : !poly.tvar<@D>, !poly.tvar<@F>
        function.return
      }
    }
  }
}
