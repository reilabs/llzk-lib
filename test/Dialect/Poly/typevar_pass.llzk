// B2 and B3 are equivalent, latter uses the redundant !poly.tvar<@X> instead of just @X
module attributes {llzk.lang} {
  poly.template @TComponentB1 {
    poly.param @T

    struct.def @ComponentB1 {
      struct.member @f : !poly.tvar<@T> {llzk.pub}

      function.def @compute(%0: !poly.tvar<@T>) -> !struct.type<@TComponentB1::@ComponentB1<[@T]>> {
        %self = struct.new : !struct.type<@TComponentB1::@ComponentB1<[@T]>>
        struct.writem %self[@f] = %0 : !struct.type<@TComponentB1::@ComponentB1<[@T]>>, !poly.tvar<@T>
        function.return %self : !struct.type<@TComponentB1::@ComponentB1<[@T]>>
      }

      function.def @constrain(%self: !struct.type<@TComponentB1::@ComponentB1<[@T]>>, %0: !poly.tvar<@T>) { function.return }
    }
  }

  poly.template @TComponentB2 {
    poly.param @X

    struct.def @ComponentB2 {
      struct.member @f : !struct.type<@TComponentB1::@ComponentB1<[@X]>>

      function.def @compute(%c0: !struct.type<@TComponentB1::@ComponentB1<[@X]>>) -> !struct.type<@TComponentB2::@ComponentB2<[@X]>> {
        %self = struct.new : !struct.type<@TComponentB2::@ComponentB2<[@X]>>
        struct.writem %self[@f] = %c0 : !struct.type<@TComponentB2::@ComponentB2<[@X]>>, !struct.type<@TComponentB1::@ComponentB1<[@X]>>
        function.return %self : !struct.type<@TComponentB2::@ComponentB2<[@X]>>
      }

      function.def @constrain(%self: !struct.type<@TComponentB2::@ComponentB2<[@X]>>, %c0: !struct.type<@TComponentB1::@ComponentB1<[@X]>>) {
        %v0 = struct.readm %c0[@f] : !struct.type<@TComponentB1::@ComponentB1<[@X]>>, !poly.tvar<@X>
        %c1 = struct.readm %self[@f] : !struct.type<@TComponentB2::@ComponentB2<[@X]>>, !struct.type<@TComponentB1::@ComponentB1<[@X]>>
        %v1 = struct.readm %c1[@f] : !struct.type<@TComponentB1::@ComponentB1<[@X]>>, !poly.tvar<@X>
        constrain.eq %v0, %v1 : !poly.tvar<@X>
        function.return
      }
    }
  }

  poly.template @TComponentB3 {
    poly.param @X

    struct.def @ComponentB3 {
      struct.member @f : !struct.type<@TComponentB1::@ComponentB1<[!poly.tvar<@X>]>>

      function.def @compute(%c0: !struct.type<@TComponentB1::@ComponentB1<[!poly.tvar<@X>]>>) -> !struct.type<@TComponentB3::@ComponentB3<[@X]>> {
        %self = struct.new : !struct.type<@TComponentB3::@ComponentB3<[@X]>>
        struct.writem %self[@f] = %c0 : !struct.type<@TComponentB3::@ComponentB3<[@X]>>, !struct.type<@TComponentB1::@ComponentB1<[!poly.tvar<@X>]>>
        function.return %self : !struct.type<@TComponentB3::@ComponentB3<[@X]>>
      }

      function.def @constrain(%self: !struct.type<@TComponentB3::@ComponentB3<[@X]>>, %c0: !struct.type<@TComponentB1::@ComponentB1<[!poly.tvar<@X>]>>) {
        %v0 = struct.readm %c0[@f] : !struct.type<@TComponentB1::@ComponentB1<[!poly.tvar<@X>]>>, !poly.tvar<@X>
        %c1 = struct.readm %self[@f] : !struct.type<@TComponentB3::@ComponentB3<[@X]>>, !struct.type<@TComponentB1::@ComponentB1<[!poly.tvar<@X>]>>
        %v1 = struct.readm %c1[@f] : !struct.type<@TComponentB1::@ComponentB1<[!poly.tvar<@X>]>>, !poly.tvar<@X>
        constrain.eq %v0, %v1 : !poly.tvar<@X>
        function.return
      }
    }
  }
}
