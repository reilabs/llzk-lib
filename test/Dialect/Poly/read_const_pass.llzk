// RUN: llzk-opt -split-input-file %s 2>&1 | FileCheck --enable-var-scope %s

module attributes {llzk.lang} {
  poly.template @TComponentE1 {
    poly.param @A

    struct.def @ComponentE1 {
      function.def @compute(%0: !felt.type) -> !struct.type<@TComponentE1::@ComponentE1<[@A]>> {
        %self = struct.new : !struct.type<@TComponentE1::@ComponentE1<[@A]>>
        function.return %self : !struct.type<@TComponentE1::@ComponentE1<[@A]>>
      }
      function.def @constrain(%self: !struct.type<@TComponentE1::@ComponentE1<[@A]>>, %0: !felt.type) {
        %1 = poly.read_const @A : !felt.type
        constrain.eq %0, %1 : !felt.type
        function.return
      }
    }
  }
}
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    poly.template @TComponentE1 {
// CHECK-NEXT:      poly.param @A
// CHECK-NEXT:      struct.def @ComponentE1 {
// CHECK-NEXT:        function.def @compute(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !felt.type) -> !struct.type<@TComponentE1::@ComponentE1<[@A]>> attributes {function.allow_witness} {
// CHECK-NEXT:          %[[VAL_1:[0-9a-zA-Z_\.]+]] = struct.new : <@TComponentE1::@ComponentE1<[@A]>>
// CHECK-NEXT:          function.return %[[VAL_1]] : !struct.type<@TComponentE1::@ComponentE1<[@A]>>
// CHECK-NEXT:        }
// CHECK-NEXT:        function.def @constrain(%[[VAL_2:[0-9a-zA-Z_\.]+]]: !struct.type<@TComponentE1::@ComponentE1<[@A]>>, %[[VAL_3:[0-9a-zA-Z_\.]+]]: !felt.type) attributes {function.allow_constraint} {
// CHECK-NEXT:          %[[VAL_4:[0-9a-zA-Z_\.]+]] = poly.read_const @A : !felt.type
// CHECK-NEXT:          constrain.eq %[[VAL_3]], %[[VAL_4]] : !felt.type, !felt.type
// CHECK-NEXT:          function.return
// CHECK-NEXT:        }
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }
