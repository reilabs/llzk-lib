        function.return %self : !struct.type<@TTester::@Tester<[@S0, @S1]>>
      }
      function.def @constrain(%self: !struct.type<@TTester::@Tester<[@S0, @S1]>>, %6: !struct.type<@TT2::@T2<[index]>>) {
        function.return
