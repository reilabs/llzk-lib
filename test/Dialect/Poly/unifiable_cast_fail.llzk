module attributes {llzk.lang} {
  poly.template @TTester {
    poly.param @S0
    poly.param @S1

    struct.def @Tester {
      function.def @compute(%0: !array.type<1 x !felt.type>) -> !struct.type<@TTester::@Tester<[@S0, @S1]>> {
        %self = struct.new : <@TTester::@Tester<[@S0, @S1]>>
        // expected-error@+1 {{'poly.unifiable_cast' op input type '!array.type<1 x !felt.type>' and output type '!array.type<2 x !felt.type>' are not unifiable}}
        %r0 = poly.unifiable_cast %0 : (!array.type<1 x !felt.type>) -> !array.type<2 x !felt.type>
        function.return %self : !struct.type<@TTester::@Tester<[@S0, @S1]>>
      }
      function.def @constrain(%self: !struct.type<@TTester::@Tester<[@S0, @S1]>>, %0: index) {
        function.return
      }
    }
  }
}

