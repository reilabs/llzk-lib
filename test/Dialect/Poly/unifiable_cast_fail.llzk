    poly.param @S1

    struct.def @Tester {
      function.def @compute(%6: !struct.type<@TT2::@T2<[index]>>) -> !struct.type<@TTester::@Tester<[@S0, @S1]>> {
        %self = struct.new : <@TTester::@Tester<[@S0, @S1]>>
        // expected-error@+1 {{'poly.unifiable_cast' op input type '!struct.type<@TT2::@T2<[index]>>' and output type '!struct.type<@TT2::@T2<[affine_map<()[s0, s1] -> (s0 + s1)>]>>' are not unifiable}}
