        function.return %self : !struct.type<@TTester::@Tester<[@S0, @S1]>>
      }
      function.def @constrain(%self: !struct.type<@TTester::@Tester<[@S0, @S1]>>, %18: !struct.type<@TT3::@T3<[1, 1, @S0, 1, !struct.type<@TT2::@T2<[1]>>]>>) {
