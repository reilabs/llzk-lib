// RUN: llzk-opt -split-input-file -verify-diagnostics %s

module attributes {llzk.lang} {
  poly.template @TTester {
    poly.param @S0
    poly.param @S1

    struct.def @Tester {
      function.def @compute(%0: index) -> !struct.type<@TTester::@Tester<[@S0, @S1]>> {
        %self = struct.new : <@TTester::@Tester<[@S0, @S1]>>
        // expected-error@+1 {{'poly.unifiable_cast' op input type 'index' and output type '!felt.type' are not unifiable}}
        %r0 = poly.unifiable_cast %0 : (index) -> !felt.type
        function.return %self : !struct.type<@TTester::@Tester<[@S0, @S1]>>
      }
      function.def @constrain(%self: !struct.type<@TTester::@Tester<[@S0, @S1]>>, %0: index) {
        function.return
      }
    }
  }
}
