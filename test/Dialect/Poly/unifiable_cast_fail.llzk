  poly.template @TTester {
    poly.param @S0
    poly.param @S1

    struct.def @Tester {
      function.def @compute(%18: !struct.type<@TT3::@T3<[1, 1, @S0, 1, !struct.type<@TT2::@T2<[1]>>]>>) -> !struct.type<@TTester::@Tester<[@S0, @S1]>> {
        %self = struct.new : <@TTester::@Tester<[@S0, @S1]>>
        // expected-error@+1 {{'poly.unifiable_cast' op input type '!struct.type<@TT3::@T3<[1, 1, @S0, 1, !struct.type<@TT2::@T2<[1]>>]>>' and output type '!struct.type<@TT3::@T3<[!string.type, affine_map<()[s0, s1] -> (s0 + s1)>, 1, @S0, !struct.type<@TT2::@T2<[affine_map<()[s0, s1] -> (s0 + s1)>]>>]>>' are not unifiable}}
