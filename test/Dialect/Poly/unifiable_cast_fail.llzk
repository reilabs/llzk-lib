  poly.template @TT3 {
    poly.param @A
    poly.param @B
    poly.param @C
    poly.param @D
    poly.param @E

    struct.def @T3 {
      function.def @compute() -> !struct.type<@TT3::@T3<[@A, @B, @C, @D, @E]>> {
