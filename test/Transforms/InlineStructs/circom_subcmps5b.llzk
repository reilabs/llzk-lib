// RUN: llzk-opt -llzk-full-struct-inlining %s 2>&1 | FileCheck --enable-var-scope %s

//////////////////////////////////////////////////////////////////////////////////
// template Nop() {
//     signal input i;
//     signal output o;
//     o <== i;
// }
//
// template SubCmp() {
//     signal input i;
//     signal output o;
//     component n = Nop();
//     n.i <-- i;
//     o <-- n.o;
// }
//
// component main = SubCmp();
//////////////////////////////////////////////////////////////////////////////////

!F = !felt.type<"bn128">
module attributes {llzk.lang = "circom", llzk.main = !struct.type<@SubCmp::@SubCmp<[]>>} {
  poly.template @Nop {
    struct.def @Nop {
      struct.member @o : !F {llzk.pub}
      function.def @compute(%arg0: !F {function.arg_name = "i"}) -> !struct.type<@Nop::@Nop<[]>> attributes {function.allow_non_native_field_ops, function.allow_witness} {
        %self = struct.new : <@Nop::@Nop<[]>>
        struct.writem %self[@o] = %arg0 : <@Nop::@Nop<[]>>, !F
        function.return %self : !struct.type<@Nop::@Nop<[]>>
      }
      function.def @constrain(%arg0: !struct.type<@Nop::@Nop<[]>>, %arg1: !F {function.arg_name = "i"}) attributes {function.allow_constraint, function.allow_non_native_field_ops} {
        %0 = struct.readm %arg0[@o] : <@Nop::@Nop<[]>>, !F
        constrain.eq %0, %arg1 : !F, !F
        function.return
      }
    }
  }
  poly.template @SubCmp {
    struct.def @SubCmp {
      struct.member @o : !F {llzk.pub}
      struct.member @n : !struct.type<@Nop::@Nop<[]>>
      struct.member @n$inputs : !pod.type<[@i: !F]>
      function.def @compute(%arg0: !F {function.arg_name = "i"}) -> !struct.type<@SubCmp::@SubCmp<[]>> attributes {function.allow_non_native_field_ops, function.allow_witness} {
        %self = struct.new : <@SubCmp::@SubCmp<[]>>
        %pod = pod.new : <[]>
        %c1 = arith.constant 1 : index
        %pod_0 = pod.new { @count = %c1, @params = %pod }  : <[@count: index, @comp: !struct.type<@Nop::@Nop<[]>>, @params: !pod.type<[]>]>
        %pod_1 = pod.new : <[@i: !F]>
        %pod_2 = pod.new : <[]>
        %c1_3 = arith.constant 1 : index
        %pod_4 = pod.new { @count = %c1_3, @params = %pod_2 }  : <[@count: index, @comp: !struct.type<@Nop::@Nop<[]>>, @params: !pod.type<[]>]>
        pod.write %pod_1[@i] = %arg0 : <[@i: !F]>, !F
        %0 = pod.read %pod_4[@count] : <[@count: index, @comp: !struct.type<@Nop::@Nop<[]>>, @params: !pod.type<[]>]>, index
        %c1_5 = arith.constant 1 : index
        %1 = arith.subi %0, %c1_5 : index
        pod.write %pod_4[@count] = %1 : <[@count: index, @comp: !struct.type<@Nop::@Nop<[]>>, @params: !pod.type<[]>]>, index
        %c0 = arith.constant 0 : index
        %2 = arith.cmpi eq, %1, %c0 : index
        scf.if %2 {
          %6 = pod.read %pod_4[@params] : <[@count: index, @comp: !struct.type<@Nop::@Nop<[]>>, @params: !pod.type<[]>]>, !pod.type<[]>
          %7 = pod.read %pod_1[@i] : <[@i: !F]>, !F
          %8 = function.call @Nop::@Nop::@compute(%7) : (!F) -> !struct.type<@Nop::@Nop<[]>>
          pod.write %pod_4[@comp] = %8 : <[@count: index, @comp: !struct.type<@Nop::@Nop<[]>>, @params: !pod.type<[]>]>, !struct.type<@Nop::@Nop<[]>>
        }
        %3 = pod.read %pod_4[@comp] : <[@count: index, @comp: !struct.type<@Nop::@Nop<[]>>, @params: !pod.type<[]>]>, !struct.type<@Nop::@Nop<[]>>
        %4 = struct.readm %3[@o] : <@Nop::@Nop<[]>>, !F
        struct.writem %self[@o] = %4 : <@SubCmp::@SubCmp<[]>>, !F
        struct.writem %self[@n$inputs] = %pod_1 : <@SubCmp::@SubCmp<[]>>, !pod.type<[@i: !F]>
        %5 = pod.read %pod_4[@comp] : <[@count: index, @comp: !struct.type<@Nop::@Nop<[]>>, @params: !pod.type<[]>]>, !struct.type<@Nop::@Nop<[]>>
        struct.writem %self[@n] = %5 : <@SubCmp::@SubCmp<[]>>, !struct.type<@Nop::@Nop<[]>>
        function.return %self : !struct.type<@SubCmp::@SubCmp<[]>>
      }
      function.def @constrain(%arg0: !struct.type<@SubCmp::@SubCmp<[]>>, %arg1: !F {function.arg_name = "i"}) attributes {function.allow_constraint, function.allow_non_native_field_ops} {
        %0 = struct.readm %arg0[@o] : <@SubCmp::@SubCmp<[]>>, !F
        %1 = struct.readm %arg0[@n] : <@SubCmp::@SubCmp<[]>>, !struct.type<@Nop::@Nop<[]>>
        %2 = struct.readm %arg0[@n$inputs] : <@SubCmp::@SubCmp<[]>>, !pod.type<[@i: !F]>
        %pod = pod.new : <[]>
        %pod_0 = pod.new : <[@count: index, @comp: !struct.type<@Nop::@Nop<[]>>, @params: !pod.type<[]>]>
        %3 = pod.read %2[@i] : <[@i: !F]>, !F
        function.call @Nop::@Nop::@constrain(%1, %3) : (!struct.type<@Nop::@Nop<[]>>, !F) -> ()
        function.return
      }
    }
  }
}

// CHECK-LABEL: module attributes {llzk.lang = "circom", llzk.main = !struct.type<@SubCmp::@SubCmp<[]>>} {
// CHECK-NEXT:    module @SubCmp {
// CHECK-NEXT:      struct.def @SubCmp {
// CHECK-NEXT:        struct.member @o : !felt.type<"bn128"> {llzk.pub}
// CHECK-NEXT:        struct.member @"n:!s<@Nop::@Nop>+o" : !felt.type<"bn128"> {llzk.pub}
// CHECK-NEXT:        struct.member @n$inputs_i : !felt.type<"bn128">
// CHECK-NEXT:        function.def @compute(%[[VAL_5:[0-9a-zA-Z_\.]+]]: !felt.type<"bn128"> {function.arg_name = "i"}) -> !struct.type<@SubCmp::@SubCmp> attributes {function.allow_non_native_field_ops, function.allow_witness} {
// CHECK-NEXT:          %[[VAL_6:[0-9a-zA-Z_\.]+]] = struct.new : <@SubCmp::@SubCmp>
// CHECK-NEXT:          struct.writem %[[VAL_6]][@"n:!s<@Nop::@Nop>+o"] = %[[VAL_5]] : <@SubCmp::@SubCmp>, !felt.type<"bn128">
// CHECK-NEXT:          %[[VAL_7:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_6]][@"n:!s<@Nop::@Nop>+o"] : <@SubCmp::@SubCmp>, !felt.type<"bn128">
// CHECK-NEXT:          struct.writem %[[VAL_6]][@o] = %[[VAL_7]] : <@SubCmp::@SubCmp>, !felt.type<"bn128">
// CHECK-NEXT:          struct.writem %[[VAL_6]][@n$inputs_i] = %[[VAL_5]] : <@SubCmp::@SubCmp>, !felt.type<"bn128">
// CHECK-NEXT:          function.return %[[VAL_6]] : !struct.type<@SubCmp::@SubCmp>
// CHECK-NEXT:        }
// CHECK-NEXT:        function.def @constrain(%[[VAL_8:[0-9a-zA-Z_\.]+]]: !struct.type<@SubCmp::@SubCmp>, %[[VAL_9:[0-9a-zA-Z_\.]+]]: !felt.type<"bn128"> {function.arg_name = "i"}) attributes {function.allow_constraint, function.allow_non_native_field_ops} {
// CHECK-NEXT:          %[[VAL_10:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_8]][@o] : <@SubCmp::@SubCmp>, !felt.type<"bn128">
// CHECK-NEXT:          %[[VAL_11:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_8]][@n$inputs_i] : <@SubCmp::@SubCmp>, !felt.type<"bn128">
// CHECK-NEXT:          %[[VAL_12:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_8]][@"n:!s<@Nop::@Nop>+o"] : <@SubCmp::@SubCmp>, !felt.type<"bn128">
// CHECK-NEXT:          constrain.eq %[[VAL_12]], %[[VAL_11]] : !felt.type<"bn128">, !felt.type<"bn128">
// CHECK-NEXT:          function.return
// CHECK-NEXT:        }
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }
