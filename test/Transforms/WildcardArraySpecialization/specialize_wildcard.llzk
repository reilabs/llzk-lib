module attributes {llzk.lang} {
  function.def @takes_two(
      %arg0: !array.type<? x !felt.type>,
      %arg1: !array.type<? x !felt.type>) {
    function.return
  }

  function.def @call_two_sizes(
      %arg0: !array.type<1 x !felt.type>,
