module attributes {llzk.lang} {
  struct.def @Log {
    function.def @compute(%arg0: !string.type, %arg1: !array.type<? x !felt.type>) -> !struct.type<@Log> {
      %self = struct.new : !struct.type<@Log>
      function.return %self : !struct.type<@Log>
    }
    function.def @constrain(%arg0: !struct.type<@Log>, %arg1: !string.type, %arg2: !array.type<? x !felt.type>) {
      function.return
    }
  }

  function.def private @Log$$extern(!string.type, !array.type<? x !felt.type>) -> !felt.type attributes {extern}

  function.def @call_log_extern(%a: !array.type<1 x !felt.type>) -> !felt.type {
    %0 = poly.unifiable_cast %a : (!array.type<1 x !felt.type>) -> !array.type<? x !felt.type>
    %1 = string.new "extern: "
    %2 = function.call @Log$$extern(%1, %0) : (!string.type, !array.type<? x !felt.type>) -> !felt.type
    function.return %2 : !felt.type
  }

  struct.def @ComponentD {
    function.def @compute(%a: !array.type<1 x !felt.type>) -> !struct.type<@ComponentD> {
      %self = struct.new : !struct.type<@ComponentD>
      %1 = poly.unifiable_cast %a : (!array.type<1 x !felt.type>) -> !array.type<? x !felt.type>
      %2 = string.new "test: "
      %3 = function.call @Log::@compute(%2, %1) : (!string.type, !array.type<? x !felt.type>) -> !struct.type<@Log>
      function.return %self : !struct.type<@ComponentD>
    }

    function.def @constrain(%self: !struct.type<@ComponentD>, %a: !array.type<1 x !felt.type>) { function.return }
  }
}
