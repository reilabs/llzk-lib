module attributes {llzk.lang} {
  poly.template @TComponentA1 {
    poly.param @T

    struct.def @ComponentA1 {
      struct.member @f1 : !poly.tvar<@T> {column, llzk.pub}

      function.def @constrain(%self: !struct.type<@TComponentA1::@ComponentA1<[@T]>>) { function.return }
      function.def @compute() -> !struct.type<@TComponentA1::@ComponentA1<[@T]>> {
        %self = struct.new : !struct.type<@TComponentA1::@ComponentA1<[@T]>>
        function.return %self : !struct.type<@TComponentA1::@ComponentA1<[@T]>>
      }
    }
  }

  poly.template @TComponentA2 {
    poly.param @N
    poly.param @T

    struct.def @ComponentA2 {
      function.def @compute(%p: !struct.type<@TComponentA1::@ComponentA1<[@T]>>) -> !struct.type<@TComponentA2::@ComponentA2<[@N, @T]>> {
        %self = struct.new : !struct.type<@TComponentA2::@ComponentA2<[@N, @T]>>
        %r = struct.readm %p[@f1] : !struct.type<@TComponentA1::@ComponentA1<[@T]>>, !poly.tvar<@T> {tableOffset = @N}
        function.return %self : !struct.type<@TComponentA2::@ComponentA2<[@N, @T]>>
      }

      function.def @constrain(%self: !struct.type<@TComponentA2::@ComponentA2<[@N, @T]>>, %p: !struct.type<@TComponentA1::@ComponentA1<[@T]>>) {
        function.return
      }
    }
  }

  struct.def @ComponentA3 {
    function.def @compute(%p: !struct.type<@TComponentA1::@ComponentA1<[!felt.type]>>) -> !struct.type<@ComponentA3> {
      %self = struct.new : !struct.type<@ComponentA3>
      %c = function.call @TComponentA2::@ComponentA2::@compute(%p) : (!struct.type<@TComponentA1::@ComponentA1<[!felt.type]>>) -> !struct.type<@TComponentA2::@ComponentA2<[-1, !felt.type]>>
      function.return %self : !struct.type<@ComponentA3>
    }

    function.def @constrain(%self: !struct.type<@ComponentA3>, %p: !struct.type<@TComponentA1::@ComponentA1<[!felt.type]>>) {
      function.return
    }
  }
}
