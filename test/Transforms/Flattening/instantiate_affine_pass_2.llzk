// RUN: llzk-opt -split-input-file -llzk-flatten -verify-diagnostics %s | FileCheck --enable-var-scope %s

#id = affine_map<(i)->(i)>
#IdxToLen = affine_map<(i)->(5*i+1)>
!ToFelt = !struct.type<@TToFelt::@ToFelt<[#id]>>
// In this test, `#IdxToLen` is instantiated via a `array.new` op but there are no instantiations of
// the `!struct.type<@ToFelt<[#id]>>` StructType (i.e., no calls to `@ToFelt::@compute()`) so no
// flattened versions of `@ToFelt` or `@VarArray` are created (the latter has an instantiation but
// only the first parameter is concrete due to the aforementioned and we do not do partial flattening).
module attributes {llzk.lang} {
  // pre-defined
  poly.template @TVarArray {
    poly.param @N
    poly.param @T

    struct.def @VarArray {
      struct.member @val: !array.type<@N x !poly.tvar<@T>>

      function.def @compute(%inp: !array.type<@N x !poly.tvar<@T>>) -> !struct.type<@TVarArray::@VarArray<[@N, @T]>> {
        %self = struct.new : !struct.type<@TVarArray::@VarArray<[@N, @T]>>
        struct.writem %self[@val] = %inp : !struct.type<@TVarArray::@VarArray<[@N, @T]>>, !array.type<@N x !poly.tvar<@T>>
        function.return %self : !struct.type<@TVarArray::@VarArray<[@N, @T]>>
      }

      function.def @constrain(%self: !struct.type<@TVarArray::@VarArray<[@N, @T]>>, %inp: !array.type<@N x !poly.tvar<@T>>) {
        function.return
      }
    }
  }

  poly.template @TToFelt {
    poly.param @A

    struct.def @ToFelt {
      struct.member @out: !felt.type {llzk.pub}

      function.def @compute() -> !struct.type<@TToFelt::@ToFelt<[@A]>> {
        %self = struct.new : !struct.type<@TToFelt::@ToFelt<[@A]>>
        %constA = poly.read_const @A : !felt.type
        struct.writem %self[@out] = %constA : !struct.type<@TToFelt::@ToFelt<[@A]>>, !felt.type
        function.return %self: !struct.type<@TToFelt::@ToFelt<[@A]>>
      }

      function.def @constrain(%self: !struct.type<@TToFelt::@ToFelt<[@A]>>) {
        function.return
      }
    }
  }

  struct.def @ComponentB {
    function.def @compute(%a: index) -> !struct.type<@ComponentB> {
      %self = struct.new : !struct.type<@ComponentB>
      // In real code, this should be loop induction variable
      %n = arith.constant 2 : index
      // The array length is a function of 'i' and it contains non-homogeneous structs
      //    !ToFelt = !struct.type<@ToFelt<[#id]>>
      %arr = array.new{(%n)} : !array.type<#IdxToLen x !ToFelt>
      // Real code would probably have a loop here j= 0..n that assigns values to the array
      //
      // Creates a VarArray with length as a function of 'n' and non-homogeneous element type
      %wsi = function.call @TVarArray::@VarArray::@compute(%arr){(%n)}
        : (!array.type<#IdxToLen x !ToFelt>) -> !struct.type<@TVarArray::@VarArray<[#IdxToLen, !ToFelt]>>
      //
      function.return %self : !struct.type<@ComponentB>
    }

    function.def @constrain(%self: !struct.type<@ComponentB>, %a: index) {
      function.return
    }
  }
}
// CHECK: #[[$M0:[0-9a-zA-Z_\.]+]] = affine_map<(d0) -> (d0)>
//
// CHECK-LABEL: poly.template @"TVarArray_11_\1A" {
// CHECK-NEXT:    poly.param @T
// CHECK-NEXT:    struct.def @VarArray {
// CHECK-NEXT:      struct.member @val : !array.type<11 x !poly.tvar<@T>>
// CHECK-NEXT:      function.def @compute(%[[V0:[0-9a-zA-Z_\.]+]]: !array.type<11 x !poly.tvar<@T>>) -> !struct.type<@"TVarArray_11_\1A"::@VarArray<[@T]>> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[V1:[0-9a-zA-Z_\.]+]] = struct.new : <@"TVarArray_11_\1A"::@VarArray<[@T]>>
// CHECK-NEXT:        struct.writem %[[V1]][@val] = %[[V0]] : <@"TVarArray_11_\1A"::@VarArray<[@T]>>, !array.type<11 x !poly.tvar<@T>>
// CHECK-NEXT:        function.return %[[V1]] : !struct.type<@"TVarArray_11_\1A"::@VarArray<[@T]>>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[V2:[0-9a-zA-Z_\.]+]]: !struct.type<@"TVarArray_11_\1A"::@VarArray<[@T]>>, %[[V3:[0-9a-zA-Z_\.]+]]: !array.type<11 x !poly.tvar<@T>>) attributes {function.allow_constraint} {
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }
//
// CHECK-LABEL: poly.template @TToFelt {
// CHECK-NEXT:    poly.param @A
// CHECK-NEXT:    struct.def @ToFelt {
// CHECK-NEXT:      struct.member @out : !felt.type {llzk.pub}
// CHECK-NEXT:      function.def @compute() -> !struct.type<@TToFelt::@ToFelt<[@A]>> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[V4:[0-9a-zA-Z_\.]+]] = struct.new : <@TToFelt::@ToFelt<[@A]>>
// CHECK-NEXT:        %[[V5:[0-9a-zA-Z_\.]+]] = poly.read_const @A : !felt.type
// CHECK-NEXT:        struct.writem %[[V4]][@out] = %[[V5]] : <@TToFelt::@ToFelt<[@A]>>, !felt.type
// CHECK-NEXT:        function.return %[[V4]] : !struct.type<@TToFelt::@ToFelt<[@A]>>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[V6:[0-9a-zA-Z_\.]+]]: !struct.type<@TToFelt::@ToFelt<[@A]>>) attributes {function.allow_constraint} {
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }
//
// CHECK-LABEL: struct.def @ComponentB {
// CHECK-NEXT:    function.def @compute(%[[V7:[0-9a-zA-Z_\.]+]]: index) -> !struct.type<@ComponentB> attributes {function.allow_witness} {
// CHECK-NEXT:      %[[V8:[0-9a-zA-Z_\.]+]] = struct.new : <@ComponentB>
// CHECK-NEXT:      %[[V9:[0-9a-zA-Z_\.]+]] = array.new  : <11 x !struct.type<@TToFelt::@ToFelt<[#[[$M0]]]>>>
// CHECK-NEXT:      %[[V10:[0-9a-zA-Z_\.]+]] = function.call @"TVarArray_11_\1A"::@VarArray::@compute(%[[V9]]) : (!array.type<11 x !struct.type<@TToFelt::@ToFelt<[#[[$M0]]]>>>) -> !struct.type<@"TVarArray_11_\1A"::@VarArray<[!struct.type<@TToFelt::@ToFelt<[#[[$M0]]]>>]>>
// CHECK-NEXT:      function.return %[[V8]] : !struct.type<@ComponentB>
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[V11:[0-9a-zA-Z_\.]+]]: !struct.type<@ComponentB>, %[[V12:[0-9a-zA-Z_\.]+]]: index) attributes {function.allow_constraint} {
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:  }
