// RUN: llzk-opt -split-input-file -llzk-flatten %s | FileCheck --enable-var-scope %s

#mapDiv = affine_map<()[s0, s1] -> (s0 floordiv s1)>
#mapAdd = affine_map<()[s0, s1] -> (s0 + s1)>
module attributes {llzk.lang = "zirgen"} {
  poly.template @TFoo {
    poly.param @Aff

    struct.def @Foo {
      struct.member @bar: !struct.type<@TBar::@Bar<[@Aff]>>
      function.def @compute(%arg: !struct.type<@TBar::@Bar<[@Aff]>>) -> !struct.type<@TFoo::@Foo<[@Aff]>> {
        %self = struct.new : !struct.type<@TFoo::@Foo<[@Aff]>>
        struct.writem %self[@bar] = %arg : !struct.type<@TFoo::@Foo<[@Aff]>>, !struct.type<@TBar::@Bar<[@Aff]>>
        function.return %self : !struct.type<@TFoo::@Foo<[@Aff]>>
      }
      function.def @constrain(%self: !struct.type<@TFoo::@Foo<[@Aff]>>, %arg: !struct.type<@TBar::@Bar<[@Aff]>>) {
        function.return
      }
    }
  }
  poly.template @TBar {
    poly.param @Aff

    struct.def @Bar {
      function.def @compute() -> !struct.type<@TBar::@Bar<[@Aff]>> {
        %self = struct.new : !struct.type<@TBar::@Bar<[@Aff]>>
        function.return %self : !struct.type<@TBar::@Bar<[@Aff]>>
      }
      function.def @constrain(%arg0: !struct.type<@TBar::@Bar<[@Aff]>>) {
        function.return
      }
    }
  }
  poly.template @TUnpack {
    poly.param @N
    poly.param @P
    poly.param @Aff

    struct.def @Unpack {
      struct.member @f: !struct.type<@TBar::@Bar<[#mapAdd]>>
      struct.member @g: !array.type<@Aff x !felt.type>
      function.def @compute(%arg0: !array.type<@Aff x !felt.type>) -> !struct.type<@TUnpack::@Unpack<[@N, @P, @Aff]>> {
        %self = struct.new : !struct.type<@TUnpack::@Unpack<[@N, @P, @Aff]>>
        struct.writem %self[@g] = %arg0 : !struct.type<@TUnpack::@Unpack<[@N, @P, @Aff]>>, !array.type<@Aff x !felt.type>

        %n = poly.read_const @N : index
        %p = poly.read_const @P : index
        %0 = function.call @TBar::@Bar::@compute() {()[%n,%p]} : () -> !struct.type<@TBar::@Bar<[#mapAdd]>>
        struct.writem %self[@f] = %0 : !struct.type<@TUnpack::@Unpack<[@N, @P, @Aff]>>, !struct.type<@TBar::@Bar<[#mapAdd]>>

        %1 = function.call @TFoo::@Foo::@compute(%0) {()[%n,%p]} : (!struct.type<@TBar::@Bar<[#mapAdd]>>) -> !struct.type<@TFoo::@Foo<[#mapAdd]>>

        function.return %self : !struct.type<@TUnpack::@Unpack<[@N, @P, @Aff]>>
      }
      function.def @constrain(%arg0: !struct.type<@TUnpack::@Unpack<[@N, @P, @Aff]>>, %arg1: !array.type<@Aff x !felt.type>) {
        function.return
      }
    }
  }
  struct.def @User1 {
    function.def @compute() -> !struct.type<@User1> {
      %0 = felt.const 42
      %1 = felt.const 99
      %2 = felt.const 42
      %3 = felt.const 99

      %arr = array.new %0, %1, %2, %3 : !array.type<4 x !felt.type>
      %a = arith.constant 8 : index
      %b = arith.constant 2 : index
      %s = function.call @TUnpack::@Unpack::@compute(%arr) {()[%a, %b]}
        : (!array.type<4 x !felt.type>) -> !struct.type<@TUnpack::@Unpack<[8, 2, #mapDiv]>>
      %self = struct.new : !struct.type<@User1>
      function.return %self : !struct.type<@User1>
    }
    function.def @constrain(%arg0: !struct.type<@User1>) {
      function.return
    }
  }
}
// CHECK-LABEL: struct.def @TFoo_10_Foo {
// CHECK-NEXT:    struct.member @bar : !struct.type<@TBar_10_Bar>
// CHECK-NEXT:    function.def @compute(%[[V0:[0-9a-zA-Z_\.]+]]: !struct.type<@TBar_10_Bar>) -> !struct.type<@TFoo_10_Foo> attributes {function.allow_witness} {
// CHECK-NEXT:      %[[V1:[0-9a-zA-Z_\.]+]] = struct.new : <@TFoo_10_Foo>
// CHECK-NEXT:      struct.writem %[[V1]][@bar] = %[[V0]] : <@TFoo_10_Foo>, !struct.type<@TBar_10_Bar>
// CHECK-NEXT:      function.return %[[V1]] : !struct.type<@TFoo_10_Foo>
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[V2:[0-9a-zA-Z_\.]+]]: !struct.type<@TFoo_10_Foo>, %[[V3:[0-9a-zA-Z_\.]+]]: !struct.type<@TBar_10_Bar>) attributes {function.allow_constraint} {
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:  }
//
// CHECK-LABEL: struct.def @TBar_10_Bar {
// CHECK-NEXT:    function.def @compute() -> !struct.type<@TBar_10_Bar> attributes {function.allow_witness} {
// CHECK-NEXT:      %[[V0:[0-9a-zA-Z_\.]+]] = struct.new : <@TBar_10_Bar>
// CHECK-NEXT:      function.return %[[V0]] : !struct.type<@TBar_10_Bar>
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[V1:[0-9a-zA-Z_\.]+]]: !struct.type<@TBar_10_Bar>) attributes {function.allow_constraint} {
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:  }
//
// CHECK-LABEL: struct.def @TUnpack_8_2_4_Unpack {
// CHECK-NEXT:    struct.member @f : !struct.type<@TBar_10_Bar>
// CHECK-NEXT:    struct.member @g : !array.type<4 x !felt.type>
// CHECK-NEXT:    function.def @compute(%[[V0:[0-9a-zA-Z_\.]+]]: !array.type<4 x !felt.type>) -> !struct.type<@TUnpack_8_2_4_Unpack> attributes {function.allow_witness} {
// CHECK-NEXT:      %[[V1:[0-9a-zA-Z_\.]+]] = struct.new : <@TUnpack_8_2_4_Unpack>
// CHECK-NEXT:      struct.writem %[[V1]][@g] = %[[V0]] : <@TUnpack_8_2_4_Unpack>, !array.type<4 x !felt.type>
// CHECK-NEXT:      %[[V2:[0-9a-zA-Z_\.]+]] = function.call @TBar_10_Bar::@compute() : () -> !struct.type<@TBar_10_Bar>
// CHECK-NEXT:      struct.writem %[[V1]][@f] = %[[V2]] : <@TUnpack_8_2_4_Unpack>, !struct.type<@TBar_10_Bar>
// CHECK-NEXT:      %[[V3:[0-9a-zA-Z_\.]+]] = function.call @TFoo_10_Foo::@compute(%[[V2]]) : (!struct.type<@TBar_10_Bar>) -> !struct.type<@TFoo_10_Foo>
// CHECK-NEXT:      function.return %[[V1]] : !struct.type<@TUnpack_8_2_4_Unpack>
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[V4:[0-9a-zA-Z_\.]+]]: !struct.type<@TUnpack_8_2_4_Unpack>, %[[V5:[0-9a-zA-Z_\.]+]]: !array.type<4 x !felt.type>) attributes {function.allow_constraint} {
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:  }
//
// CHECK-LABEL: struct.def @User1 {
// CHECK-NEXT:    function.def @compute() -> !struct.type<@User1> attributes {function.allow_witness} {
// CHECK-NEXT:      %[[V0:[0-9a-zA-Z_\.]+]] = felt.const 42
// CHECK-NEXT:      %[[V1:[0-9a-zA-Z_\.]+]] = felt.const 99
// CHECK-NEXT:      %[[V2:[0-9a-zA-Z_\.]+]] = array.new %[[V0]], %[[V1]], %[[V0]], %[[V1]] : <4 x !felt.type>
// CHECK-NEXT:      %[[V3:[0-9a-zA-Z_\.]+]] = function.call @TUnpack_8_2_4_Unpack::@compute(%[[V2]]) : (!array.type<4 x !felt.type>) -> !struct.type<@TUnpack_8_2_4_Unpack>
// CHECK-NEXT:      %[[V4:[0-9a-zA-Z_\.]+]] = struct.new : <@User1>
// CHECK-NEXT:      function.return %[[V4]] : !struct.type<@User1>
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[V5:[0-9a-zA-Z_\.]+]]: !struct.type<@User1>) attributes {function.allow_constraint} {
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:  }
