// CHECK-NEXT:      %[[V0:[0-9a-zA-Z_\.]+]] = struct.new : <@TPair_f_f_Pair>
// CHECK-NEXT:      function.return %[[V0]] : !struct.type<@TPair_f_f_Pair>
// CHECK-NEXT:    }
