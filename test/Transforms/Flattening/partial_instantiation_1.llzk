// CHECK-NEXT:      %[[V6:[0-9a-zA-Z_\.]+]] = struct.new : <@TMakeGuess_4_MakeGuess>
// CHECK-NEXT:      function.return %[[V6]] : !struct.type<@TMakeGuess_4_MakeGuess>
