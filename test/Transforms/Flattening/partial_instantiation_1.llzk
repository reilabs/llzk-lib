// CHECK-NEXT:      %[[V15:[0-9a-zA-Z_\.]+]] = struct.new : <@Main>
// CHECK-NEXT:      %[[V16:[0-9a-zA-Z_\.]+]] = function.call @TMakeGuess_4_MakeGuess::@compute() : () -> !struct.type<@TMakeGuess_4_MakeGuess>
// CHECK-NEXT:      function.return %[[V15]] : !struct.type<@Main>
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[V17:[0-9a-zA-Z_\.]+]]: !struct.type<@Main>) attributes {function.allow_constraint} {
