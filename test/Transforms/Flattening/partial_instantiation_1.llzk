// CHECK-NEXT:      %[[V8:[0-9a-zA-Z_\.]+]] = arith.constant 1 : index
// CHECK-NEXT:      %[[V9:[0-9a-zA-Z_\.]+]] = arith.constant 0 : index
// CHECK-NEXT:      %[[V10:[0-9a-zA-Z_\.]+]] = struct.readm %[[V7]][@"$temp"] : <@TMakeGuess_4_MakeGuess>, !struct.type<@TZip_f_f_4_Zip>
// CHECK-NEXT:      %[[V11:[0-9a-zA-Z_\.]+]] = struct.readm %[[V10]][@"$super"] : <@TZip_f_f_4_Zip>, !array.type<9 x !struct.type<@TPair_f_f_Pair>>
// CHECK-NEXT:      %[[V12:[0-9a-zA-Z_\.]+]] = array.len %[[V11]], %[[V9]] : <9 x !struct.type<@TPair_f_f_Pair>>
// CHECK-NEXT:      scf.for %[[V13:[0-9a-zA-Z_\.]+]] = %[[V9]] to %[[V12]] step %[[V8]] {
// CHECK-NEXT:        %[[V14:[0-9a-zA-Z_\.]+]] = array.read %[[V11]]{{\[}}%[[V13]]] : <9 x !struct.type<@TPair_f_f_Pair>>, !struct.type<@TPair_f_f_Pair>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.return
