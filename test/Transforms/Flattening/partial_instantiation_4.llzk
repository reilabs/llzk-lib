// RUN: llzk-opt -split-input-file -llzk-flatten %s | FileCheck --enable-var-scope %s

// TEST: partial instantiation where 'read_const' cannot be removed
#id = affine_map<(i)->(i)>
module attributes {llzk.lang} {
  poly.template @TZip {
    poly.param @Lhs
    poly.param @Rhs
    poly.param @N

    struct.def @Zip {
      struct.member @"$array" : !array.type<#id x !felt.type>

      function.def @compute() -> !struct.type<@TZip::@Zip<[@Lhs, @Rhs, @N]>> {
        %self = struct.new : !struct.type<@TZip::@Zip<[@Lhs, @Rhs, @N]>>
        %1 = poly.read_const @N : index
        %array = array.new{(%1)[]} : !array.type<#id x !felt.type>
        struct.writem %self[@"$array"] = %array : !struct.type<@TZip::@Zip<[@Lhs, @Rhs, @N]>>, !array.type<#id x !felt.type>
        function.return %self : !struct.type<@TZip::@Zip<[@Lhs, @Rhs, @N]>>
      }

      function.def @constrain(%arg0: !struct.type<@TZip::@Zip<[@Lhs, @Rhs, @N]>>) {
        %1 = poly.read_const @N : index
        %array = array.new{(%1)[]} : <#id x !felt.type>
        function.return
      }
    }
  }

  poly.template @TTop {
    poly.param @N

    struct.def @Top {
      function.def @compute() -> !struct.type<@TTop::@Top<[@N]>> {
        %self = struct.new : !struct.type<@TTop::@Top<[@N]>>
        function.call @TZip::@Zip::@compute() : () -> !struct.type<@TZip::@Zip<[!felt.type, !felt.type, @N]>>
        function.return %self : !struct.type<@TTop::@Top<[@N]>>
      }
      function.def @constrain(%arg0: !struct.type<@TTop::@Top<[@N]>>) {
        function.return
      }
    }
  }
}
// CHECK: #[[$M0:.+]] = affine_map<(d0) -> (d0)>
//
// CHECK-LABEL: poly.template @"TZip_f_f_\1A" {
// CHECK-NEXT:    poly.param @N
// CHECK-NEXT:    struct.def @Zip {
// CHECK-NEXT:      struct.member @"$array" : !array.type<#[[$M0]] x !felt.type>
// CHECK-NEXT:      function.def @compute() -> !struct.type<@"TZip_f_f_\1A"::@Zip<[@N]>> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[V0:[0-9a-zA-Z_\.]+]] = struct.new : <@"TZip_f_f_\1A"::@Zip<[@N]>>
// CHECK-NEXT:        %[[V1:[0-9a-zA-Z_\.]+]] = poly.read_const @N : index
// CHECK-NEXT:        %[[V2:[0-9a-zA-Z_\.]+]] = array.new{(%[[V1]])} : <#[[$M0]] x !felt.type>
// CHECK-NEXT:        struct.writem %[[V0]][@"$array"] = %[[V2]] : <@"TZip_f_f_\1A"::@Zip<[@N]>>, !array.type<#[[$M0]] x !felt.type>
// CHECK-NEXT:        function.return %[[V0]] : !struct.type<@"TZip_f_f_\1A"::@Zip<[@N]>>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[V3:[0-9a-zA-Z_\.]+]]: !struct.type<@"TZip_f_f_\1A"::@Zip<[@N]>>) attributes {function.allow_constraint} {
// CHECK-NEXT:        %[[V4:[0-9a-zA-Z_\.]+]] = poly.read_const @N : index
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }
//
// CHECK-LABEL: poly.template @TTop {
// CHECK-NEXT:    poly.param @N
// CHECK-NEXT:    struct.def @Top {
// CHECK-NEXT:      function.def @compute() -> !struct.type<@TTop::@Top<[@N]>> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[V5:[0-9a-zA-Z_\.]+]] = struct.new : <@TTop::@Top<[@N]>>
// CHECK-NEXT:        %[[V6:[0-9a-zA-Z_\.]+]] = function.call @"TZip_f_f_\1A"::@Zip::@compute() : () -> !struct.type<@"TZip_f_f_\1A"::@Zip<[@N]>>
// CHECK-NEXT:        function.return %[[V5]] : !struct.type<@TTop::@Top<[@N]>>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[V7:[0-9a-zA-Z_\.]+]]: !struct.type<@TTop::@Top<[@N]>>) attributes {function.allow_constraint} {
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }
