// RUN: llzk-opt -split-input-file -llzk-flatten -verify-diagnostics %s | FileCheck %s

#id = affine_map<(i)->(i)>
!ToFelt = !struct.type<@TToFelt::@ToFelt<[#id]>>
module attributes {llzk.lang} {
  poly.template @TToFelt {
    poly.param @A

    struct.def @ToFelt {
      function.def @compute() -> !struct.type<@TToFelt::@ToFelt<[@A]>> {
        %self = struct.new : !struct.type<@TToFelt::@ToFelt<[@A]>>
        function.return %self: !struct.type<@TToFelt::@ToFelt<[@A]>>
      }

      function.def @constrain(%self: !struct.type<@TToFelt::@ToFelt<[@A]>>) { function.return }
    }
  }

  poly.template @TComponentA {
    poly.param @T

    struct.def @ComponentA {
      function.def @compute(%inp: !struct.type<@TToFelt::@ToFelt<[@T]>>) -> !struct.type<@TComponentA::@ComponentA<[@T]>> {
        %self = struct.new : !struct.type<@TComponentA::@ComponentA<[@T]>>
        function.return %self : !struct.type<@TComponentA::@ComponentA<[@T]>>
      }

      function.def @constrain(%self: !struct.type<@TComponentA::@ComponentA<[@T]>>, %inp: !struct.type<@TToFelt::@ToFelt<[@T]>>) { function.return }
    }
  }

  struct.def @ComponentB {
    function.def @compute() -> !struct.type<@ComponentB> {
      // In real code, this should be loop induction variable
      %n = arith.constant 2 : index
      %in = function.call @TToFelt::@ToFelt::@compute(){(%n)} : () -> !ToFelt
      %out = function.call @TComponentA::@ComponentA::@compute(%in) : (!ToFelt) -> !struct.type<@TComponentA::@ComponentA<[2]>>

      %self = struct.new : !struct.type<@ComponentB>
      function.return %self : !struct.type<@ComponentB>
    }

    function.def @constrain(%self: !struct.type<@ComponentB>) { function.return }
  }
}
// CHECK-LABEL: struct.def @TToFelt_2_ToFelt {
// CHECK-NEXT:    function.def @compute() -> !struct.type<@TToFelt_2_ToFelt> attributes {function.allow_witness} {
// CHECK-NEXT:      %[[V0:[0-9a-zA-Z_\.]+]] = struct.new : <@TToFelt_2_ToFelt>
// CHECK-NEXT:      function.return %[[V0]] : !struct.type<@TToFelt_2_ToFelt>
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[V1:[0-9a-zA-Z_\.]+]]: !struct.type<@TToFelt_2_ToFelt>) attributes {function.allow_constraint} {
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:  }
//
// CHECK-LABEL: struct.def @TComponentA_2_ComponentA {
// CHECK-NEXT:    function.def @compute(%[[V2:[0-9a-zA-Z_\.]+]]: !struct.type<@TToFelt_2_ToFelt>) -> !struct.type<@TComponentA_2_ComponentA> attributes {function.allow_witness} {
// CHECK-NEXT:      %[[V3:[0-9a-zA-Z_\.]+]] = struct.new : <@TComponentA_2_ComponentA>
// CHECK-NEXT:      function.return %[[V3]] : !struct.type<@TComponentA_2_ComponentA>
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[V4:[0-9a-zA-Z_\.]+]]: !struct.type<@TComponentA_2_ComponentA>, %[[V5:[0-9a-zA-Z_\.]+]]: !struct.type<@TToFelt_2_ToFelt>) attributes {function.allow_constraint} {
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:  }
//
// CHECK-LABEL: struct.def @ComponentB {
// CHECK-NEXT:    function.def @compute() -> !struct.type<@ComponentB> attributes {function.allow_witness} {
// CHECK-NEXT:      %[[V6:[0-9a-zA-Z_\.]+]] = function.call @TToFelt_2_ToFelt::@compute() : () -> !struct.type<@TToFelt_2_ToFelt>
// CHECK-NEXT:      %[[V7:[0-9a-zA-Z_\.]+]] = function.call @TComponentA_2_ComponentA::@compute(%[[V6]]) : (!struct.type<@TToFelt_2_ToFelt>) -> !struct.type<@TComponentA_2_ComponentA>
// CHECK-NEXT:      %[[V8:[0-9a-zA-Z_\.]+]] = struct.new : <@ComponentB>
// CHECK-NEXT:      function.return %[[V8]] : !struct.type<@ComponentB>
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[V9:[0-9a-zA-Z_\.]+]]: !struct.type<@ComponentB>) attributes {function.allow_constraint} {
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:  }
