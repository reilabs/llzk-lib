// CHECK-NEXT:      struct.writem %[[VAL_0]][@f2] = %[[VAL_1]] : <@TComponent01B_43_Component01B>, !struct.type<@TComponent01A_5_43_Component01A>
// CHECK-NEXT:      function.return %[[VAL_0]] : !struct.type<@TComponent01B_43_Component01B>
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[VAL_2:[0-9a-zA-Z_\.]+]]: !struct.type<@TComponent01B_43_Component01B>) attributes {function.allow_constraint} {
// CHECK-NEXT:      %[[VAL_3:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_2]][@f2] : <@TComponent01B_43_Component01B>, !struct.type<@TComponent01A_5_43_Component01A>
// CHECK-NEXT:      function.call @TComponent01A_5_43_Component01A::@constrain(%[[VAL_3]]) : (!struct.type<@TComponent01A_5_43_Component01A>) -> ()
// CHECK-NEXT:      function.return
