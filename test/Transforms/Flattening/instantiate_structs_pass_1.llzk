module attributes {llzk.lang} {
  poly.template @TComponent01A {
    poly.param @A
    poly.param @B

    struct.def @Component01A {
      function.def @compute() -> !struct.type<@TComponent01A::@Component01A<[@A, @B]>> {
        %self = struct.new : !struct.type<@TComponent01A::@Component01A<[@A, @B]>>
        function.return %self : !struct.type<@TComponent01A::@Component01A<[@A, @B]>>
      }
      function.def @constrain(%self: !struct.type<@TComponent01A::@Component01A<[@A, @B]>>) { function.return }
    }
  }

  poly.template @TComponent01B {
    poly.param @C

    struct.def @Component01B {
      struct.member @f2 : !struct.type<@TComponent01A::@Component01A<[5, @C]>>

      function.def @compute() -> !struct.type<@TComponent01B::@Component01B<[@C]>> {
        %self = struct.new : !struct.type<@TComponent01B::@Component01B<[@C]>>
        %x = function.call @TComponent01A::@Component01A::@compute() : () -> (!struct.type<@TComponent01A::@Component01A<[5, @C]>>)
        struct.writem %self[@f2] = %x : !struct.type<@TComponent01B::@Component01B<[@C]>>, !struct.type<@TComponent01A::@Component01A<[5, @C]>>
        function.return %self : !struct.type<@TComponent01B::@Component01B<[@C]>>
      }

      function.def @constrain(%self: !struct.type<@TComponent01B::@Component01B<[@C]>>) {
        %b = struct.readm %self[@f2] : !struct.type<@TComponent01B::@Component01B<[@C]>>, !struct.type<@TComponent01A::@Component01A<[5, @C]>>
        function.call @TComponent01A::@Component01A::@constrain(%b) : (!struct.type<@TComponent01A::@Component01A<[5, @C]>>) -> ()
        function.return
      }
    }
  }

  struct.def @Component01C {
    struct.member @f3 : !struct.type<@TComponent01B::@Component01B<[43]>>

    function.def @compute() -> !struct.type<@Component01C> {
      %self = struct.new : !struct.type<@Component01C>
      %x = function.call @TComponent01B::@Component01B::@compute() : () -> (!struct.type<@TComponent01B::@Component01B<[43]>>)
      struct.writem %self[@f3] = %x : !struct.type<@Component01C>, !struct.type<@TComponent01B::@Component01B<[43]>>
      function.return %self : !struct.type<@Component01C>
    }

    function.def @constrain(%self: !struct.type<@Component01C>) {
      %b = struct.readm %self[@f3] : !struct.type<@Component01C>, !struct.type<@TComponent01B::@Component01B<[43]>>
      function.call @TComponent01B::@Component01B::@constrain(%b) : (!struct.type<@TComponent01B::@Component01B<[43]>>) -> ()
      function.return
    }
  }
}
// CHECK-LABEL: struct.def @TComponent01A_5_43_Component01A {
// CHECK-NEXT:    function.def @compute() -> !struct.type<@TComponent01A_5_43_Component01A> attributes {function.allow_witness} {
// CHECK-NEXT:      %[[VAL_0:[0-9a-zA-Z_\.]+]] = struct.new : <@TComponent01A_5_43_Component01A>
// CHECK-NEXT:      function.return %[[VAL_0]] : !struct.type<@TComponent01A_5_43_Component01A>
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[VAL_1:[0-9a-zA-Z_\.]+]]: !struct.type<@TComponent01A_5_43_Component01A>) attributes {function.allow_constraint} {
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:  }
//
