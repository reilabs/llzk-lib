/// Ensure a StructType using a param somewhere in the type is not converted.
module attributes {llzk.lang} {
  poly.template @TComponent06A {
    poly.param @C

    struct.def @Component06A {
      struct.member @f1 : !poly.tvar<@C>

      function.def @compute() -> !struct.type<@TComponent06A::@Component06A<[@C]>> {
        %self = struct.new : !struct.type<@TComponent06A::@Component06A<[@C]>>
        function.return %self : !struct.type<@TComponent06A::@Component06A<[@C]>>
      }

      function.def @constrain(%self: !struct.type<@TComponent06A::@Component06A<[@C]>>) {
        function.return
      }
    }
  }

  poly.template @TComponent06B {
    poly.param @T

    struct.def @Component06B {
      struct.member @f2 : !struct.type<@TComponent06A::@Component06A<[!array.type<@T x i1>]>>

      function.def @compute() -> !struct.type<@TComponent06B::@Component06B<[@T]>> {
        %self = struct.new : !struct.type<@TComponent06B::@Component06B<[@T]>>
        %x = function.call @TComponent06A::@Component06A::@compute() : () -> (!struct.type<@TComponent06A::@Component06A<[!array.type<@T x i1>]>>)
        struct.writem %self[@f2] = %x : !struct.type<@TComponent06B::@Component06B<[@T]>>, !struct.type<@TComponent06A::@Component06A<[!array.type<@T x i1>]>>
        function.return %self : !struct.type<@TComponent06B::@Component06B<[@T]>>
      }

      function.def @constrain(%self: !struct.type<@TComponent06B::@Component06B<[@T]>>) {
        %b = struct.readm %self[@f2] : !struct.type<@TComponent06B::@Component06B<[@T]>>, !struct.type<@TComponent06A::@Component06A<[!array.type<@T x i1>]>>
        function.call @TComponent06A::@Component06A::@constrain(%b) : (!struct.type<@TComponent06A::@Component06A<[!array.type<@T x i1>]>>) -> ()
        function.return
      }
    }
  }
}
