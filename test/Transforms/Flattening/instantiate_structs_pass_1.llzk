module attributes {llzk.lang} {
  poly.template @TComponent05 {
    poly.param @S
    poly.param @T

    struct.def @Component05 {
      struct.member @f : !array.type<@S x !poly.tvar<@T>>

      function.def @compute() -> !struct.type<@TComponent05::@Component05<[@S, @T]>> {
        %self = struct.new : !struct.type<@TComponent05::@Component05<[@S, @T]>>
        %arr = array.new : !array.type<@S x !poly.tvar<@T>>
        %lb = arith.constant 0 : index
        %up = poly.read_const @S : index
        %step = arith.constant 1 : index
        scf.for %iv = %lb to %up step %step {
          // Although a type variable is used, this struct can only be instantiated
          //  with `@T = index` since an `index` value is assigned to the tvar array.
          array.write %arr[%iv] = %iv : !array.type<@S x !poly.tvar<@T>>, index
        }
        struct.writem %self[@f] = %arr : !struct.type<@TComponent05::@Component05<[@S, @T]>>, !array.type<@S x !poly.tvar<@T>>
        function.return %self : !struct.type<@TComponent05::@Component05<[@S, @T]>>
      }

      function.def @constrain(%self: !struct.type<@TComponent05::@Component05<[@S, @T]>>) {
        %arr = struct.readm %self[@f] : !struct.type<@TComponent05::@Component05<[@S, @T]>>, !array.type<@S x !poly.tvar<@T>>
        %lb = arith.constant 0 : index
        %up = poly.read_const @S : index
        %step = arith.constant 1 : index
        scf.for %iv = %lb to %up step %step {
          %temp = array.read %arr[%iv] : !array.type<@S x !poly.tvar<@T>>, !poly.tvar<@T>
          constrain.eq %temp, %iv : !poly.tvar<@T>, index // requires that @T==index
        }
        function.return
      }
    }
  }
  struct.def @Main {
    struct.member @sub : !struct.type<@TComponent05::@Component05<[5, index]>>

    function.def @compute() -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      %1 = function.call @TComponent05::@Component05::@compute() : () -> !struct.type<@TComponent05::@Component05<[5, index]>>
      struct.writem %self[@sub] = %1 : !struct.type<@Main>, !struct.type<@TComponent05::@Component05<[5, index]>>
      function.return %self : !struct.type<@Main>
    }
    function.def @constrain(%self: !struct.type<@Main>) {
      %1 = struct.readm %self[@sub] : !struct.type<@Main>, !struct.type<@TComponent05::@Component05<[5, index]>>
      function.call @TComponent05::@Component05::@constrain(%1) : (!struct.type<@TComponent05::@Component05<[5, index]>>) -> ()
      function.return
    }
  }
}
