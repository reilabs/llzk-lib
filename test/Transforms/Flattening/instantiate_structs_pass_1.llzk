module attributes {llzk.lang} {
  poly.template @TComponent04A {
    poly.param @A

    struct.def @Component04A {
      struct.member @f : !array.type<@A,@A x index>

      function.def @compute(%0: !array.type<@A,@A x index>) -> !struct.type<@TComponent04A::@Component04A<[@A]>> {
        %self = struct.new : !struct.type<@TComponent04A::@Component04A<[@A]>>
        struct.writem %self[@f] = %0 : !struct.type<@TComponent04A::@Component04A<[@A]>>, !array.type<@A,@A x index>
        function.return %self : !struct.type<@TComponent04A::@Component04A<[@A]>>
      }
      function.def @constrain(%self: !struct.type<@TComponent04A::@Component04A<[@A]>>, %0: !array.type<@A,@A x index>) {
        %b = struct.readm %self[@f] : !struct.type<@TComponent04A::@Component04A<[@A]>>, !array.type<@A,@A x index>
        function.return
      }
    }
  }

  function.def @producer() -> !array.type<2,2 x index> {
    %1 = arith.constant 11 : index
    %2 = arith.constant 22 : index
    %3 = arith.constant 33 : index
    %4 = arith.constant 44 : index
    %r = array.new %1, %2, %3, %4 : !array.type<2,2 x index>
    function.return %r: !array.type<2,2 x index>
  }

  struct.def @Component04B {
    struct.member @g : !struct.type<@TComponent04A::@Component04A<[2]>>

    function.def @compute() -> !struct.type<@Component04B> {
      %self = struct.new : !struct.type<@Component04B>
      %0 = function.call @producer() : () -> !array.type<2,2 x index>
      %1 = function.call @TComponent04A::@Component04A::@compute(%0) : (!array.type<2,2 x index>) -> !struct.type<@TComponent04A::@Component04A<[2]>>
      struct.writem %self[@g] = %1 : !struct.type<@Component04B>, !struct.type<@TComponent04A::@Component04A<[2]>>
      function.return %self : !struct.type<@Component04B>
    }
    function.def @constrain(%self: !struct.type<@Component04B>) {
      function.return
    }
  }
}
// CHECK-LABEL: struct.def @TComponent04A_2_Component04A {
// CHECK-NEXT:    struct.member @f : !array.type<2,2 x index>
// CHECK-NEXT:    function.def @compute(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !array.type<2,2 x index>) -> !struct.type<@TComponent04A_2_Component04A> attributes {function.allow_witness} {
// CHECK-NEXT:      %[[VAL_1:[0-9a-zA-Z_\.]+]] = struct.new : <@TComponent04A_2_Component04A>
// CHECK-NEXT:      struct.writem %[[VAL_1]][@f] = %[[VAL_0]] : <@TComponent04A_2_Component04A>, !array.type<2,2 x index>
// CHECK-NEXT:      function.return %[[VAL_1]] : !struct.type<@TComponent04A_2_Component04A>
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[VAL_2:[0-9a-zA-Z_\.]+]]: !struct.type<@TComponent04A_2_Component04A>, %[[VAL_3:[0-9a-zA-Z_\.]+]]: !array.type<2,2 x index>) attributes {function.allow_constraint} {
// CHECK-NEXT:      %[[VAL_4:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_2]][@f] : <@TComponent04A_2_Component04A>, !array.type<2,2 x index>
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:  }
//
// CHECK-LABEL: function.def @producer() -> !array.type<2,2 x index> {
// CHECK-NEXT:    %[[VAL_0:[0-9a-zA-Z_\.]+]] = arith.constant 11 : index
// CHECK-NEXT:    %[[VAL_1:[0-9a-zA-Z_\.]+]] = arith.constant 22 : index
// CHECK-NEXT:    %[[VAL_2:[0-9a-zA-Z_\.]+]] = arith.constant 33 : index
// CHECK-NEXT:    %[[VAL_3:[0-9a-zA-Z_\.]+]] = arith.constant 44 : index
// CHECK-NEXT:    %[[VAL_4:[0-9a-zA-Z_\.]+]] = array.new %[[VAL_0]], %[[VAL_1]], %[[VAL_2]], %[[VAL_3]] : <2,2 x index>
// CHECK-NEXT:    function.return %[[VAL_4]] : !array.type<2,2 x index>
// CHECK-NEXT:  }
//
// CHECK-LABEL: struct.def @Component04B {
// CHECK-NEXT:    struct.member @g : !struct.type<@TComponent04A_2_Component04A>
// CHECK-NEXT:    function.def @compute() -> !struct.type<@Component04B> attributes {function.allow_witness} {
// CHECK-NEXT:      %[[VAL_0:[0-9a-zA-Z_\.]+]] = struct.new : <@Component04B>
