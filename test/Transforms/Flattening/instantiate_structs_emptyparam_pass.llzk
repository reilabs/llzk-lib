// RUN: llzk-opt -split-input-file -llzk-flatten %s | FileCheck --enable-var-scope %s

module attributes {llzk.lang} {
  poly.template @TComponent1A {
    struct.def @Component1A {
      function.def @constrain(%self: !struct.type<@TComponent1A::@Component1A<[]>>) { function.return }
      function.def @compute() -> !struct.type<@TComponent1A::@Component1A<[]>> {
        %self = struct.new : !struct.type<@TComponent1A::@Component1A<[]>>
        function.return %self : !struct.type<@TComponent1A::@Component1A<[]>>
      }
    }
  }

  struct.def @Component1B {
    function.def @compute(%p: !struct.type<@TComponent1A::@Component1A<[]>>) -> !struct.type<@Component1B> {
      %self = struct.new : !struct.type<@Component1B>
      function.return %self : !struct.type<@Component1B>
    }

    function.def @constrain(%self: !struct.type<@Component1B>, %p: !struct.type<@TComponent1A::@Component1A<[]>>) {
      function.return
    }
  }
}
// CHECK-LABEL: module @TComponent1A {
// CHECK-NEXT:    struct.def @Component1A {
// CHECK-NEXT:      function.def @constrain(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !struct.type<@TComponent1A::@Component1A>) attributes {function.allow_constraint} {
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @compute() -> !struct.type<@TComponent1A::@Component1A> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_1:[0-9a-zA-Z_\.]+]] = struct.new : <@TComponent1A::@Component1A>
// CHECK-NEXT:        function.return %[[VAL_1]] : !struct.type<@TComponent1A::@Component1A>
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }
//
// CHECK-LABEL: struct.def @Component1B {
// CHECK-NEXT:    function.def @compute(%[[VAL_2:[0-9a-zA-Z_\.]+]]: !struct.type<@TComponent1A::@Component1A>) -> !struct.type<@Component1B> attributes {function.allow_witness} {
// CHECK-NEXT:      %[[VAL_3:[0-9a-zA-Z_\.]+]] = struct.new : <@Component1B>
// CHECK-NEXT:      function.return %[[VAL_3]] : !struct.type<@Component1B>
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[VAL_4:[0-9a-zA-Z_\.]+]]: !struct.type<@Component1B>, %[[VAL_5:[0-9a-zA-Z_\.]+]]: !struct.type<@TComponent1A::@Component1A>) attributes {function.allow_constraint} {
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:  }
// -----

module attributes {llzk.lang} {
  poly.template @TComponent2A {
    struct.def @Component2A {
      function.def @constrain(%self: !struct.type<@TComponent2A::@Component2A<[]>>) { function.return }
      function.def @compute() -> !struct.type<@TComponent2A::@Component2A<[]>> {
        %self = struct.new : !struct.type<@TComponent2A::@Component2A<[]>>
        function.return %self : !struct.type<@TComponent2A::@Component2A<[]>>
      }
    }
  }

  struct.def @Main {
    struct.member @b : !struct.type<@TComponent2A::@Component2A<[]>>
    function.def @compute() -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      %b = function.call @TComponent2A::@Component2A::@compute() : () -> !struct.type<@TComponent2A::@Component2A<[]>>
      struct.writem %self[@b] = %b : !struct.type<@Main>, !struct.type<@TComponent2A::@Component2A<[]>>
      function.return %self : !struct.type<@Main>
    }

    function.def @constrain(%self: !struct.type<@Main>) {
      function.return
    }
  }
}
// CHECK-LABEL: module @TComponent2A {
// CHECK-NEXT:    struct.def @Component2A {
// CHECK-NEXT:      function.def @constrain(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !struct.type<@TComponent2A::@Component2A>) attributes {function.allow_constraint} {
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @compute() -> !struct.type<@TComponent2A::@Component2A> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_1:[0-9a-zA-Z_\.]+]] = struct.new : <@TComponent2A::@Component2A>
// CHECK-NEXT:        function.return %[[VAL_1]] : !struct.type<@TComponent2A::@Component2A>
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }
//
// CHECK-LABEL: struct.def @Main {
// CHECK-NEXT:    struct.member @b : !struct.type<@TComponent2A::@Component2A>
// CHECK-NEXT:    function.def @compute() -> !struct.type<@Main> attributes {function.allow_witness} {
// CHECK-NEXT:      %[[VAL_2:[0-9a-zA-Z_\.]+]] = struct.new : <@Main>
// CHECK-NEXT:      %[[VAL_3:[0-9a-zA-Z_\.]+]] = function.call @TComponent2A::@Component2A::@compute() : () -> !struct.type<@TComponent2A::@Component2A>
// CHECK-NEXT:      struct.writem %[[VAL_2]][@b] = %[[VAL_3]] : <@Main>, !struct.type<@TComponent2A::@Component2A>
// CHECK-NEXT:      function.return %[[VAL_2]] : !struct.type<@Main>
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[VAL_4:[0-9a-zA-Z_\.]+]]: !struct.type<@Main>) attributes {function.allow_constraint} {
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:  }
