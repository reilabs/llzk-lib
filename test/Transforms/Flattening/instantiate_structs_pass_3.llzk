module attributes {llzk.lang} {
  poly.template @NeedsTemplateParam {
    poly.param @A

    function.def @id() -> index {
      %a = poly.read_const @A : index
      function.return %a : index
    }
  }

  struct.def @Main {
    function.def @compute() -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      %0 = function.call @NeedsTemplateParam::@id<[89]>() : () -> index
      function.return %self : !struct.type<@Main>
    }

    function.def @constrain(%self: !struct.type<@Main>) { function.return }
  }
}
