module attributes {llzk.lang} {
  poly.template @template_expr_A {
    poly.param @N : index
    poly.expr @M {
      %n = poly.read_const @N : index
      %c2 = arith.constant 2 : index
      %m = arith.muli %n, %c2 : index
      poly.yield %m : index
    }

    function.def @f(%inp: !array.type<@N x !felt.type>) -> index {
      %m = poly.read_const @M : index
      function.return %m : index
    }
  }

  struct.def @Main {
    function.def @compute(%z: !array.type<5 x !felt.type>) -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      function.call @template_expr_A::@f(%z) : (!array.type<5 x !felt.type>) -> index
      function.return %self : !struct.type<@Main>
    }
    function.def @constrain(%self: !struct.type<@Main>, %z: !array.type<5 x !felt.type>) {
      function.return
    }
  }
}
