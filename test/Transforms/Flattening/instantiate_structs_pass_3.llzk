module attributes {llzk.lang} {
  poly.template @TemplateA {
    poly.param @A : !felt.type<"goldilocks">
    poly.param @B : !felt.type<"goldilocks">
    poly.expr @C {
      %a = poly.read_const @A : !felt.type<"goldilocks">
      %b = poly.read_const @B : !felt.type<"goldilocks">
      %c = felt.add %a, %b : !felt.type<"goldilocks">, !felt.type<"goldilocks">
      poly.yield %c : !felt.type<"goldilocks">
    }

    struct.def @StructA {
      struct.member @f1 : !felt.type<"goldilocks">
      function.def @compute() -> !struct.type<@TemplateA::@StructA<[@A, @B]>> {
        %self = struct.new : !struct.type<@TemplateA::@StructA<[@A, @B]>>
        %c = poly.read_const @C : !felt.type<"goldilocks">
        struct.writem %self[@f1] = %c : !struct.type<@TemplateA::@StructA<[@A, @B]>>, !felt.type<"goldilocks">
        function.return %self : !struct.type<@TemplateA::@StructA<[@A, @B]>>
      }
      function.def @constrain(%self: !struct.type<@TemplateA::@StructA<[@A, @B]>>)   {
        function.return
      }
    }
  }

  struct.def @Main {
    struct.member @f1 : !struct.type<@TemplateA::@StructA<[56, 9]>>
    struct.member @f2 : !struct.type<@TemplateA::@StructA<[8, 25]>>

    function.def @compute() -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      %x = function.call @TemplateA::@StructA::@compute() : () -> (!struct.type<@TemplateA::@StructA<[56, 9]>>)
      struct.writem %self[@f1] = %x : !struct.type<@Main>, !struct.type<@TemplateA::@StructA<[56, 9]>>
      %y = function.call @TemplateA::@StructA::@compute() : () -> (!struct.type<@TemplateA::@StructA<[8, 25]>>)
      struct.writem %self[@f2] = %y : !struct.type<@Main>, !struct.type<@TemplateA::@StructA<[8, 25]>>
      function.return %self : !struct.type<@Main>
    }

    function.def @constrain(%self: !struct.type<@Main>) {
      function.return
    }
  }
}
