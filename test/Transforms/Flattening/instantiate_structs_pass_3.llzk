module attributes {llzk.lang} {
  poly.template @TemplateB {
    poly.param @A : !felt.type<"bn254">
    poly.param @B : !felt.type<"bn254">
    poly.expr @C {
      %a = poly.read_const @A : !felt.type<"bn254">
      %b = poly.read_const @B : !felt.type<"bn254">
      %c = felt.add %a, %b : !felt.type<"bn254">, !felt.type<"bn254">
      poly.yield %c : !felt.type<"bn254">
    }
    poly.expr @D {
      %a = poly.read_const @A : !felt.type<"bn254">
      %b = poly.read_const @B : !felt.type<"bn254">
      %d = felt.mul %a, %b : !felt.type<"bn254">, !felt.type<"bn254">
      poly.yield %d : !felt.type<"bn254">
    }

    struct.def @StructB {
      struct.member @sum : !felt.type<"bn254">
      struct.member @prod : !felt.type<"bn254">
      function.def @compute() -> !struct.type<@TemplateB::@StructB<[@A, @B]>> {
        %self = struct.new : !struct.type<@TemplateB::@StructB<[@A, @B]>>
        %c = poly.read_const @C : !felt.type<"bn254">
        %d = poly.read_const @D : !felt.type<"bn254">
        struct.writem %self[@sum] = %c : !struct.type<@TemplateB::@StructB<[@A, @B]>>, !felt.type<"bn254">
        struct.writem %self[@prod] = %d : !struct.type<@TemplateB::@StructB<[@A, @B]>>, !felt.type<"bn254">
        function.return %self : !struct.type<@TemplateB::@StructB<[@A, @B]>>
      }
      function.def @constrain(%self: !struct.type<@TemplateB::@StructB<[@A, @B]>>) {
        function.return
      }
    }
  }

  struct.def @Main {
    struct.member @f1 : !struct.type<@TemplateB::@StructB<[4, 3]>>

    function.def @compute() -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      %x = function.call @TemplateB::@StructB::@compute() : () -> (!struct.type<@TemplateB::@StructB<[4, 3]>>)
      struct.writem %self[@f1] = %x : !struct.type<@Main>, !struct.type<@TemplateB::@StructB<[4, 3]>>
      function.return %self : !struct.type<@Main>
    }

    function.def @constrain(%self: !struct.type<@Main>) {
      function.return
    }
  }
}
