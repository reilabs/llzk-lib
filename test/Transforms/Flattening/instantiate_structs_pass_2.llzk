// COM: Must use a separate FileCheck for each instantiated version of the structs because
// COM:   there is no guarantee on the order they will be produced. The final FileCheck
// COM:   runs on the last component that uses the default "CHECK" prefix.
//
// RUN: llzk-opt -llzk-flatten %s > %t \
// RUN:   && FileCheck %s --check-prefix CHECK1 < %t \
// RUN:   && FileCheck %s --check-prefix CHECK2 < %t \
// RUN:   && FileCheck %s --check-prefix CHECK3 < %t \
// RUN:   && FileCheck %s < %t

module attributes {llzk.lang} {
  poly.template @T08A {
    poly.param @A
    poly.param @B

    struct.def @Component08A {
      function.def @compute() -> !struct.type<@T08A::@Component08A<[@A, @B]>> {
        %self = struct.new : !struct.type<@T08A::@Component08A<[@A, @B]>>
        function.return %self : !struct.type<@T08A::@Component08A<[@A, @B]>>
      }
      function.def @constrain(%self: !struct.type<@T08A::@Component08A<[@A, @B]>>) { function.return }
    }
  }

  poly.template @T08B {
    poly.param @C

    struct.def @Component08B {
      struct.member @f2 : !struct.type<@T08A::@Component08A<[5, @C]>>

      function.def @compute() -> !struct.type<@T08B::@Component08B<[@C]>> {
        %self = struct.new : !struct.type<@T08B::@Component08B<[@C]>>
        %x = function.call @T08A::@Component08A::@compute() : () -> (!struct.type<@T08A::@Component08A<[5, @C]>>)
        struct.writem %self[@f2] = %x : !struct.type<@T08B::@Component08B<[@C]>>, !struct.type<@T08A::@Component08A<[5, @C]>>
        function.return %self : !struct.type<@T08B::@Component08B<[@C]>>
      }

      function.def @constrain(%self: !struct.type<@T08B::@Component08B<[@C]>>) {
        %b = struct.readm %self[@f2] : !struct.type<@T08B::@Component08B<[@C]>>, !struct.type<@T08A::@Component08A<[5, @C]>>
        function.call @T08A::@Component08A::@constrain(%b) : (!struct.type<@T08A::@Component08A<[5, @C]>>) -> ()
        function.return
      }
    }
  }

  struct.def @Component08C {
    struct.member @f3 : !struct.type<@T08B::@Component08B<[7]>>
    struct.member @f4 : !struct.type<@T08B::@Component08B<[!felt.type]>>
    struct.member @f5 : !struct.type<@T08B::@Component08B<[7]>>
    struct.member @f6 : !struct.type<@T08B::@Component08B<[5]>>

    function.def @compute() -> !struct.type<@Component08C> {
      %self = struct.new : !struct.type<@Component08C>

      %1 = function.call @T08B::@Component08B::@compute() : () -> (!struct.type<@T08B::@Component08B<[7]>>)
      struct.writem %self[@f3] = %1 : !struct.type<@Component08C>, !struct.type<@T08B::@Component08B<[7]>>

      %2 = function.call @T08B::@Component08B::@compute() : () -> (!struct.type<@T08B::@Component08B<[!felt.type]>>)
      struct.writem %self[@f4] = %2 : !struct.type<@Component08C>, !struct.type<@T08B::@Component08B<[!felt.type]>>

      %3 = function.call @T08B::@Component08B::@compute() : () -> (!struct.type<@T08B::@Component08B<[7]>>)
      struct.writem %self[@f5] = %3 : !struct.type<@Component08C>, !struct.type<@T08B::@Component08B<[7]>>

      %4 = function.call @T08B::@Component08B::@compute() : () -> (!struct.type<@T08B::@Component08B<[5]>>)
      struct.writem %self[@f6] = %4 : !struct.type<@Component08C>, !struct.type<@T08B::@Component08B<[5]>>

      function.return %self : !struct.type<@Component08C>
    }

    function.def @constrain(%self: !struct.type<@Component08C>) {
      %1 = struct.readm %self[@f3] : !struct.type<@Component08C>, !struct.type<@T08B::@Component08B<[7]>>
      function.call @T08B::@Component08B::@constrain(%1) : (!struct.type<@T08B::@Component08B<[7]>>) -> ()

      %2 = struct.readm %self[@f4] : !struct.type<@Component08C>, !struct.type<@T08B::@Component08B<[!felt.type]>>
      function.call @T08B::@Component08B::@constrain(%2) : (!struct.type<@T08B::@Component08B<[!felt.type]>>) -> ()

      %3 = struct.readm %self[@f5] : !struct.type<@Component08C>, !struct.type<@T08B::@Component08B<[7]>>
      function.call @T08B::@Component08B::@constrain(%3) : (!struct.type<@T08B::@Component08B<[7]>>) -> ()

      %4 = struct.readm %self[@f6] : !struct.type<@Component08C>, !struct.type<@T08B::@Component08B<[5]>>
      function.call @T08B::@Component08B::@constrain(%4) : (!struct.type<@T08B::@Component08B<[5]>>) -> ()

      function.return
    }
  }
}
