module attributes {llzk.lang} {
  poly.template @template_b1 {
    poly.param @X
    function.def @f(%inp: !array.type<8,@X x !felt.type>) -> !felt.type {
      %c0 = arith.constant 0 : index
      %2 = array.read %inp[%c0, %c0] : !array.type<8,@X x !felt.type>, !felt.type
      function.return %2 : !felt.type
    }
  }

  poly.template @template_b2 {
    poly.param @N : index
    poly.param @M : index
    poly.param @T : !poly.tvar<@T>
    function.def @f(%inp: !array.type<@N,@M x !poly.tvar<@T>>) -> !poly.tvar<@T> {
      %2 = function.call @template_b1::@f<[@N]>(%inp) : (!array.type<@N,@M x !poly.tvar<@T>>) -> !poly.tvar<@T>
      function.return %2 : !poly.tvar<@T>
    }
  }

  struct.def @Main {
    function.def @compute(%z: !array.type<8,9 x !felt.type>) -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      function.call @template_b2::@f(%z) : (!array.type<8,9 x !felt.type>) -> !felt.type
      function.return %self : !struct.type<@Main>
    }
    function.def @constrain(%self: !struct.type<@Main>, %z: !array.type<8,9 x !felt.type>) {
      function.return
    }
  }
}
