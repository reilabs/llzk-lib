// Similar to previous but there is eventually a concrete instantiation of intermediate partial instantiations.
// No cleanup runs in this test so the partials are left in the output IR.
module attributes {llzk.lang} {
  poly.template @template_k1 {
    poly.param @A : index
    poly.param @B : index

    function.def @f(%inp: !array.type<@A,@B x !felt.type>) -> !felt.type {
      %c0 = arith.constant 0 : index
      %r = array.read %inp[%c0, %c0] : !array.type<@A,@B x !felt.type>, !felt.type
      function.return %r : !felt.type
    }
  }

  poly.template @template_k2 {
    poly.param @N : index

    function.def @g(%inp: !array.type<8,@N x !felt.type>) -> !felt.type {
      %r = function.call @template_k1::@f(%inp) : (!array.type<8,@N x !felt.type>) -> !felt.type
      function.return %r : !felt.type
    }
  }

  struct.def @Main {
    function.def @compute(%z: !array.type<8,5 x !felt.type>) -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      function.call @template_k2::@g(%z) : (!array.type<8,5 x !felt.type>) -> !felt.type
      function.return %self : !struct.type<@Main>
    }
    function.def @constrain(%self: !struct.type<@Main>, %z: !array.type<8,5 x !felt.type>) {
      function.return
    }
  }
}
