// RUN: llzk-opt -split-input-file -llzk-flatten -verify-diagnostics %s | FileCheck --enable-var-scope %s

#IdxToLen = affine_map<(i)->(2*i)>
#Values = affine_map<(i,j)->(5*j+i)>
!ToFelt = !struct.type<@TToFelt::@ToFelt<[#Values]>>
!HeterArr = !struct.type<@TVarArray::@VarArray<[#IdxToLen, !ToFelt]>>
module attributes {llzk.lang} {
  // pre-defined
  poly.template @TVarArray {
    poly.param @N
    poly.param @T

    struct.def @VarArray {
      struct.member @val: !array.type<@N x !poly.tvar<@T>>

      function.def @compute(%inp: !array.type<@N x !poly.tvar<@T>>) -> !struct.type<@TVarArray::@VarArray<[@N, @T]>> {
        %self = struct.new : !struct.type<@TVarArray::@VarArray<[@N, @T]>>
        struct.writem %self[@val] = %inp : !struct.type<@TVarArray::@VarArray<[@N, @T]>>, !array.type<@N x !poly.tvar<@T>>
        function.return %self : !struct.type<@TVarArray::@VarArray<[@N, @T]>>
      }

      function.def @constrain(%self: !struct.type<@TVarArray::@VarArray<[@N, @T]>>, %inp: !array.type<@N x !poly.tvar<@T>>) {
        function.return
      }
    }
  }

  poly.template @TToFelt {
    poly.param @A

    struct.def @ToFelt {
      struct.member @out: !felt.type {llzk.pub}

      function.def @compute() -> !struct.type<@TToFelt::@ToFelt<[@A]>> {
        %self = struct.new : !struct.type<@TToFelt::@ToFelt<[@A]>>
        %constA = poly.read_const @A : !felt.type
        struct.writem %self[@out] = %constA : !struct.type<@TToFelt::@ToFelt<[@A]>>, !felt.type
        function.return %self: !struct.type<@TToFelt::@ToFelt<[@A]>>
      }

      function.def @constrain(%self: !struct.type<@TToFelt::@ToFelt<[@A]>>) {
        function.return
      }
    }
  }

  poly.template @TN {
    poly.param @N

    struct.def @TestLoopWithAffineArrayStruct {
      // The `pub` here is intended to test that attributes are copied by
      //  UpdateMemberTypeFromWrite when creating a new MemberDefOp.
      struct.member @arrs: !array.type<@N x !HeterArr> {llzk.pub}

      function.def @compute() -> !struct.type<@TN::@TestLoopWithAffineArrayStruct<[@N]>> {
        %arrs_temp = array.new : !array.type<@N x !HeterArr>

        %0 = arith.constant 0 : index
        %1 = arith.constant 1 : index
        %n = poly.read_const @N : index
        %step = arith.constant 1 : index
        scf.for %i = %1 to %n step %step { // range: [1,N)
          // The array length is a function of 'i' and it contains non-homogeneous structs
          //    !ToFelt = !struct.type<@ToFelt<[#Values]>>
          %arr = array.new{(%i)} : !array.type<#IdxToLen x !ToFelt>
          scf.for %j = %0 to %i step %step { // range: [0,i)
            %v = function.call @TToFelt::@ToFelt::@compute(){(%i, %j)} : () -> !ToFelt
            array.write %arr[%j] = %v : !array.type<#IdxToLen x !ToFelt>, !ToFelt
          }
          // Create a VarArray with length as a function of 'i' and non-homogeneous element type
          %va = function.call @TVarArray::@VarArray::@compute(%arr){(%i)} : (!array.type<#IdxToLen x !ToFelt>) -> !HeterArr
          array.write %arrs_temp[%i] = %va : !array.type<@N x !HeterArr>, !HeterArr
        }
        //
        %self = struct.new : !struct.type<@TN::@TestLoopWithAffineArrayStruct<[@N]>>
        struct.writem %self[@arrs] = %arrs_temp
              : !struct.type<@TN::@TestLoopWithAffineArrayStruct<[@N]>>, !array.type<@N x !HeterArr>
        function.return %self : !struct.type<@TN::@TestLoopWithAffineArrayStruct<[@N]>>
      }

      function.def @constrain(%self: !struct.type<@TN::@TestLoopWithAffineArrayStruct<[@N]>>) {
        function.return
      }
    }
  }

  struct.def @Main {
    function.def @compute() -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      %x = function.call @TN::@TestLoopWithAffineArrayStruct::@compute()
            : () -> !struct.type<@TN::@TestLoopWithAffineArrayStruct<[2]>>
      function.return %self: !struct.type<@Main>
    }

    function.def @constrain(%self: !struct.type<@Main>) {
      function.return
    }
  }
}
// CHECK-LABEL: struct.def @"TVarArray_2_!s<@TToFelt_1_ToFelt>_VarArray" {
// CHECK-NEXT:    struct.member @val : !array.type<2 x !struct.type<@TToFelt_1_ToFelt>>
// CHECK-NEXT:    function.def @compute(%[[V0:[0-9a-zA-Z_\.]+]]: !array.type<2 x !struct.type<@TToFelt_1_ToFelt>>) -> !struct.type<@"TVarArray_2_!s<@TToFelt_1_ToFelt>_VarArray"> attributes {function.allow_witness} {
// CHECK-NEXT:      %[[V1:[0-9a-zA-Z_\.]+]] = struct.new : <@"TVarArray_2_!s<@TToFelt_1_ToFelt>_VarArray">
// CHECK-NEXT:      struct.writem %[[V1]][@val] = %[[V0]] : <@"TVarArray_2_!s<@TToFelt_1_ToFelt>_VarArray">, !array.type<2 x !struct.type<@TToFelt_1_ToFelt>>
// CHECK-NEXT:      function.return %[[V1]] : !struct.type<@"TVarArray_2_!s<@TToFelt_1_ToFelt>_VarArray">
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[V2:[0-9a-zA-Z_\.]+]]: !struct.type<@"TVarArray_2_!s<@TToFelt_1_ToFelt>_VarArray">, %[[V3:[0-9a-zA-Z_\.]+]]: !array.type<2 x !struct.type<@TToFelt_1_ToFelt>>) attributes {function.allow_constraint} {
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:  }
//
// CHECK-LABEL: struct.def @TToFelt_1_ToFelt {
// CHECK-NEXT:    struct.member @out : !felt.type {llzk.pub}
// CHECK-NEXT:    function.def @compute() -> !struct.type<@TToFelt_1_ToFelt> attributes {function.allow_witness} {
// CHECK-NEXT:      %[[V4:[0-9a-zA-Z_\.]+]] = felt.const  1
// CHECK-NEXT:      %[[V5:[0-9a-zA-Z_\.]+]] = struct.new : <@TToFelt_1_ToFelt>
// CHECK-NEXT:      struct.writem %[[V5]][@out] = %[[V4]] : <@TToFelt_1_ToFelt>, !felt.type
// CHECK-NEXT:      function.return %[[V5]] : !struct.type<@TToFelt_1_ToFelt>
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[V6:[0-9a-zA-Z_\.]+]]: !struct.type<@TToFelt_1_ToFelt>) attributes {function.allow_constraint} {
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:  }
//
// CHECK-LABEL: struct.def @TN_2_TestLoopWithAffineArrayStruct {
// CHECK-NEXT:    struct.member @arrs : !array.type<2 x !struct.type<@"TVarArray_2_!s<@TToFelt_1_ToFelt>_VarArray">> {llzk.pub}
// CHECK-NEXT:    function.def @compute() -> !struct.type<@TN_2_TestLoopWithAffineArrayStruct> attributes {function.allow_witness} {
// CHECK-NEXT:      %[[V7:[0-9a-zA-Z_\.]+]] = arith.constant 1 : index
// CHECK-NEXT:      %[[V8:[0-9a-zA-Z_\.]+]] = arith.constant 0 : index
// CHECK-NEXT:      %[[V9:[0-9a-zA-Z_\.]+]] = array.new  : <2 x !struct.type<@"TVarArray_2_!s<@TToFelt_1_ToFelt>_VarArray">>
// CHECK-NEXT:      %[[V10:[0-9a-zA-Z_\.]+]] = array.new  : <2 x !struct.type<@TToFelt_1_ToFelt>>
// CHECK-NEXT:      %[[V11:[0-9a-zA-Z_\.]+]] = function.call @TToFelt_1_ToFelt::@compute() : () -> !struct.type<@TToFelt_1_ToFelt>
// CHECK-NEXT:      array.write %[[V10]]{{\[}}%[[V8]]] = %[[V11]] : <2 x !struct.type<@TToFelt_1_ToFelt>>, !struct.type<@TToFelt_1_ToFelt>
// CHECK-NEXT:      %[[V12:[0-9a-zA-Z_\.]+]] = function.call @"TVarArray_2_!s<@TToFelt_1_ToFelt>_VarArray"::@compute(%[[V10]]) : (!array.type<2 x !struct.type<@TToFelt_1_ToFelt>>) -> !struct.type<@"TVarArray_2_!s<@TToFelt_1_ToFelt>_VarArray">
// CHECK-NEXT:      array.write %[[V9]]{{\[}}%[[V7]]] = %[[V12]] : <2 x !struct.type<@"TVarArray_2_!s<@TToFelt_1_ToFelt>_VarArray">>, !struct.type<@"TVarArray_2_!s<@TToFelt_1_ToFelt>_VarArray">
// CHECK-NEXT:      %[[V13:[0-9a-zA-Z_\.]+]] = struct.new : <@TN_2_TestLoopWithAffineArrayStruct>
// CHECK-NEXT:      struct.writem %[[V13]][@arrs] = %[[V9]] : <@TN_2_TestLoopWithAffineArrayStruct>, !array.type<2 x !struct.type<@"TVarArray_2_!s<@TToFelt_1_ToFelt>_VarArray">>
// CHECK-NEXT:      function.return %[[V13]] : !struct.type<@TN_2_TestLoopWithAffineArrayStruct>
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[V14:[0-9a-zA-Z_\.]+]]: !struct.type<@TN_2_TestLoopWithAffineArrayStruct>) attributes {function.allow_constraint} {
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:  }
