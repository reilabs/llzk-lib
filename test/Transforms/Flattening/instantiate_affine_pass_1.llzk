// CHECK-NEXT:      %[[V16:[0-9a-zA-Z_\.]+]] = function.call @TN_2_TestLoopWithAffineArrayStruct::@compute() : () -> !struct.type<@TN_2_TestLoopWithAffineArrayStruct>
// CHECK-NEXT:      function.return %[[V15]] : !struct.type<@Main>
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[V17:[0-9a-zA-Z_\.]+]]: !struct.type<@Main>) attributes {function.allow_constraint} {
// CHECK-NEXT:      function.return
