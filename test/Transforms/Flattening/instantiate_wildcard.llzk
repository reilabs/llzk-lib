module attributes {llzk.lang} {
  poly.template @LaterConcrete {
    poly.param @A : !poly.tvar<@A>
    poly.param @B : !poly.tvar<@B>

    function.def @bridge(%arg0: !poly.tvar<@B>) {
      %0 = poly.unifiable_cast %arg0 : (!poly.tvar<@B>) -> !poly.tvar<@A>
      function.return
    }
  }

  poly.template @UseLaterConcrete {
    struct.def @UseLaterConcrete {
      function.def @compute(%arg0: !felt.type<"bn128">) -> !struct.type<@UseLaterConcrete::@UseLaterConcrete<[]>> {
        %self = struct.new : !struct.type<@UseLaterConcrete::@UseLaterConcrete<[]>>
        function.call @LaterConcrete::@bridge<[?, !felt.type<"bn128">]>(%arg0) : (!felt.type<"bn128">) -> ()
        function.return %self : !struct.type<@UseLaterConcrete::@UseLaterConcrete<[]>>
      }

      function.def @constrain(
          %self: !struct.type<@UseLaterConcrete::@UseLaterConcrete<[]>>,
          %arg0: !felt.type<"bn128">) {
        function.call @LaterConcrete::@bridge<[?, !felt.type<"bn128">]>(%arg0) : (!felt.type<"bn128">) -> ()
        function.return
      }
    }
  }
}
