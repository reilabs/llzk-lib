// CHECK-LABEL: struct.def @Num2Bits_0 {
// CHECK:       function.def @product(%[[N2B_IN:[0-9a-zA-Z_\.]+]]: !felt.type) -> !struct.type<@Num2Bits_0> attributes {function.allow_constraint, function.allow_non_native_field_ops, function.allow_witness, llzk.derived} {
// CHECK:         %[[N2B_SELF:[0-9a-zA-Z_\.]+]] = struct.new : <@Num2Bits_0> {product_source = "compute"}
// CHECK:         %[[N2B_BITS:[0-9a-zA-Z_\.]+]] = llzk.nondet : !array.type<33 x !felt.type> {product_source = "compute"}
// CHECK:         struct.writem %[[N2B_SELF]][@out] = %[[N2B_BITS]] : <@Num2Bits_0>, !array.type<33 x !felt.type> {product_source = "compute"}
// CHECK:         %[[N2B_READ:[0-9a-zA-Z_\.]+]] = struct.readm %[[N2B_SELF]][@out] : <@Num2Bits_0>, !array.type<33 x !felt.type> {product_source = "constrain"}
// CHECK:         constrain.eq %{{.*}}, %[[N2B_IN]] : !felt.type, !felt.type {product_source = "constrain"}
// CHECK:         function.return %[[N2B_SELF]] : !struct.type<@Num2Bits_0>
// CHECK:       }

// CHECK-LABEL: struct.def @LessThan_1 {
// CHECK:       function.def @product(%[[LT_IN:[0-9a-zA-Z_\.]+]]: !array.type<2 x !felt.type>) -> !struct.type<@LessThan_1> attributes {function.allow_constraint, function.allow_non_native_field_ops, function.allow_witness, llzk.derived} {
// CHECK:         %[[LT_SELF:[0-9a-zA-Z_\.]+]] = struct.new : <@LessThan_1> {product_source = "compute"}
// CHECK:         %[[LT_POD:[0-9a-zA-Z_\.]+]] = pod.new { @count = %{{.*}} }  : <[@count: index, @comp: !struct.type<@Num2Bits_0>, @params: !pod.type<[]>]> {product_source = "compute"}
// CHECK:         %[[LT_INPUTS:[0-9a-zA-Z_\.]+]] = pod.new : <[@in: !felt.type]> {product_source = "compute"}
// CHECK:         bool.assert %{{.*}}, "assertion failed" {product_source = "compute"}
// CHECK:         pod.write %[[LT_INPUTS]][@in] = %{{.*}} : <[@in: !felt.type]>, !felt.type {product_source = "compute"}
// CHECK:         %[[LT_PROD_ARG:[0-9a-zA-Z_\.]+]] = pod.read %[[LT_INPUTS]][@in] : <[@in: !felt.type]>, !felt.type {product_source = "compute"}
// CHECK:         %[[LT_PROD_COMP:[0-9a-zA-Z_\.]+]] = function.call @Num2Bits_0::@product(%[[LT_PROD_ARG]]) : (!felt.type) -> !struct.type<@Num2Bits_0>
// CHECK:         pod.write %[[LT_POD]][@comp] = %[[LT_PROD_COMP]] : <[@count: index, @comp: !struct.type<@Num2Bits_0>, @params: !pod.type<[]>]>, !struct.type<@Num2Bits_0> {product_source = "compute"}
// CHECK:         struct.writem %[[LT_SELF]][@n2b$inputs] = %[[LT_INPUTS]] : <@LessThan_1>, !pod.type<[@in: !felt.type]> {product_source = "compute"}
// CHECK:         %[[LT_COMP:[0-9a-zA-Z_\.]+]] = pod.read %[[LT_POD]][@comp] : <[@count: index, @comp: !struct.type<@Num2Bits_0>, @params: !pod.type<[]>]>, !struct.type<@Num2Bits_0> {product_source = "compute"}
// CHECK:         struct.writem %[[LT_SELF]][@n2b] = %[[LT_COMP]] : <@LessThan_1>, !struct.type<@Num2Bits_0> {product_source = "compute"}
// CHECK:         %[[LT_CONS_OUT:[0-9a-zA-Z_\.]+]] = struct.readm %[[LT_SELF]][@out] : <@LessThan_1>, !felt.type {product_source = "constrain"}
// CHECK:         function.call @Num2Bits_0::@constrain(%{{.*}}, %{{.*}}) : (!struct.type<@Num2Bits_0>, !felt.type) -> ()  {product_source = "constrain"}
// CHECK:         function.return %[[LT_SELF]] : !struct.type<@LessThan_1>
// CHECK:       }
