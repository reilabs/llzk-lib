      %13 = array.read %11[%12] : <33 x !felt.type>, !felt.type
      %14 = felt.sub %felt_const_1_2, %13 : !felt.type, !felt.type
      constrain.eq %0, %14 : !felt.type, !felt.type
      %15 = pod.read %2[@in] : <[@in: !felt.type]>, !felt.type
